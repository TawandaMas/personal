---
import Base from '../layouts/Base.astro';

import { getCollection } from 'astro:content';

const projectEntries = await getCollection('projects');
const projects = projectEntries
  .map(p => ({ ...p.data }))
  .sort((a, b) => (a.order || 99) - (b.order || 99));
---

<Base title="Projects">
  <div class="page-header">
    <h1>Projects</h1>
    <p>Things I've shipped, or am shipping.</p>
  </div>

  <div class="projects-list">
    {projectEntries.map(project => (
      <div class="project-row">
        {project.data.logo && (
          <div class="project-logo">
            <img src={project.data.logo} alt="" />
          </div>
        )}
        <div class="project-main">
          <div class="project-tag">{project.data.tag} · {project.data.year}</div>
          <h2 class="project-name">
            <a href={`/projects/${project.slug}`}>{project.data.title}</a>
          </h2>
          <p class="project-desc">{project.data.description}</p>
        </div>
        <div class="project-meta">
          <span class:list={['status-pip', project.data.status === 'Live' ? 'live' : 'wip']}></span>
          <span class="status-label">{project.data.status}</span>
          <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="external-arrow" title="Visit Site">
            <span class="arrow">↗</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</Base>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-row {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--rule);
    transition: opacity 0.2s;
  }

  .project-logo {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--paper-dark);
    border: 1px solid var(--rule);
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .project-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  .project-row:hover .project-name a { color: var(--accent); }
  .project-row:hover .arrow { transform: translate(3px, -3px); color: var(--accent); }

  .project-tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 0.4rem;
  }

  .project-name a {
    text-decoration: none;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.2;
    color: var(--ink);
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .project-desc {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--ink-mid);
    line-height: 1.65;
    max-width: 440px;
    margin-top: 0.5rem;
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
    flex-shrink: 0;
    padding-top: 0.3rem;
    margin-left: auto;
  }

  .status-pip {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ink-light);
  }

  .status-pip.live {
    background: #5a8a5e;
    box-shadow: 0 0 5px rgba(90,138,94,0.4);
  }

  .status-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 0.5rem;
  }

  .external-arrow {
    text-decoration: none;
  }

  .arrow {
    font-size: 1rem;
    color: var(--ink-light);
    margin-top: auto;
    transition: transform 0.2s, color 0.2s;
  }

  @media (max-width: 500px) {
    .project-row { flex-direction: column; gap: 1rem; }
    .project-meta { flex-direction: row; align-items: center; }
    .arrow { margin-top: 0; }
  }
</style>
