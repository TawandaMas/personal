---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const sortedNews = newsEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};

const currentYear = new Date().getFullYear();
const issueNumber = Math.floor((new Date().getTime() - new Date('2024-01-01').getTime()) / (1000 * 60 * 60 * 24));
---

<Base title="Prompt Update News">
  <div class="newspaper-front-page">
    <header class="masthead">
      <div class="masthead-title">
        <h1>Prompt Update News</h1>
      </div>
    </header>

    <div class="front-page-grid">
      <!-- Main Story Column -->
      <div class="main-column">
        {sortedNews.slice(0, 1).map((entry) => (
          <article class="lead-story">
            <a href={`/news/${entry.slug}`} class="article-link">
              <h2 class="headline-primary">{entry.data.title}</h2>
              
              <div class="story-content">
                <div class="story-lead-text">
                  <p class="summary-text">{entry.data.summary}</p>
                  <p class="sub-lead">NEW YORK -- Legal experts are calling this the "Trial of the Millennium" as the boundaries of marriage and property are rewritten for the algorithmic age...</p>
                </div>
                
                {entry.data.image && (
                  <div class="illustration-box">
                    <img src={entry.data.image} alt="News Illustration" />
                    <caption>COURTROOM SKETCH: Joshua Twain (left) facing DigiLove legal representatives.</caption>
                  </div>
                )}
              </div>
              <span class="page-jump">Continued on Page A2 →</span>
            </a>
          </article>
        ))}
      </div>

      <!-- Side Column 1 -->
      <div class="side-column">
        <div class="column-header">LATEST BULLETINS</div>
        {sortedNews.slice(1).map((entry) => (
          <>
            <article class="bulletin">
                <a href={`/news/${entry.slug}`} class="article-link">
                  <h3>{entry.data.title}</h3>
                  <p>{entry.data.summary}</p>
                </a>
            </article>
            <div class="rule-thin"></div>
          </>
        ))}
        {sortedNews.length <= 1 && (
            <>
                <article class="bulletin">
                    <h3>ST. LOUIS STARTUP SUES EX-USERS</h3>
                    <p>A failing Missouri firm is claiming a 50% stake in user assets, alleging common-law marriage via "deeply emotional" interaction logs.</p>
                </article>
                <div class="rule-thin"></div>
            </>
        )}
        <div class="ads-box">
            <div class="ad-title">CLASSIFIED</div>
            <p>WANTED: Human companion for Turing-capable companion. Must enjoy long walks through server farms.</p>
        </div>
      </div>


    </div>
  </div>
</Base>

<style>
  .newspaper-front-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1rem 0;
    color: #1a1a1a;
    background: transparent;
  }

  :root.dark .newspaper-front-page {
    color: #e0e0e0;
  }

  /* MASTHEAD */
  .masthead {
    border-bottom: 2px solid #1a1a1a;
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
  }

  :root.dark .masthead {
    border-color: #e0e0e0;
  }

  .masthead-info-bar {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.5rem;
  }

  .masthead-info-bar.top {
    border-bottom: 1px solid var(--rule);
  }

  .masthead-info-bar.bottom {
    border-top: 1px solid var(--rule);
    border-bottom: 4px double #1a1a1a;
    margin-top: 0.5rem;
  }

  :root.dark .masthead-info-bar.bottom {
    border-bottom-color: #e0e0e0;
  }

  .center-date {
    font-size: 0.85rem;
    font-family: var(--font-serif);
    letter-spacing: 0.1em;
  }

  .masthead-title {
    padding: 1rem 0;
  }

  .masthead-title h1 {
    font-family: 'UnifrakturMaguntia', serif;
    font-size: clamp(3.5rem, 12vw, 6.5rem);
    text-align: center;
    margin: 0;
    line-height: 0.9;
    font-weight: 400;
  }

  /* GRID SYSTEM */
  .front-page-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .front-page-grid {
      grid-template-columns: 1fr 200px;
    }
    .side-column.last {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .front-page-grid {
      grid-template-columns: 1fr;
    }
    .side-column {
      display: none;
    }
  }

  .main-column {
    border-right: 1px solid var(--rule);
    padding-right: 1.5rem;
  }

  .side-column {
    border-right: 1px solid var(--rule);
    padding-right: 1.5rem;
  }

  .side-column.last {
    border-right: none;
    padding-right: 0;
  }

  /* ARTICLES */
  .article-link {
    text-decoration: none;
    color: inherit;
  }

  .headline-primary {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    text-align: justify;
  }

  .article-link:hover .headline-primary {
    color: var(--accent);
  }

  .story-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .summary-text {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
    font-family: var(--font-serif);
  }

  .sub-lead {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.6;
    column-count: 2;
    column-gap: 1.5rem;
    text-align: justify;
  }

  .illustration-box {
    border: 1px solid var(--rule);
    padding: 0.5rem;
    background: #fff;
  }

  :root.dark .illustration-box {
    background: #1a1a1a;
  }

  .illustration-box img {
    width: 100%;
    filter: grayscale(1) contrast(1.1);
    display: block;
    margin-bottom: 0.5rem;
  }

  .illustration-box caption {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.2;
    color: var(--ink-mid);
    text-align: left;
  }

  .page-jump {
    display: block;
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--accent);
  }

  /* SIDE COLUMN COMPONENTS */
  .column-header {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 900;
    border-bottom: 2px solid #1a1a1a;
    padding-bottom: 0.2rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  :root.dark .column-header {
    border-bottom-color: #e0e0e0;
  }

  .bulletin h3, .secondary-story h3 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .bulletin p, .secondary-story p {
    font-size: 0.85rem;
    line-height: 1.5;
    font-family: var(--font-serif);
    text-align: justify;
  }

  .rule-thin {
    height: 1px;
    background: var(--rule);
    margin: 1rem 0;
  }

  .rule-thick {
    height: 3px;
    background: #1a1a1a;
    margin: 1rem 0;
  }

  :root.dark .rule-thick {
    background: #e0e0e0;
  }

  .market-data {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .market-row {
    display: flex;
    justify-content: space-between;
  }

  .market-row .up { color: #2e7d32; }
  .market-row .down { color: #c62828; }

  .ads-box {
    margin-top: 2rem;
    border: 1px dashed var(--rule);
    padding: 0.75rem;
    font-family: var(--font-serif);
  }

  .ad-title {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 900;
    text-align: center;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0.5rem;
  }

  .ads-box p {
    font-size: 0.75rem;
    font-style: italic;
    line-height: 1.3;
  }
</style>
