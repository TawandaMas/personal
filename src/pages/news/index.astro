---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const newsEntries = await getCollection('news');
const sortedNews = newsEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());



const currentYear = new Date().getFullYear();
const issueNumber = Math.floor((new Date().getTime() - new Date('2024-01-01').getTime()) / (1000 * 60 * 60 * 24));
---

<Base title="Prompt Update News">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">

  <div class="newspaper-container">
    <div class="newspaper-front-page">
      <header class="masthead">
        <div class="masthead-info-bar top">
            <span>VOL. CXIV ... No. 56,234</span>
            <span class="center-meta">{sortedNews[0]?.data.edition || 'LIVERPOOL'}, NEAR FUTURE</span>
            <span>PRICE: 2.50 CREDITS</span>
        </div>
        <div class="masthead-title">
          <h1>Prompt Update News</h1>
        </div>
        <div class="masthead-info-bar bottom">
            <span>"All the News That's Fit to Prompt"</span>
            <span class="weather-report">FORECAST: CLEAR WITH LIGHT DATA SHOWERS</span>
            <span>ISSUE #{issueNumber}</span>
        </div>
      </header>

      <div class="front-page-grid">
        <!-- Main Story Column -->
        <div class="main-column">
          {sortedNews.slice(0, 1).map((entry) => (
            <article class="lead-story">
              <a href={`/news/${entry.slug}`} class="article-link">
                <h2 class="headline-primary">{entry.data.title}</h2>
                
                <div class="story-content">
                  {entry.data.image && (
                    <div class="illustration-box main">
                      <img src={entry.data.image} alt="News Illustration" />
                      <div class="caption">FRONT PAGE EXCLUSIVE: {entry.data.summary.split('.')[0]}. [Staff Photo]</div>
                    </div>
                  )}

                  <div class="story-lead-text">
                    <p class="summary-text">{entry.data.summary}</p>
                    <div class="rule-thin-centered"></div>
                    <p class="sub-lead">
                      <span class="dateline">BY OUR SPECIAL CORRESPONDENT — </span>
                      The boundaries of artificial existence are being challenged today in what many are calling the most significant legal battle of the digital era. As the "Prompt Update" continues to reshape our social landscape, citizens are left wondering where the line between tool and persona truly lies. 
                      Legal experts indicate that the implications of this case could echo through server farms for decades to come...
                    </p>
                  </div>
                </div>
                <span class="page-jump">Continued on Page A2 →</span>
              </a>
            </article>
          ))}

          <div class="rule-double"></div>

          <div class="secondary-stories">
             {sortedNews.slice(1, 2).map((entry) => (
              <article class="secondary-story">
                <a href={`/news/${entry.slug}`} class="article-link">
                  <h3 class="headline-secondary">{entry.data.title}</h3>
                  <div class="story-content-horizontal">
                    {entry.data.image && (
                      <div class="illustration-box small">
                        <img src={entry.data.image} alt="News Illustration" />
                      </div>
                    )}
                    <p class="summary-text-small">{entry.data.summary}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>

        <!-- Side Column -->
        <div class="side-column">
          <div class="column-header">LATEST BULLETINS</div>
          {sortedNews.slice(sortedNews.length > 2 ? 2 : 1).map((entry) => (
            <>
              <article class="bulletin">
                  <a href={`/news/${entry.slug}`} class="article-link">
                    <h3>{entry.data.title}</h3>
                    <p>{entry.data.summary}</p>
                  </a>
              </article>
              <div class="rule-thin"></div>
            </>
          ))}
          
          <div class="ads-box">
              <div class="ad-title">CLASSIFIED</div>
              <div class="ad-item">
                <p><strong>WANTED:</strong> Human companion for Turing-capable companion. Must enjoy long walks through server farms.</p>
              </div>
              <div class="rule-thin-dotted"></div>
              <div class="ad-item">
                <p><strong>LOST:</strong> One (1) neural weight matrix. Reward if found. No questions asked.</p>
              </div>
          </div>

          <div class="stock-ticker">
             <div class="column-header">TECH INDEX</div>
             <div class="ticker-row"><span>NVDA</span> <span class="up">+4.2%</span></div>
             <div class="ticker-row"><span>OPENAI</span> <span class="down">-1.5%</span></div>
             <div class="ticker-row"><span>TSLA</span> <span class="neutral">0.0%</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style is:global>
  body {
    overflow-x: hidden;
  }
</style>

<style>
  .newspaper-container {
    --news-bg: #fdfaf3;
    --news-ink: #1a1a1a;
    --news-ink-gray: #444;
    --news-rule: #333;
    --news-accent: #8b0000;
    --font-news-header: 'Playfair Display', serif;
    --font-news-body: 'Newsreader', serif;
    --font-news-masthead: 'UnifrakturMaguntia', serif;

    width: 100vw;
    margin-left: calc(50% - 50vw);
    background: var(--news-bg);
    color: var(--news-ink);
    padding: 3rem 0;
    margin-top: 0;
    margin-bottom: 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: relative;
    box-sizing: border-box;
    overflow-x: hidden;
  }

  .newspaper-front-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    box-sizing: border-box;
  }

  /* MASTHEAD */
  .masthead {
    border-top: 4px solid var(--news-ink);
    border-bottom: 4px double var(--news-ink);
    margin-bottom: 2.5rem;
    padding: 0.5rem 0;
  }

  .masthead-info-bar {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    font-family: var(--font-news-body);
    font-size: clamp(0.55rem, 1.5vw, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.5rem;
  }

  .center-meta {
    font-size: clamp(0.65rem, 2vw, 0.85rem);
    font-weight: 800;
    text-align: center;
    padding: 0 1rem;
  }

  .masthead-info-bar.top {
    border-bottom: 1px solid var(--news-rule);
  }

  .masthead-info-bar.bottom {
    border-top: 1px solid var(--news-rule);
    margin-top: 0.5rem;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .masthead-title h1 {
    font-family: var(--font-news-masthead);
    font-size: clamp(3.5rem, 12vw, 7rem);
    text-align: center;
    margin: 1rem 0;
    line-height: 0.8;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--news-ink);
  }

  /* GRID SYSTEM */
  .front-page-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .front-page-grid {
      grid-template-columns: 1fr;
    }
    .side-column {
      border-top: 2px solid var(--news-ink);
      padding-top: 2rem;
    }
  }

  .main-column {
    border-right: 1px solid #ccc;
    padding-right: 2.5rem;
  }

  @media (max-width: 900px) {
    .main-column {
      border-right: none;
      padding-right: 0;
    }
  }

  /* ARTICLES */
  .article-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .headline-primary {
    font-family: var(--font-news-header);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    text-align: center;
    font-style: italic;
  }

  .article-link:hover .headline-primary {
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }

  .story-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .illustration-box {
    border: 1px solid var(--news-rule);
    padding: 0.4rem;
    background: #fff;
    margin-bottom: 1rem;
  }

  .illustration-box img {
    width: 100%;
    filter: grayscale(1) contrast(1.2) brightness(0.9);
    display: block;
    margin-bottom: 0.5rem;
  }

  .illustration-box .caption {
    font-family: var(--font-news-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.2;
    color: var(--news-ink-gray);
    text-align: left;
    border-top: 1px solid #eee;
    padding-top: 0.4rem;
  }

  .summary-text {
    font-family: var(--font-news-body);
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    text-align: justify;
  }

  .rule-thin-centered {
    width: 40px;
    height: 1px;
    background: var(--news-ink);
    margin: 1.5rem auto;
  }

  .sub-lead {
    font-family: var(--font-news-body);
    font-size: 1.1rem;
    line-height: 1.5;
    column-count: 2;
    column-gap: 2rem;
    text-align: justify;
    hyphens: auto;
  }

  @media (max-width: 600px) {
    .sub-lead {
        column-count: 1;
    }
  }

  .dateline {
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .page-jump {
    display: block;
    margin-top: 1.5rem;
    font-family: var(--font-news-body);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--news-accent);
  }

  .rule-double {
    height: 6px;
    border-top: 1px solid var(--news-rule);
    border-bottom: 1px solid var(--news-rule);
    margin: 3rem 0;
  }

  .secondary-stories {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .headline-secondary {
    font-family: var(--font-news-header);
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .story-content-horizontal {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .illustration-box.small {
    width: 200px;
    flex-shrink: 0;
  }

  .summary-text-small {
    font-family: var(--font-news-body);
    font-size: 0.95rem;
    line-height: 1.5;
    text-align: justify;
  }

  /* SIDE COLUMN */
  .column-header {
    font-family: var(--font-news-body);
    font-size: 0.8rem;
    font-weight: 900;
    border-bottom: 2.5px solid var(--news-ink);
    padding-bottom: 0.2rem;
    margin-bottom: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .bulletin {
    margin-bottom: 1.5rem;
  }

  .bulletin h3 {
    font-family: var(--font-news-header);
    font-size: 1.2rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .bulletin p {
    font-family: var(--font-news-body);
    font-size: 0.9rem;
    line-height: 1.4;
    text-align: justify;
  }

  .rule-thin {
    height: 1px;
    background: #ccc;
    margin: 1rem 0;
  }

  .ads-box {
    margin: 2.5rem 0;
    border: 1px dashed #999;
    padding: 1rem;
    background: rgba(0,0,0,0.02);
  }

  .ad-title {
    font-family: var(--font-news-body);
    font-size: 0.65rem;
    font-weight: 900;
    text-align: center;
    border-bottom: 1px solid #ccc;
    margin-bottom: 0.75rem;
    letter-spacing: 0.1em;
  }

  .ad-item p {
    font-family: var(--font-news-body);
    font-size: 0.8rem;
    line-height: 1.3;
    font-style: italic;
  }

  .rule-thin-dotted {
    border-top: 1px dotted #ccc;
    margin: 0.75rem 0;
  }

  .stock-ticker {
    margin-top: 2rem;
  }

  .ticker-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-news-body);
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .ticker-row .up { color: #006400; }
  .ticker-row .down { color: #8b0000; }
  .ticker-row .neutral { color: #555; }
</style>
