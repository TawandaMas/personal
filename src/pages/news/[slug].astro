---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allNews = await getCollection('news');
const otherNews = allNews
  .filter(n => n.slug !== entry.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Base title={entry.data.title}>
  <div class="article-inner-page">
    <header class="masthead-mini">
      <div class="masthead-title-mini">
        <a href="/news">Prompt Update News</a>
      </div>

    </header>



    <header class="article-header">
      <h1 class="headline-large">{entry.data.title}</h1>
    </header>

    <div class="article-body-layout">
      <div class="main-body-column">

        
        <div class="article-content-prose prose">
          <Content />
        </div>

        <div class="article-footer-mark">
          <span>(Continued from Page A1)</span>
          <span class="end-slug">■</span>
        </div>

        <!-- Mobile More News -->
        <div class="mobile-more-news">
          <h3>RECENT HEADLINES</h3>
          <div class="more-news-grid">
            {otherNews.map((news) => (
              <a href={`/news/${news.slug}`} class="more-news-card">
                <h4>{news.data.title}</h4>
                <p>{news.data.summary}</p>
              </a>
            ))}
          </div>
          <a href="/news" class="view-all-headlines">VIEW ALL HEADLINES →</a>
        </div>
      </div>

      <aside class="sidebar-column">


        <div class="sidebar-widget">
          <h4>SYNDICATED</h4>
          <ul class="syndicated-links">
            {otherNews.map((news) => (
              <li><a href={`/news/${news.slug}`}>{news.data.title}</a></li>
            ))}
          </ul>
        </div>
        
        <div class="vertical-promo">
            <p>SUBSCRIBE TO PROMPT UPDATE NEWS</p>
            <div class="qr-placeholder">GET THE LATEST</div>
        </div>
      </aside>
    </div>
  </div>
</Base>

<style>
  .article-inner-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 0;
    color: #1a1a1a;
  }

  :root.dark .article-inner-page {
    color: #e0e0e0;
  }

  .masthead-mini {
    border-bottom: 4px double #1a1a1a;
    margin-bottom: 3rem;
    padding-bottom: 0.5rem;
    text-align: center;
  }

  :root.dark .masthead-mini {
    border-color: #e0e0e0;
  }

  .masthead-title-mini {
    padding: 0.5rem 0;
  }

  .masthead-title-mini a {
    font-family: 'UnifrakturMaguntia', serif;
    font-size: 2.5rem;
    color: inherit;
    text-decoration: none;
    font-weight: 400;
  }



  .article-header {
    margin-bottom: 3rem;
  }

  .header-pre {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.1rem 0.6rem;
  }

  .headline-large {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 7vw, 4.5rem);
    line-height: 0.95;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
    margin: 1rem 0 2rem;
    letter-spacing: -0.02em;
  }

  .byline-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 0.6rem 0;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .author-name {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .dateline {
    font-style: italic;
    color: var(--ink-mid);
  }

  /* LAYOUT */
  .article-body-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 3.5rem;
  }

  @media (max-width: 850px) {
    .article-body-layout {
      grid-template-columns: 1fr;
    }
    .sidebar-column {
      display: none;
    }
  }

  /* MOBILE MORE NEWS */
  .mobile-more-news {
    display: none;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 3px solid #1a1a1a;
  }

  :root.dark .mobile-more-news {
    border-color: #e0e0e0;
  }

  @media (max-width: 850px) {
    .mobile-more-news {
      display: block;
    }
  }

  .mobile-more-news h3 {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 900;
    margin-bottom: 1.5rem;
    text-align: center;
    letter-spacing: 0.1em;
  }

  .more-news-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .more-news-card {
    text-decoration: none;
    color: inherit;
    border-bottom: 1px dashed var(--rule);
    padding-bottom: 1rem;
  }

  .more-news-card h4 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .more-news-card p {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--ink-mid);
  }

  .view-all-headlines {
    display: block;
    margin-top: 2rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 850px) {
    .main-body-column {
      border-right: none;
      padding-right: 0;
    }
  }

  /* CONTENT STYLE */
  .body-illustration {
    margin-bottom: 2.5rem;
    border: 1px solid var(--rule);
    padding: 4px;
    background: #fff;
  }

  :root.dark .body-illustration {
     background: #1a1a1a;
  }

  .body-illustration img {
    width: 100%;
    filter: grayscale(1) contrast(1.1);
    display: block;
  }

  .body-illustration caption {
    display: block;
    margin-top: 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.3;
    color: var(--ink-mid);
    text-align: left;
  }

  .article-content-prose {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.7;
    text-align: justify;
  }

  /* Drop Cap */
  .article-content-prose :global(p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-serif);
    font-size: 4.5rem;
    line-height: 1;
    font-weight: 900;
    padding-right: 0.75rem;
    padding-top: 0.25rem;
    color: #1a1a1a;
  }

  :root.dark .article-content-prose :global(p:first-of-type::first-letter) {
    color: #e0e0e0;
  }

  .article-content-prose :global(p) {
    margin-bottom: 1.5rem;
    text-indent: 1.5rem;
  }

  .article-content-prose :global(p:first-of-type) {
    text-indent: 0;
  }

  .article-content-prose :global(blockquote) {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-style: italic;
    font-weight: 500;
    line-height: 1.3;
    border-top: 2.5px solid #1a1a1a;
    border-bottom: 2.5px solid #1a1a1a;
    padding: 1.75rem 0;
    margin: 2.5rem 0;
    text-align: center;
    text-indent: 0;
  }

  :root.dark .article-content-prose :global(blockquote) {
    border-color: #e0e0e0;
  }

  .article-content-prose :global(.ad-viewport) {
    margin: 3rem 0;
    padding: 2rem;
    border: 2px solid #1a1a1a;
    background: rgba(0,0,0,0.03);
    text-align: center;
    position: relative;
    text-indent: 0;
  }

  :root.dark .article-content-prose :global(.ad-viewport) {
    border-color: #e0e0e0;
    background: rgba(255,255,255,0.03);
  }

  .article-content-prose :global(.ad-viewport::before) {
    content: "ADVERTISEMENT";
    position: absolute;
    top: -0.6rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    color: var(--ink-mid);
    background: #fdfbf7; /* Matching paper background if possible */
  }

  :root.dark .article-content-prose :global(.ad-viewport::before) {
    background: #0a0a0a;
  }

  .article-content-prose :global(.ad-viewport p) {
    margin: 0;
    text-indent: 0;
    font-style: italic;
    font-weight: 700;
    font-size: 1.2rem;
    line-height: 1.4;
  }

  .article-footer-mark {
    margin-top: 3rem;
    border-top: 1px solid var(--rule);
    padding-top: 1rem;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--ink-light);
  }

  .end-slug {
    color: var(--accent);
    font-size: 1rem;
  }

  /* SIDEBAR */
  .sidebar-widget {
    border-top: 4px solid #1a1a1a;
    padding-top: 0.75rem;
    margin-bottom: 3rem;
  }

  :root.dark .sidebar-widget {
    border-color: #e0e0e0;
  }

  .sidebar-widget h4 {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .sidebar-widget p {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    line-height: 1.5;
    text-align: justify;
  }

  .syndicated-links {
    list-style: none;
  }

  .syndicated-links li {
    padding: 0.6rem 0;
    border-bottom: 1px dashed var(--rule);
  }

  .syndicated-links a {
    text-decoration: none;
    color: inherit;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
    display: block;
  }

  .syndicated-links a:hover {
    color: var(--accent);
  }

  .vertical-promo {
    background: var(--paper-dark);
    padding: 1.5rem;
    text-align: center;
    border: 1px solid var(--rule);
  }

  .vertical-promo p {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .qr-placeholder {
    height: 100px;
    background: var(--paper);
    border: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 900;
    color: var(--rule);
  }
</style>
