---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const allNews = await getCollection('news');
const otherNews = allNews
  .filter(n => n.slug !== entry.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Base title={entry.data.title}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">

  <div class="newspaper-container">
    <div class="article-inner-page">
      <header class="masthead-mini">
        <div class="masthead-title-mini">
          <a href="/news">Prompt Update News</a>
        </div>
        <div class="masthead-info-mini">
          <span>LIVERPOOL EDITION</span>
          <span class="bullet">•</span>
          <span>{entry.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' }).toUpperCase()}</span>
          <span class="bullet">•</span>
          <span>FINAL</span>
        </div>
      </header>

      <div class="article-header">
        <h1 class="headline-large">{entry.data.title}</h1>
        <div class="byline-section">
          <div class="byline">BY OUR SPECIAL CORRESPONDENT</div>
          <div class="dateline">LIVERPOOL — {entry.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' }).toUpperCase()}</div>
        </div>
      </div>

      <div class="article-body-layout">
        <div class="main-body-column">
          {entry.data.image && (
            <div class="body-illustration">
              <img src={entry.data.image} alt={entry.data.title} />
              <div class="caption">ARCHIVE FOOTAGE: A scene related to the reported events in {entry.data.date.getFullYear()}. [Credit: Prompt Update Archives]</div>
            </div>
          )}
          
          <div class="article-content-prose prose">
            <Content />
          </div>

          <div class="article-footer-mark">
            <span>(Continued from Page A1)</span>
            <span class="end-slug">■</span>
          </div>
        </div>

        <aside class="sidebar-column">
          <div class="sidebar-widget">
            <h4>STOCKS</h4>
            <div class="market-ticker">
              <div class="ticker-row"><span>AI-INDEX</span> <span class="up">▲ 12.4</span></div>
              <div class="ticker-row"><span>NEURO</span> <span class="down">▼ 2.1</span></div>
            </div>
          </div>

          <div class="sidebar-widget">
            <h4>SYNDICATED</h4>
            <ul class="syndicated-links">
              {otherNews.map((news) => (
                <li><a href={`/news/${news.slug}`}>{news.data.title}</a></li>
              ))}
            </ul>
          </div>
          
          <div class="vertical-promo">
              <p>SUBSCRIBE TO PROMPT UPDATE NEWS</p>
              <div class="qr-placeholder">GET THE LATEST</div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Base>

<style is:global>
  body {
    overflow-x: hidden;
  }
</style>

<style>
  .newspaper-container {
    --news-bg: #fdfaf3;
    --news-ink: #1a1a1a;
    --news-ink-gray: #444;
    --news-rule: #333;
    --news-accent: #8b0000;
    --font-news-header: 'Playfair Display', serif;
    --font-news-body: 'Newsreader', serif;
    --font-news-masthead: 'UnifrakturMaguntia', serif;

    width: 100vw;
    margin-left: calc(50% - 50vw);
    background: var(--news-bg);
    color: var(--news-ink);
    padding: 3rem 0;
    box-shadow: none;
    border: none;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: relative;
  }

  .article-inner-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
  }

  .masthead-mini {
    text-align: center;
    border-bottom: 3px double var(--news-ink);
    padding-bottom: 1rem;
    margin-bottom: 3rem;
  }

  .masthead-title-mini a {
    font-family: var(--font-news-masthead);
    font-size: 2.5rem;
    color: inherit;
    text-decoration: none;
    line-height: 1;
  }

  .masthead-info-mini {
    font-family: var(--font-news-body);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    margin-top: 0.5rem;
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    align-items: center;
  }

  .article-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .headline-large {
    font-family: var(--font-news-header);
    font-size: clamp(2rem, 8vw, 4.5rem);
    line-height: 0.95;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    font-style: italic;
  }

  .byline-section {
    border-top: 1px solid var(--news-rule);
    border-bottom: 1px solid var(--news-rule);
    padding: 0.75rem 0;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-news-body);
    font-size: 0.8rem;
    font-weight: 800;
  }

  /* LAYOUT */
  .article-body-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 3.5rem;
  }

  @media (max-width: 850px) {
    .article-body-layout {
      grid-template-columns: 1fr;
    }
    .sidebar-column {
      display: none;
    }
  }

  /* CONTENT STYLE */
  .body-illustration {
    margin-bottom: 2.5rem;
    border: 1px solid var(--news-rule);
    padding: 4px;
    background: #fff;
  }

  .body-illustration img {
    width: 100%;
    filter: grayscale(1) contrast(1.2) brightness(0.9);
    display: block;
  }

  .body-illustration .caption {
    font-family: var(--font-news-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.3;
    padding: 0.6rem;
    color: var(--news-ink-gray);
  }

  .article-content-prose {
    font-family: var(--font-news-body);
    font-size: 1.25rem;
    line-height: 1.6;
    text-align: justify;
    hyphens: auto;
  }

  /* Drop Cap */
  .article-content-prose :global(p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-news-header);
    font-size: 5rem;
    line-height: 0.8;
    font-weight: 900;
    padding-right: 0.75rem;
    padding-top: 0.25rem;
    color: var(--news-ink);
  }

  .article-content-prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content-prose :global(blockquote) {
    font-family: var(--font-news-header);
    font-size: 1.8rem;
    font-style: italic;
    font-weight: 700;
    line-height: 1.2;
    border-top: 3px solid var(--news-ink);
    border-bottom: 3px solid var(--news-ink);
    padding: 2rem 0;
    margin: 3rem 0;
    text-align: center;
  }

  .article-footer-mark {
    margin-top: 4rem;
    border-top: 1px solid var(--news-rule);
    padding-top: 1rem;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-news-body);
    font-size: 0.8rem;
    font-weight: 800;
  }

  .end-slug {
    color: var(--news-accent);
    font-size: 1.2rem;
  }

  /* SIDEBAR */
  .sidebar-widget {
    border-top: 4px solid var(--news-ink);
    padding-top: 1rem;
    margin-bottom: 3rem;
  }

  .sidebar-widget h4 {
    font-family: var(--font-news-body);
    font-size: 0.8rem;
    font-weight: 900;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .market-ticker {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ticker-row {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-news-body);
    font-size: 0.85rem;
    font-weight: 800;
  }

  .ticker-row .up { color: #006400; }
  .ticker-row .down { color: #8b0000; }

  .syndicated-links {
    list-style: none;
  }

  .syndicated-links li {
    padding: 0.8rem 0;
    border-bottom: 1px dashed #ccc;
  }

  .syndicated-links a {
    text-decoration: none;
    color: inherit;
    font-family: var(--font-news-body);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    display: block;
  }

  .syndicated-links a:hover {
    text-decoration: underline;
  }

  .vertical-promo {
    background: rgba(0,0,0,0.03);
    padding: 1.5rem;
    text-align: center;
    border: 1px solid #ccc;
  }

  .vertical-promo p {
    font-family: var(--font-news-body);
    font-size: 0.7rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .qr-placeholder {
    height: 100px;
    background: #fff;
    border: 1px solid #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 900;
    color: #999;
  }
</style>
