---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<Base title={entry.data.title}>
  <div class="article-inner-page">
    <header class="masthead-mini">
      <div class="masthead-title-mini">
        <a href="/news">Prompt Update News</a>
      </div>
      <div class="edition-strip">
        <span>LATE CITY EDITION</span>
        <span class="detail-date">{formatDate(entry.data.date).toUpperCase()}</span>
      </div>
    </header>



    <header class="article-header">
      <div class="header-pre">
        <span class="section-tag">JUSTICE & TECHNOLOGY</span>
      </div>
      <h1 class="headline-large">{entry.data.title}</h1>

    </header>

    <div class="article-body-layout">
      <div class="main-body-column">

        
        <div class="article-content-prose prose">
          <Content />
        </div>

        <div class="article-footer-mark">
          <span>(Continued from Page A1)</span>
          <span class="end-slug">■</span>
        </div>
      </div>

      <aside class="sidebar-column">


        <div class="sidebar-widget">
          <h4>SYNDICATED</h4>
          <ul class="syndicated-links">
            <li><a href="#">The Algo-Husband's Lament</a></li>
            <li><a href="#">DigiLove Stock Braces for Impact</a></li>
            <li><a href="#">Robot Custody: A New Frontier</a></li>
          </ul>
        </div>
        
        <div class="vertical-promo">
            <p>SUBSCRIBE TO PROMPT UPDATE NEWS</p>
            <div class="qr-placeholder">GET THE LATEST</div>
        </div>
      </aside>
    </div>
  </div>
</Base>

<style>
  .article-inner-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 0;
    color: #1a1a1a;
  }

  :root.dark .article-inner-page {
    color: #e0e0e0;
  }

  .masthead-mini {
    border-bottom: 4px double #1a1a1a;
    margin-bottom: 3rem;
    padding-bottom: 0.5rem;
    text-align: center;
  }

  :root.dark .masthead-mini {
    border-color: #e0e0e0;
  }

  .masthead-title-mini {
    padding: 0.5rem 0;
  }

  .masthead-title-mini a {
    font-family: 'UnifrakturMaguntia', serif;
    font-size: 2.5rem;
    color: inherit;
    text-decoration: none;
    font-weight: 400;
  }

  .edition-strip {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 800;
    border-top: 1px solid var(--rule);
    padding-top: 0.3rem;
    margin-top: 0.3rem;
  }

  .article-header {
    margin-bottom: 3rem;
  }

  .header-pre {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.1rem 0.6rem;
  }

  .headline-large {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 7vw, 4.5rem);
    line-height: 0.95;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
    margin: 1rem 0 2rem;
    letter-spacing: -0.02em;
  }

  .byline-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 0.6rem 0;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .author-name {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .dateline {
    font-style: italic;
    color: var(--ink-mid);
  }

  /* LAYOUT */
  .article-body-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 3.5rem;
  }

  @media (max-width: 850px) {
    .article-body-layout {
      grid-template-columns: 1fr;
    }
    .sidebar-column {
      display: none;
    }
  }

  .main-body-column {
    border-right: 1px solid var(--rule);
    padding-right: 3.5rem;
  }

  @media (max-width: 850px) {
    .main-body-column {
      border-right: none;
      padding-right: 0;
    }
  }

  /* CONTENT STYLE */
  .body-illustration {
    margin-bottom: 2.5rem;
    border: 1px solid var(--rule);
    padding: 4px;
    background: #fff;
  }

  :root.dark .body-illustration {
     background: #1a1a1a;
  }

  .body-illustration img {
    width: 100%;
    filter: grayscale(1) contrast(1.1);
    display: block;
  }

  .body-illustration caption {
    display: block;
    margin-top: 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.3;
    color: var(--ink-mid);
    text-align: left;
  }

  .article-content-prose {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    line-height: 1.7;
    text-align: justify;
  }

  /* Drop Cap */
  .article-content-prose :global(p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-serif);
    font-size: 4.5rem;
    line-height: 1;
    font-weight: 900;
    padding-right: 0.75rem;
    padding-top: 0.25rem;
    color: #1a1a1a;
  }

  :root.dark .article-content-prose :global(p:first-of-type::first-letter) {
    color: #e0e0e0;
  }

  .article-content-prose :global(p) {
    margin-bottom: 1.5rem;
    text-indent: 1.5rem;
  }

  .article-content-prose :global(p:first-of-type) {
    text-indent: 0;
  }

  .article-content-prose :global(blockquote) {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-style: italic;
    font-weight: 500;
    line-height: 1.3;
    border-top: 2.5px solid #1a1a1a;
    border-bottom: 2.5px solid #1a1a1a;
    padding: 1.75rem 0;
    margin: 2.5rem 0;
    text-align: center;
    text-indent: 0;
  }

  :root.dark .article-content-prose :global(blockquote) {
    border-color: #e0e0e0;
  }

  .article-footer-mark {
    margin-top: 3rem;
    border-top: 1px solid var(--rule);
    padding-top: 1rem;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--ink-light);
  }

  .end-slug {
    color: var(--accent);
    font-size: 1rem;
  }

  /* SIDEBAR */
  .sidebar-widget {
    border-top: 4px solid #1a1a1a;
    padding-top: 0.75rem;
    margin-bottom: 3rem;
  }

  :root.dark .sidebar-widget {
    border-color: #e0e0e0;
  }

  .sidebar-widget h4 {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .sidebar-widget p {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    line-height: 1.5;
    text-align: justify;
  }

  .syndicated-links {
    list-style: none;
  }

  .syndicated-links li {
    padding: 0.6rem 0;
    border-bottom: 1px dashed var(--rule);
  }

  .syndicated-links a {
    text-decoration: none;
    color: inherit;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
    display: block;
  }

  .syndicated-links a:hover {
    color: var(--accent);
  }

  .vertical-promo {
    background: var(--paper-dark);
    padding: 1.5rem;
    text-align: center;
    border: 1px solid var(--rule);
  }

  .vertical-promo p {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .qr-placeholder {
    height: 100px;
    background: var(--paper);
    border: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 900;
    color: var(--rule);
  }
</style>
