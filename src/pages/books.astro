---
import Base from '../layouts/Base.astro';

const bookFiles = await Astro.glob('../content/books/*.md');
const books = bookFiles
  .map(b => ({ ...b.frontmatter }))
  .sort((a, b) => (a.order || 99) - (b.order || 99));

const reading = books.filter(b => b.status === 'reading');
const read = books.filter(b => b.status === 'read');
const queue = books.filter(b => b.status === 'queue');
---

<Base title="Books">
  <div class="page-header">
    <h1>Books</h1>
    <p>What I'm reading, what I've read, what's next.</p>
  </div>

  {reading.length > 0 && (
    <section class="book-section">
      <div class="section-label">Currently reading</div>
      {reading.map(book => (
        <div class="book-row">
          <div class="book-info">
            <div class="book-title">{book.title}</div>
            <div class="book-author">{book.author} · {book.year}</div>
            {book.note && <div class="book-note">{book.note}</div>}
          </div>
          <div class="book-genre">{book.genre}</div>
        </div>
      ))}
    </section>
  )}

  {read.length > 0 && (
    <section class="book-section">
      <div class="section-label">Read</div>
      {read.map(book => (
        <div class="book-row">
          <div class="book-info">
            <div class="book-title">{book.title}</div>
            <div class="book-author">{book.author} · {book.year}</div>
            {book.note && <div class="book-note">{book.note}</div>}
          </div>
          <div class="book-genre">{book.genre}</div>
        </div>
      ))}
    </section>
  )}

  {queue.length > 0 && (
    <section class="book-section">
      <div class="section-label">Queue</div>
      {queue.map(book => (
        <div class="book-row">
          <div class="book-info">
            <div class="book-title">{book.title}</div>
            <div class="book-author">{book.author} · {book.year}</div>
            {book.note && <div class="book-note">{book.note}</div>}
          </div>
          <div class="book-genre">{book.genre}</div>
        </div>
      ))}
    </section>
  )}
</Base>

<style>
  .book-section { margin-bottom: 2.5rem; }

  .section-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 0;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rule);
  }

  .book-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: start;
    padding: 1.1rem 0;
    border-bottom: 1px dashed var(--paper-crease);
  }

  .book-row:last-child { border-bottom: none; }

  .book-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 0.15rem;
    line-height: 1.3;
  }

  .book-author {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--ink-light);
  }

  .book-note {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--ink-mid);
    font-style: italic;
    margin-top: 0.35rem;
    opacity: 0.8;
  }

  .book-genre {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent);
    text-align: right;
    padding-top: 0.25rem;
    white-space: nowrap;
    opacity: 0.7;
  }
</style>
