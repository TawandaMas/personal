---
import Base from '../layouts/Base.astro';

const bookFiles = await Astro.glob('../content/books/*.md');
const books = bookFiles
  .map(b => ({ ...b.frontmatter }))
  .sort((a, b) => (a.order || 99) - (b.order || 99));

const reading = books.filter(b => b.status === 'reading');
const read = books.filter(b => b.status === 'read');
const queue = books.filter(b => b.status === 'queue');
---

<Base title="Books">
  <div class="page-header">
    <h1>The Library</h1>
    <p>A digital card catalog of things I've consumed and contemplated.</p>
  </div>

  <div class="catalog-drawer">
    {reading.length > 0 && (
      <div class="drawer-section">
        <h2 class="drawer-label">In Progress</h2>
        <div class="card-grid">
          {reading.map((book, i) => (
            <div class="book-card card-active" style={`--rotation: ${(i % 2 === 0 ? 1 : -1) * (1 + (i % 3) * 0.5)}deg`}>
              <div class="card-status status-reading">Reading</div>
              <div class="card-content">
                <h3 class="book-title">{book.title}</h3>
                <p class="book-author">{book.author} — {book.year}</p>
                <div class="card-rule"></div>
                {book.note && <p class="book-note">{book.note}</p>}
              </div>
              <div class="card-footer">
                <span class="genre-tag">{book.genre}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {read.length > 0 && (
      <div class="drawer-section">
        <h2 class="drawer-label">Archive</h2>
        <div class="card-grid">
          {read.map((book, i) => (
            <div class="book-card card-read" style={`--rotation: ${(i % 2 === 0 ? -1 : 1) * (1 + (i % 2) * 0.4)}deg`}>
              <div class="card-status status-read">Finished</div>
              <div class="card-content">
                <h3 class="book-title">{book.title}</h3>
                <p class="book-author">{book.author} — {book.year}</p>
                <div class="card-rule"></div>
                {book.note && <p class="book-note">{book.note}</p>}
              </div>
              <div class="card-footer">
                <span class="genre-tag">{book.genre}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {queue.length > 0 && (
      <div class="drawer-section">
        <h2 class="drawer-label">Wishlist</h2>
        <div class="card-grid">
          {queue.map((book, i) => (
            <div class="book-card card-queue" style={`--rotation: ${(i % 2 === 0 ? 0.8 : -0.8)}deg`}>
              <div class="card-status status-queue">Queue</div>
              <div class="card-content">
                <h3 class="book-title">{book.title}</h3>
                <p class="book-author">{book.author} — {book.year}</p>
                <div class="card-rule"></div>
                {book.note && <p class="book-note">{book.note}</p>}
              </div>
              <div class="card-footer">
                <span class="genre-tag">{book.genre}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</Base>

<style>
  .catalog-drawer {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .drawer-section {
    position: relative;
  }

  .drawer-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 2rem;
    padding-left: 0.5rem;
    border-left: 3px solid var(--accent);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
  }

  /* PHYSICAL CARD STYLING */
  .book-card {
    background: #fffcf8;
    background-image: 
      linear-gradient(90deg, transparent 79px, #abced4 79px, #abced4 81px, transparent 81px),
      linear-gradient(#eee 0.1em, transparent 0.1em);
    background-size: 100% 1.4rem;
    border: 1px solid var(--rule);
    border-bottom: 2px solid var(--paper-crease);
    padding: 1.5rem;
    min-height: 220px;
    position: relative;
    display: flex;
    flex-direction: column;
    transform: rotate(var(--rotation, 0deg));
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 2px 4px 12px rgba(0,0,0,0.03);
  }

  .book-card::before {
    content: '';
    position: absolute;
    top: 50%;
    left: -5px;
    width: 10px;
    height: 10px;
    background: var(--paper-crease);
    border-radius: 50%;
    transform: translateY(-50%);
    box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);
    opacity: 0.5;
  }

  .book-card:hover {
    transform: rotate(0deg) translateY(-8px) scale(1.02);
    box-shadow: 4px 8px 20px rgba(0,0,0,0.06);
    z-index: 10;
  }

  .card-content {
    flex: 1;
    z-index: 2;
  }

  .book-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.25rem;
    line-height: 1.2;
  }

  .book-author {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--ink-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .card-rule {
    height: 1px;
    background: var(--rule);
    margin: 0.75rem 0;
    opacity: 0.6;
  }

  .book-note {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--ink-mid);
    line-height: 1.6;
    font-style: italic;
    padding-top: 0.5rem;
  }

  /* STATUS STAMPS */
  .card-status {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border: 1.5px solid currentColor;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transform: rotate(15deg);
    opacity: 0.75;
    mix-blend-mode: multiply;
  }

  .status-reading { color: #b34a3b; border-color: #b34a3b; }
  .status-read { color: #4a6b4a; border-color: #4a6b4a; opacity: 0.5; transform: rotate(-8deg); }
  .status-queue { color: var(--ink-light); border-color: var(--ink-light); transform: rotate(5deg); }

  .card-footer {
    padding-top: 1.5rem;
    display: flex;
    justify-content: flex-end;
  }

  .genre-tag {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    color: var(--ink-light);
    background: var(--paper);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    letter-spacing: 0.05em;
  }

  @media (max-width: 600px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

