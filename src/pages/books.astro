---
import Base from '../layouts/Base.astro';

import { getCollection } from 'astro:content';

const bookEntries = await getCollection('books');
const books = bookEntries
  .map(b => ({ ...b.data }))
  .sort((a, b) => (a.order || 99) - (b.order || 99));

const reading = books.filter(b => b.status === 'reading');
const read = books.filter(b => b.status === 'read');
const queue = books.filter(b => b.status === 'queue');
---

<Base title="Books">
  <div class="page-header">
    <h1>The Library</h1>
    <p>A digital card catalog of things I've consumed and contemplated.</p>
  </div>

  <div class="catalog-drawer">
    {reading.length > 0 && (
      <div class="drawer-section">
        <h2 class="drawer-label">In Progress</h2>
        <div class="card-grid">
          {reading.map((book, i) => (
            <div class="book-card card-active">
              <div class="card-status status-reading">Reading</div>
              <div class="card-content">
                <h3 class="book-title">{book.title}</h3>
                <p class="book-author">{book.author} — {book.year}</p>
                {book.rating > 0 && (
                  <div class="book-rating" aria-label={`Rating: ${book.rating} out of 5 stars`}>
                    {[...Array(5)].map((_, i) => {
                      const full = i < Math.floor(book.rating);
                      const half = !full && i < book.rating;
                      return (
                        <span class:list={['star', { filled: full, half: half }]}>★</span>
                      );
                    })}
                  </div>
                )}
                <div class="card-rule"></div>
                {book.note && <p class="book-note">{book.note}</p>}
              </div>
              <div class="card-footer">
                <span class="genre-tag">{book.genre}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {read.length > 0 && (
      <div class="drawer-section">
        <h2 class="drawer-label">Archive</h2>
        <div class="card-grid">
          {read.map((book, i) => (
            <div class="book-card card-read">
              <div class="card-status status-read">Finished</div>
              <div class="card-content">
                <h3 class="book-title">{book.title}</h3>
                <p class="book-author">{book.author} — {book.year}</p>
                {book.rating > 0 && (
                  <div class="book-rating" aria-label={`Rating: ${book.rating} out of 5 stars`}>
                    {[...Array(5)].map((_, i) => {
                      const full = i < Math.floor(book.rating);
                      const half = !full && i < book.rating;
                      return (
                        <span class:list={['star', { filled: full, half: half }]}>★</span>
                      );
                    })}
                  </div>
                )}
                <div class="card-rule"></div>
                {book.note && <p class="book-note">{book.note}</p>}
              </div>
              <div class="card-footer">
                <span class="genre-tag">{book.genre}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {queue.length > 0 && (
      <div class="drawer-section">
        <h2 class="drawer-label">Wishlist</h2>
        <div class="card-grid">
          {queue.map((book, i) => (
            <div class="book-card card-queue">
              <div class="card-status status-queue">Queue</div>
              <div class="card-content">
                <h3 class="book-title">{book.title}</h3>
                <p class="book-author">{book.author} — {book.year}</p>
                {book.rating > 0 && (
                  <div class="book-rating" aria-label={`Rating: ${book.rating} out of 5 stars`}>
                    {[...Array(5)].map((_, i) => {
                      const full = i < Math.floor(book.rating);
                      const half = !full && i < book.rating;
                      return (
                        <span class:list={['star', { filled: full, half: half }]}>★</span>
                      );
                    })}
                  </div>
                )}
                <div class="card-rule"></div>
                {book.note && <p class="book-note">{book.note}</p>}
              </div>
              <div class="card-footer">
                <span class="genre-tag">{book.genre}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</Base>

<style>
  .catalog-drawer {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .drawer-section {
    position: relative;
  }

  .drawer-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 2rem;
    padding-left: 0.5rem;
    border-left: 3px solid var(--accent);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
  }

  /* NEO-BRUTALIST CARD STYLING */
  .book-card {
    background: var(--bg);
    border: var(--border-w) solid var(--rule);
    padding: 1.5rem;
    min-height: 220px;
    position: relative;
    display: flex;
    flex-direction: column;
    box-shadow: 6px 6px 0px var(--shadow-color);
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .book-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 10px 10px 0px var(--shadow-color);
    z-index: 10;
  }

  .card-content {
    flex: 1;
    z-index: 2;
  }

  .book-title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 0.25rem;
    line-height: 1.1;
  }

  .book-author {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-mid);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .book-rating {
    display: flex;
    gap: 2px;
    margin-bottom: 1rem;
    color: var(--rule);
    font-size: 0.85rem;
  }

  .star.filled {
    color: var(--accent);
  }

  .star.half {
    position: relative;
    color: var(--rule);
  }

  .star.half::after {
    content: '★';
    position: absolute;
    left: 0;
    top: 0;
    width: 50%;
    overflow: hidden;
    color: var(--accent);
  }

  :root.dark .star.filled,
  :root.dark .star.half::after {
    color: var(--accent);
  }

  .card-rule {
    height: 1px;
    background: var(--rule);
    margin: 0.75rem 0;
    opacity: 0.6;
  }

  .book-note {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--ink-mid);
    line-height: 1.6;
    font-style: italic;
    padding-top: 0.5rem;
  }

  /* STATUS STAMPS */
  .card-status {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 800;
    padding: 0.25rem 0.5rem;
    border: var(--border-w) solid var(--rule);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    align-self: flex-start;
    box-shadow: 2px 2px 0px var(--shadow-color);
  }

  .status-reading { background: var(--accent); color: var(--bg); border-color: var(--rule); }
  .status-read { background: var(--bg); color: var(--ink); }
  .status-queue { background: var(--paper-dark); color: var(--ink-mid); }

  .card-footer {
    padding-top: 1.5rem;
    display: flex;
    justify-content: flex-end;
  }

  .genre-tag {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 800;
    color: var(--ink);
    background: var(--bg);
    border: 1px solid var(--rule);
    padding: 0.25rem 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 600px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

