---
import Base from '../../layouts/Base.astro';
---

<Base title="Bubble Shooter">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Bubble Shooter</h1>
      <div class="score-wrap">Score: <span id="score">0</span></div>
    </div>
  </div>

  <div class="game-wrap" id="game-container">
    <canvas id="bubble-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Bubbles</div>
        <div id="overlay-sub" class="overlay-sub">Tap to aim and fire. Match 3+ bubbles to pop them!</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap to shoot · Match 3 colours to pop</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
    aspect-ratio: 0.75;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    overflow: hidden;
    touch-action: none;
  }

  #bubble-canvas { display: block; width: 100%; height: 100%; }

  .overlay {
    position: absolute; inset: 0; background: var(--paper); opacity: 0.98;
    display: flex; align-items: center; justify-content: center; z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn {
    margin-top: 1.5rem; padding: 0.75rem 2rem;
    background: var(--ink); color: var(--paper); border: none; border-radius: 2rem;
    font-family: var(--font-sans); font-weight: 600; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
  .hint { font-family: var(--font-sans); font-size: 0.65rem; color: var(--ink-light); text-align: center; margin-top: 1.5rem; text-transform: uppercase; }
</style>

  const COLORS = ['#8b3a2a', '#4a6b4a', '#4a6bb3', '#b3904a', '#7a4ab3'];
  const canvas = document.getElementById('bubble-canvas');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  const COLS = 9;
  const ROWS = 9;
  let R, grid, shooter, score, gameActive, animFrame;
  let nextColor;
  
  let bestScore = parseInt(localStorage.getItem('bubbles-best') || 0);
  
  // Aiming logic
  let pointerX = 0;
  let pointerY = 0;
  let isPointerDown = false;
  
  // Ceiling mechanics
  let ceilingOffset = 0;
  let shotsFired = 0;
  let dropThreshold = 5; // Drop ceiling every N shots

  function resize() {
    const wrap = canvas.parentElement;
    canvas.width = wrap.clientWidth;
    canvas.height = wrap.clientHeight;
    R = Math.floor(canvas.width / (COLS * 2 + 1));
    if (!gameActive) drawIdle();
  }

  function drawIdle() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  function hexX(col, row) {
    return (col + 0.5 + (row % 2) * 0.5) * R * 2;
  }
  function hexY(row) {
    return row * R * 1.7 + R + ceilingOffset;
  }

  function initGame() {
    grid = [];
    ceilingOffset = 0;
    shotsFired = 0;
    
    for (let row = 0; row < 6; row++) {
      const cols = COLS - (row % 2 === 1 ? 1 : 0);
      for (let col = 0; col < cols; col++) {
        grid.push({ row, col, x: hexX(col, row), y: hexY(row), color: COLORS[Math.floor(Math.random() * 4)] });
      }
    }
    score = 0;
    scoreEl.textContent = '0';
    nextColor = COLORS[Math.floor(Math.random() * COLORS.length)];
    shooter = null;
  }

  function drawBubble(x, y, color, r = R - 2) {
    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fill();
    ctx.strokeStyle = 'rgba(0,0,0,0.15)';
    ctx.lineWidth = 1;
    ctx.stroke();
    // Shine
    ctx.fillStyle = 'rgba(255,255,255,0.25)';
    ctx.beginPath();
    ctx.arc(x - r * 0.3, y - r * 0.3, r * 0.3, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawAimLine() {
      if (!isPointerDown || shooter || !gameActive) return;
      const bx = canvas.width / 2;
      const by = canvas.height - R;
      
      const angle = Math.atan2(pointerY - by, pointerX - bx);
      if (Math.sin(angle) > -0.1) return; // Don't aim downwards
      
      ctx.strokeStyle = nextColor;
      ctx.lineWidth = 2;
      ctx.setLineDash([8, 8]);
      
      ctx.beginPath();
      ctx.moveTo(bx, by);
      
      // Calculate basic bounce
      let endX = bx + Math.cos(angle) * 1000;
      let endY = by + Math.sin(angle) * 1000;
      
      // Simplistic wall bounce preview
      if (endX < 0) {
          const m = (endY - by) / (endX - bx);
          const bounceY = by + m * (0 - bx);
          ctx.lineTo(0, bounceY);
          ctx.moveTo(0, bounceY);
          endX = canvas.width;
          endY = bounceY + (-m) * canvas.width;
      } else if (endX > canvas.width) {
          const m = (endY - by) / (endX - bx);
          const bounceY = by + m * (canvas.width - bx);
          ctx.lineTo(canvas.width, bounceY);
          ctx.moveTo(canvas.width, bounceY);
          endX = 0;
          endY = bounceY + (-m) * (-canvas.width);
      }
      
      ctx.lineTo(endX, endY);
      ctx.stroke();
      ctx.setLineDash([]);
  }

  function draw() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    // Ceiling drop warning area
    ctx.fillStyle = 'rgba(139,58,42,0.1)';
    ctx.fillRect(0, 0, canvas.width, ceilingOffset);
    ctx.strokeStyle = 'rgba(139,58,42,0.5)';
    ctx.beginPath();
    ctx.moveTo(0, ceilingOffset);
    ctx.lineTo(canvas.width, ceilingOffset);
    ctx.stroke();

    drawAimLine();

    grid.forEach(b => drawBubble(b.x, b.y, b.color));

    if (shooter) drawBubble(shooter.x, shooter.y, shooter.color);

    // Shooter base
    drawBubble(canvas.width / 2, canvas.height - R, nextColor);
    ctx.fillStyle = 'rgba(0,0,0,0.3)';
    ctx.fillRect(canvas.width / 2 - R, canvas.height - 4, R * 2, 4);
  }

  function snapToGrid(x, y) {
    let bestRow = -1, bestCol = -1, bestDist = Infinity;
    // Search a bit deeper to accommodate dropped ceiling
    for (let row = 0; row < ROWS + Math.floor(ceilingOffset / R); row++) {
      const cols = COLS - (row % 2 === 1 ? 1 : 0);
      for (let col = 0; col < cols; col++) {
        // Skip if there's already a bubble here
        if (grid.some(b => b.row === row && b.col === col)) continue;
        
        const gx = hexX(col, row), gy = hexY(row);
        const d = Math.hypot(x - gx, y - gy);
        if (d < bestDist) { bestDist = d; bestRow = row; bestCol = col; }
      }
    }
    return { row: bestRow, col: bestCol };
  }

  function update() {
    if (!shooter) { draw(); return; }
    shooter.x += shooter.vx;
    shooter.y += shooter.vy;

    if (shooter.x - R < 0) { shooter.x = R; shooter.vx = Math.abs(shooter.vx); }
    if (shooter.x + R > canvas.width) { shooter.x = canvas.width - R; shooter.vx = -Math.abs(shooter.vx); }

    let hit = false;
    for (const b of grid) {
      if (Math.hypot(shooter.x - b.x, shooter.y - b.y) < R * 1.9) { hit = true; break; }
    }
    if (shooter.y < ceilingOffset + R) hit = true;

    if (hit) {
      const snap = snapToGrid(shooter.x, shooter.y);
      const newBubble = {
        row: snap.row, col: snap.col,
        x: hexX(snap.col, snap.row), y: hexY(snap.row),
        color: shooter.color
      };
      
      // Failsafe if grid is full
      if (snap.row !== -1) grid.push(newBubble);
      
      shooter = null;
      shotsFired++;
      
      const popped = popMatches(newBubble);
      
      if (!popped && shotsFired % dropThreshold === 0) {
          dropCeiling();
      }
      
      nextColor = COLORS[Math.floor(Math.random() * COLORS.length)];
      checkGameOver();
      
      if (!gameActive) return; // Prevent draw/update cycle if over
    }

    draw();
    if (gameActive && shooter) animFrame = requestAnimationFrame(update);
  }

  function getNeighbors(curr) {
      return grid.filter(b => {
          if (b === curr) return false;
          // Check physical distance because row/col logical adjacencies depend on odd/even row logic
          return Math.hypot(b.x - curr.x, b.y - curr.y) < R * 2.2;
      });
  }

  function popMatches(start) {
    if (!start || start.row === -1) return false;

    // 1. Find matching colors
    const visited = new Set();
    const matches = [];
    const stack = [start];
    
    while (stack.length) {
      const curr = stack.pop();
      const key = `${curr.row},${curr.col}`;
      if (visited.has(key)) continue;
      visited.add(key);
      
      if (curr.color === start.color) {
          matches.push(curr);
          const neighbors = getNeighbors(curr);
          neighbors.forEach(n => {
              if (!visited.has(`${n.row},${n.col}`)) stack.push(n);
          });
      }
    }

    let popped = false;
    if (matches.length >= 3) {
      grid = grid.filter(b => !matches.includes(b));
      score += matches.length * 10;
      scoreEl.textContent = String(score);
      popped = true;
      
      // 2. Remove orphaned bubbles (not connected to ceiling)
      removeOrphans();
    }
    return popped;
  }

  function removeOrphans() {
      const connected = new Set();
      const stack = grid.filter(b => b.y <= ceilingOffset + R * 1.5); // Top row bubbles
      
      while (stack.length > 0) {
          const curr = stack.pop();
          const key = `${curr.row},${curr.col}`;
          if (connected.has(key)) continue;
          connected.add(key);
          
          const neighbors = getNeighbors(curr);
          neighbors.forEach(n => {
              if (!connected.has(`${n.row},${n.col}`)) stack.push(n);
          });
      }
      
      const orphans = grid.filter(b => !connected.has(`${b.row},${b.col}`));
      if (orphans.length > 0) {
          grid = grid.filter(b => connected.has(`${b.row},${b.col}`));
          score += orphans.length * 20; // Bonus for dropping
          scoreEl.textContent = String(score);
      }
  }

  function dropCeiling() {
      // Add a new row of bubbles to the top and push everything down
      grid.forEach(b => {
          b.row += 1;
          b.y = hexY(b.row);
      });
      
      // Determine if new row is odd or even based on offset
      const isOdd = Math.floor(ceilingOffset / (R*1.7)) % 2 === 1;
      const cols = COLS - (isOdd ? 1 : 0);
      
      for (let col = 0; col < cols; col++) {
          grid.push({ 
              row: 0, 
              col, 
              x: hexX(col, 0), 
              y: hexY(0), 
              color: COLORS[Math.floor(Math.random() * 4)] 
          });
      }
      // Push actual drawing boundary down as visual feedback
      ceilingOffset += 5;
  }

  function checkGameOver() {
    if (grid.some(b => b.y + R > canvas.height - R * 3)) {
      endGame();
    }
  }

  function fire(ex, ey) {
    if (!gameActive || shooter) return;
    const bx = canvas.width / 2, by = canvas.height - R;
    const angle = Math.atan2(ey - by, ex - bx);
    
    // Prevent shooting downwards
    if (Math.sin(angle) > -0.1) return;
    
    const speed = 12;
    shooter = {
      x: bx, y: by,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      color: nextColor
    };
    if (shooter.vy > 0) shooter.vy = -Math.abs(shooter.vy);
    animFrame = requestAnimationFrame(update);
  }

  function getPos(e) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    if (e.touches) {
      return { x: (e.touches[0].clientX - rect.left) * scaleX, y: (e.touches[0].clientY - rect.top) * scaleY };
    }
    return { x: (e.clientX - rect.left) * scaleX, y: (e.clientY - rect.top) * scaleY };
  }
  
  function handlePointerMove(e) {
      if (!isPointerDown) return;
      e.preventDefault();
      const pos = getPos(e);
      pointerX = pos.x;
      pointerY = pos.y;
      if (!shooter && gameActive) draw();
  }
  
  function handlePointerDown(e) {
      if (!gameActive) return;
      isPointerDown = true;
      const pos = getPos(e);
      pointerX = pos.x;
      pointerY = pos.y;
      if (!shooter) draw();
  }
  
  function handlePointerUp(e) {
      if (!isPointerDown || !gameActive) return;
      isPointerDown = false;
      const pos = getPos(e);
      fire(pos.x, pos.y);
  }

  function endGame() {
    gameActive = false;
    cancelAnimationFrame(animFrame);
    
    let bestMsg = '';
    if (score > bestScore) {
        bestScore = score;
        localStorage.setItem('bubbles-best', bestScore);
        bestMsg = `<br/><span style="color:var(--accent);">New Best!</span>`;
    } else {
        bestMsg = `<br/>Best: ${bestScore}`;
    }
    
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = `Score: ${score}`;
    document.getElementById('overlay-sub').innerHTML = 'Game over!' + bestMsg;
    startBtn.textContent = 'Play Again';
  }

  // Inject best score into header
  if (bestScore > 0) {
      const bestDiv = document.createElement('div');
      bestDiv.style.fontSize = '0.75rem';
      bestDiv.style.color = 'var(--ink-light)';
      bestDiv.textContent = `Best: ${bestScore}`;
      document.querySelector('.score-wrap').appendChild(bestDiv);
  }

  startBtn.addEventListener('click', () => {
    overlay.classList.add('hidden');
    gameActive = true;
    initGame();
    draw();
  });

  canvas.addEventListener('mousedown', handlePointerDown);
  window.addEventListener('mousemove', handlePointerMove);
  window.addEventListener('mouseup', handlePointerUp);
  
  canvas.addEventListener('touchstart', handlePointerDown, { passive: false });
  window.addEventListener('touchmove', handlePointerMove, { passive: false });
  window.addEventListener('touchend', handlePointerUp);

  window.addEventListener('resize', resize);
  resize();
</script>
