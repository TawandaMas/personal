---
import Base from '../../layouts/Base.astro';
---

<Base title="Bubble Shooter">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Bubble Shooter</h1>
      <div class="score-wrap">Score: <span id="score">0</span></div>
    </div>
  </div>

  <div class="game-wrap" id="game-container">
    <canvas id="bubble-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Bubbles</div>
        <div id="overlay-sub" class="overlay-sub">Tap to aim and fire. Match 3 bubbles to pop.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap anywhere to shoot</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
    aspect-ratio: 0.8;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    overflow: hidden;
  }

  #bubble-canvas { display: block; width: 100%; height: 100%; }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(242, 237, 228, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .overlay.hidden { display: none; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { margin-top: 1.5rem; padding: 0.6rem 1.5rem; background: transparent; border: 1.5px solid var(--accent); color: var(--accent); font-family: var(--font-sans); text-transform: uppercase; cursor: pointer; }
</style>

<script>
  const COLORS = ['#8b3a2a', '#4a6b4a', '#4a6bb3', '#b3a54a', '#7a4ab3'];
  const canvas = document.getElementById('bubble-canvas');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let bubbles = [], projectile = null, score = 0, gameActive = false, r = 18;

  function initBoard() {
    bubbles = [];
    score = 0;
    scoreEl.textContent = '0';
    for (let row = 0; row < 5; row++) {
        for (let col = 0; col < 11; col++) {
            const x = col * 2 * r + (row % 2 === 0 ? r : 2 * r);
            if (x + r > canvas.width) continue;
            bubbles.push({ x, y: row * 1.7 * r + r, color: COLORS[Math.floor(Math.random() * COLORS.length)] });
        }
    }
  }

  function draw() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    bubbles.forEach(b => {
        ctx.fillStyle = b.color;
        ctx.beginPath(); ctx.arc(b.x, b.y, r-1, 0, Math.PI*2); ctx.fill();
    });

    if (projectile) {
        ctx.fillStyle = projectile.color;
        ctx.beginPath(); ctx.arc(projectile.x, projectile.y, r-1, 0, Math.PI*2); ctx.fill();
    }
    
    // Shooter preview
    ctx.fillStyle = COLORS[0]; // Next color logic simplified
    ctx.beginPath(); ctx.arc(canvas.width/2, canvas.height - r, r-1, 0, Math.PI*2); ctx.fill();
  }

  function update() {
    if (projectile) {
        projectile.x += projectile.vx;
        projectile.y += projectile.vy;

        // Walls
        if (projectile.x - r < 0 || projectile.x + r > canvas.width) projectile.vx *= -1;

        // Collision with bubbles
        for (let b of bubbles) {
            const dist = Math.hypot(projectile.x - b.x, projectile.y - b.y);
            if (dist < 2 * r) {
                bubbles.push({...projectile, vx:0, vy:0});
                checkMatches(bubbles[bubbles.length-1]);
                projectile = null;
                break;
            }
        }

        if (projectile && projectile.y < 0) projectile = null;
    }
    draw();
    if (gameActive) requestAnimationFrame(update);
  }

  function checkMatches(newBubble) {
    // simplified match logic: find neighbors with same color
    let matches = [newBubble];
    // This needs a recursive search for a real implementation, but for MVP we'll do radius check
    bubbles = bubbles.filter(b => {
        const dist = Math.hypot(newBubble.x - b.x, newBubble.y - b.y);
        if (dist < 2.5 * r && b.color === newBubble.color) {
            score += 10; scoreEl.textContent = String(score);
            return false;
        }
        return true;
    });
  }

  function fire(e) {
    if (!gameActive || projectile) return;
    const rect = canvas.getBoundingClientRect();
    const tx = (e.clientX || e.touches[0].clientX) - rect.left;
    const ty = (e.clientY || e.touches[0].clientY) - rect.top;
    
    const angle = Math.atan2(ty - (canvas.height - r), tx - canvas.width/2);
    projectile = {
        x: canvas.width/2, y: canvas.height - r,
        vx: Math.cos(angle) * 8, vy: Math.sin(angle) * 8,
        color: COLORS[Math.floor(Math.random() * COLORS.length)]
    };
  }

  canvas.width = 400; canvas.height = 500;
  startBtn.addEventListener('click', () => {
    overlay.classList.add('hidden');
    gameActive = true;
    initBoard();
    update();
  });
  canvas.addEventListener('mousedown', fire);
</script>
