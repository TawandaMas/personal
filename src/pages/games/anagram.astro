---
import Base from '../../layouts/Base.astro';
---

<Base title="Anagram">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Anagram</h1>
      <div class="score-wrap">Score: <span id="score">0</span></div>
    </div>
  </div>

  <div class="game-wrap">
    <div class="anagram-pane">
        <div id="scrambled-letters" class="letter-grid"></div>
        <div id="answer-slots" class="answer-row"></div>
        <div class="action-row">
            <button id="btn-clear" class="action-btn">Clear</button>
            <button id="btn-submit" class="action-btn primary">Submit</button>
        </div>
    </div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Anagram</div>
        <div id="overlay-sub" class="overlay-sub">Unscramble the letters to reveal the hidden word.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap letters to build word · 5 to 7 characters</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  .score-wrap { font-family: var(--font-sans); font-size: 0.8rem; color: var(--ink-light); }
  #score { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    aspect-ratio: 1.2;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    display: flex;
    flex-direction: column;
  }

  .anagram-pane { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; gap: 2rem; }

  .letter-grid { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; }

  .letter-tile {
    width: 3.5rem;
    height: 3.5rem;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-bottom-width: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    user-select: none;
    transition: all 0.15s;
  }
  .letter-tile:hover { transform: translateY(-2px); border-bottom-color: var(--accent); }
  .letter-tile:active { transform: translateY(0); }
  .letter-tile.used { opacity: 0.3; cursor: default; pointer-events: none; }

  .answer-row { display: flex; gap: 0.5rem; min-height: 4rem; border-bottom: 2px solid var(--rule); padding: 0 1rem; align-items: center; width: 100%; justify-content: center; }
  .answer-letter { 
    font-family: var(--font-serif); 
    font-size: 2rem; 
    font-weight: 700; 
    color: var(--ink); 
    text-transform: uppercase;
    border-bottom: 3px solid var(--accent);
    min-width: 1.5rem;
    text-align: center;
  }

  .action-row { display: flex; gap: 1rem; width: 100%; margin-top: 1rem; }
  .action-btn { 
    flex: 1; 
    padding: 0.75rem; 
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    letter-spacing: 0.1em; 
    background: var(--paper); 
    color: var(--ink);
    border: 1.5px solid var(--rule);
    cursor: pointer;
    border-radius: 2rem;
    transition: all 0.2s;
  }
  .action-btn:hover { background: var(--paper-dark); border-color: var(--ink-light); }
  .action-btn.primary { background: var(--ink); color: var(--paper); border-color: var(--ink); }
  .action-btn.primary:hover { opacity: 0.9; }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

<script>
  const WORDS = [
    'ASTRONOMY', 'PHANTOM', 'RHYTHM', 'WHISPER', 'JOURNEY', 'SILENCE', 'CRIMSON', 'MYSTERY', 'HARVEST', 'THUNDER',
    'ORCHARD', 'LANTERN', 'HORIZON', 'ECLIPSE', 'DIAMOND', 'CRYSTAL', 'BLOSSOM', 'VAMPIRE', 'PENGUIN', 'MONSTER',
    'PYRAMID', 'DYNAMITE', 'TORNADO', 'VOLCANO', 'DRAGON', 'CACTUS', 'GUITAR', 'GALAXY', 'PLANET', 'ROCKET',
    'CASTLE', 'WIZARD', 'PIRATE', 'KNIGHT', 'FOREST', 'OCEAN', 'DESERT', 'JUNGLE', 'MOUNTAIN', 'RIVER'
  ];
  
  const letterGrid = document.getElementById('scrambled-letters');
  const answerRow = document.getElementById('answer-slots');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  const startBtn = document.getElementById('start-btn');
  const btnClear = document.getElementById('btn-clear');
  const btnSubmit = document.getElementById('btn-submit');

  let currentWord = '';
  let scrambled = '';
  let userWord = '';
  let score = 0;
  let gameActive = false;

  // Refined Logic
  let activeIndices = [];

  function updateDisplay() {
    letterGrid.innerHTML = '';
    scrambled.split('').forEach((char, idx) => {
        const tile = document.createElement('div');
        tile.className = 'letter-tile';
        if (activeIndices.includes(idx)) tile.classList.add('used');
        tile.textContent = char;
        tile.addEventListener('click', () => {
            if (!activeIndices.includes(idx) && userWord.length < currentWord.length) {
                activeIndices.push(idx);
                userWord += char;
                updateDisplay();
            }
        });
        letterGrid.appendChild(tile);
    });

    answerRow.innerHTML = '';
    // Create empty slots for the entire word length
    for (let i = 0; i < currentWord.length; i++) {
        const span = document.createElement('span');
        span.className = 'answer-letter';
        span.textContent = userWord[i] || '';
        if (i === userWord.length) span.style.borderBottomColor = 'var(--accent)'; // Highlight active cursor
        else span.style.borderBottomColor = 'var(--rule)';
        answerRow.appendChild(span);
    }
  }

  function checkAnswer() {
    if (!gameActive || userWord.length === 0) return;
    
    if (userWord === currentWord) {
        score += currentWord.length * 10;
        scoreEl.textContent = String(score);
        // celebration
        answerRow.animate([
            { transform: 'scale(1)' },
            { transform: 'scale(1.1)', color: 'var(--accent)' },
            { transform: 'scale(1)' }
        ], { duration: 300 });
        
        // Save high score
        const best = localStorage.getItem('anagram-best') || 0;
        if (score > parseInt(best)) localStorage.setItem('anagram-best', score);

        setTimeout(nextWord, 800);
    } else {
        answerRow.animate([
            { transform: 'translateX(-10px)' },
            { transform: 'translateX(10px)' },
            { transform: 'translateX(0)' }
        ], { duration: 200 });
    }
  }

  function handleClear() {
    if (userWord.length > 0) {
        // Just pop the last letter like a backspace for better UX
        const lastIdx = activeIndices.pop();
        userWord = userWord.slice(0, -1);
        updateDisplay();
    }
  }

  function start() {
    score = 0;
    scoreEl.textContent = '0';
    overlay.classList.add('hidden');
    gameActive = true;
    nextWord();
  }

  async function nextWord() {
    userWord = '';
    activeIndices = [];
    currentWord = '';
    scrambled = '';
    
    // Loading state
    letterGrid.innerHTML = '<div style="font-family: var(--font-sans); color: var(--ink-light); font-size: 0.9rem;">Fetching word...</div>';
    answerRow.innerHTML = '';
    btnSubmit.disabled = true;

    try {
        // Request a random word of length between 5 and 8 chars
        const len = Math.floor(Math.random() * 4) + 5;
        const pattern = '?'.repeat(len);
        // Datamuse API: sp is spelled like, max is limit, md=f gets frequency. Adding 'a' or 'e' ensures it's a commonish word.
        const res = await fetch(`https://api.datamuse.com/words?sp=${pattern}&md=f&max=100`);
        const data = await res.json();
        
        if (data && data.length > 0) {
            // Filter out words with spaces or hyphens, and ensure they are somewhat common
            const valid = data.filter(w => !w.word.includes(' ') && !w.word.includes('-') && parseFloat(w.tags?.[0]?.replace('f:','') || 0) > 1);
            if (valid.length > 0) {
                currentWord = valid[Math.floor(Math.random() * valid.length)].word.toUpperCase();
            }
        }
    } catch (e) {
        console.error("API failed, using fallback dictionary:", e);
    }

    if (!currentWord) {
        // Fallback to static dictionary
        currentWord = WORDS[Math.floor(Math.random() * WORDS.length)];
    }

    // Scramble the word ensuring it's actually scrambled
    do {
        scrambled = currentWord.split('').sort(() => Math.random() - 0.5).join('');
    } while (scrambled === currentWord && currentWord.length > 1);

    btnSubmit.disabled = false;
    updateDisplay();
  }

  startBtn.addEventListener('click', start);
  btnClear.addEventListener('click', handleClear);
  btnSubmit.addEventListener('click', checkAnswer);

  // Add keyboard support
  window.addEventListener('keydown', (e) => {
    if (!gameActive || !currentWord) return;
    
    if (e.key === 'Backspace') {
        handleClear();
    } else if (e.key === 'Enter') {
        checkAnswer();
    } else if (/^[a-zA-Z]$/.test(e.key)) {
        const char = e.key.toUpperCase();
        // Find if this character is available in the scrambled pool and not yet used
        const availableIdx = scrambled.split('').findIndex((c, i) => c === char && !activeIndices.includes(i));
        if (availableIdx !== -1 && userWord.length < currentWord.length) {
            activeIndices.push(availableIdx);
            userWord += char;
            updateDisplay();
        }
    }
  });

  // Show previous high score on load
  const bestScore = localStorage.getItem('anagram-best');
  if (bestScore) {
    const hs = document.createElement('div');
    hs.style.fontSize = '0.8rem';
    hs.style.marginTop = '0.5rem';
    hs.style.color = 'var(--ink-light)';
    hs.textContent = `Best: ${bestScore}`;
    document.querySelector('.score-wrap').appendChild(hs);
  }
</script>
