---
import Base from '../../layouts/Base.astro';
---

<Base title="Number Sequence">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Number Sequence</h1>
      <div class="score-wrap">Next: <span id="next-num">1</span> · Time: <span id="timer">0.00</span>s</div>
    </div>
  </div>

  <div class="game-wrap">
    <div id="grid" class="number-grid"></div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">1 to 25</div>
        <div id="overlay-sub" class="overlay-sub">Tap the numbers in order as fast as you can.</div>
        <button id="start-btn" class="start-btn">Start</button>
      </div>
    </div>
  </div>

  <div class="hint">Focus on the center · Use peripheral vision</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  .score-wrap { font-family: var(--font-sans); font-size: 0.8rem; color: var(--ink-light); }
  #next-num, #timer { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
  }

  .number-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(5, 1fr);
    width: 100%;
    height: 100%;
    gap: 1px;
    background: var(--rule);
  }

  .number-cell {
    background: var(--paper-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
    transition: all 0.1s;
  }
  .number-cell:hover { background: var(--paper-crease); }
  .number-cell:active { background: var(--accent-light); color: white; }
  .number-cell.correct { background: var(--paper); color: var(--ink-light); cursor: default; }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

<script>
const grid = document.getElementById('grid');
  const nextEl = document.getElementById('next-num');
  const timerEl = document.getElementById('timer');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  
  // Create difficulty UI dynamically inside overlay or replace start btn logic
  const diffWrap = document.createElement('div');
  diffWrap.style.display = 'flex';
  diffWrap.style.gap = '0.5rem';
  diffWrap.style.justifyContent = 'center';
  diffWrap.style.marginTop = '1.5rem';
  diffWrap.style.flexWrap = 'wrap';

  [9, 16, 25, 36, 49].forEach(size => {
      const btn = document.createElement('button');
      btn.textContent = `${Math.sqrt(size)}x${Math.sqrt(size)}`;
      btn.className = 'start-btn';
      btn.style.marginTop = '0';
      btn.style.padding = '0.5rem 1rem';
      btn.addEventListener('click', () => startGame(size));
      diffWrap.appendChild(btn);
  });
  
  document.getElementById('start-btn').replaceWith(diffWrap);

  let nextNum = 1;
  let targetNum = 25;
  let startTime = 0;
  let timerInterval = null;
  let gameActive = false;

  function initGrid(size) {
    grid.innerHTML = '';
    const cols = Math.sqrt(size);
    grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
    grid.style.gridTemplateRows = `repeat(${cols}, 1fr)`;
    
    // Scale font
    const fontSize = cols >= 7 ? '1rem' : (cols >= 6 ? '1.2rem' : '1.5rem');
    
    let nums = Array.from({length: size}, (_, i) => i + 1);
    
    // Shuffle
    for (let i = nums.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [nums[i], nums[j]] = [nums[j], nums[i]];
    }

    nums.forEach(n => {
      const cell = document.createElement('div');
      cell.className = 'number-cell';
      cell.style.fontSize = fontSize;
      cell.textContent = String(n);
      cell.dataset.num = String(n);
      cell.addEventListener('mousedown', (e) => { e.preventDefault(); handleTap(cell, n); });
      cell.addEventListener('touchstart', (e) => { e.preventDefault(); handleTap(cell, n); }, {passive: false});
      grid.appendChild(cell);
    });
  }

  function handleTap(cell, n) {
    if (!gameActive) return;
    if (n === nextNum) {
      cell.classList.add('correct');
      nextNum++;
      if (nextNum > targetNum) {
        endGame();
      } else {
        nextEl.textContent = String(nextNum);
      }
    } else {
        // penalty flash
        cell.animate([
            { background: '#b34a3b', color: 'white' },
            { background: 'var(--paper-dark)', color: 'var(--ink)' }
        ], { duration: 200 });
    }
  }

  function startGame(size) {
    targetNum = size;
    nextNum = 1;
    gameActive = true;
    nextEl.textContent = '1';
    timerEl.textContent = '0.00';
    overlay.classList.add('hidden');
    
    // Update score header to show mode best
    const bestScore = localStorage.getItem(`best-numbers-${size}`);
    const scoreWrap = document.querySelector('.score-wrap');
    const existingBest = document.getElementById('best-display');
    if (existingBest) existingBest.remove();
    
    if (bestScore) {
        const bestDiv = document.createElement('div');
        bestDiv.id = 'best-display';
        bestDiv.style.fontSize = '0.75rem';
        bestDiv.style.color = 'var(--ink-light)';
        bestDiv.style.marginTop = '0.2rem';
        bestDiv.textContent = `Best ${Math.sqrt(size)}x${Math.sqrt(size)}: ${bestScore}s`;
        scoreWrap.appendChild(bestDiv);
    }
    
    initGrid(size);
    
    startTime = performance.now();
    timerInterval = setInterval(() => {
      const elapsed = (performance.now() - startTime) / 1000;
      timerEl.textContent = elapsed.toFixed(2);
    }, 10);
  }

  function endGame() {
    gameActive = false;
    clearInterval(timerInterval);
    const finalTime = timerEl.textContent;
    overlay.classList.remove('hidden');
    overlayTitle.textContent = `${finalTime}s`;
    
    let msg = "Fast!";
    const timeNum = parseFloat(finalTime);
    
    // Rough tier logic scaling with size
    const expectedTime = targetNum * 0.8; 
    
    if (timeNum < expectedTime * 0.7) msg = "Elite speed!";
    else if (timeNum > expectedTime * 1.5) msg = "Take your time.";
    
    overlaySub.textContent = msg;

    const bestKey = `best-numbers-${targetNum}`;
    const best = localStorage.getItem(bestKey);
    if (!best || timeNum < parseFloat(best)) {
        localStorage.setItem(bestKey, finalTime);
        overlaySub.innerHTML = `<span style="color:var(--accent)">New Best!</span><br/>${msg}`;
    } else {
        overlaySub.innerHTML = `${msg}<br/>Best: ${best}s`;
    }
  }
</script>

