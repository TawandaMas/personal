---
import Base from '../../layouts/Base.astro';
---

<Base title="Path Finder">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Path Finder</h1>
      <div class="score-wrap">Level: <span id="level">1</span>/5</div>
    </div>
  </div>

  <div class="game-wrap">
    <canvas id="path-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Path Finder</div>
        <div id="overlay-sub" class="overlay-sub">Connect the matching dots. Paths cannot cross.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Drag from dot to dot · Fill the grid</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #level { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
  }

  #path-canvas { display: block; width: 100%; height: 100%; cursor: crosshair; }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

  const COLORS = ['#8b3a2a', '#4a6b4a', '#4a6bb3', '#b3a54a', '#7a4ab3'];
  const canvas = document.getElementById('path-canvas');
  const ctx = canvas.getContext('2d');
  const levelEl = document.getElementById('level');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let grid = 5, cellSize, dots = [], paths = [], currentPath = null;
  let level = parseInt(localStorage.getItem('pathfinder-level') || 1);

  function generateSolvableLevel() {
      // Procedural Generation:
      // We start with an empty grid. We pick a random empty cell, start a path of color C,
      // and do a random walk until we hit a dead end or decide to stop.
      // The start and end of that walk become the "dots" for color C.
      // We repeat for 3 to 5 colors.
      
      const numColors = Math.min(3 + Math.floor(level / 3), 5); // scales up to 5 colors
      grid = Math.min(5 + Math.floor(level / 5), 8); // grid grows slowly up to 8x8
      
      let generatedDots = [];
      let attempts = 0;
      
      while(generatedDots.length < numColors * 2 && attempts < 50) {
          attempts++;
          generatedDots = [];
          let occupied = Array(grid).fill(true).map(() => Array(grid).fill(false));
          
          for(let colorIdx=0; colorIdx<numColors; colorIdx++) {
              // Find random empty start
              let startR, startC;
              let found = false;
              for(let tries=0; tries<50; tries++) {
                  startR = Math.floor(Math.random() * grid);
                  startC = Math.floor(Math.random() * grid);
                  if (!occupied[startR][startC]) { found = true; break; }
              }
              if (!found) break; // grid too full
              
              occupied[startR][startC] = true;
              let currR = startR, currC = startC;
              let pathLen = 0;
              const targetLen = Math.floor(Math.random() * 4) + 3; // 3 to 6 steps
              
              while(pathLen < targetLen) {
                  const dirs = [[-1,0],[1,0],[0,-1],[0,1]].sort(()=>Math.random()-0.5);
                  let moved = false;
                  for(let [dr, dc] of dirs) {
                      const nr = currR+dr, nc = currC+dc;
                      if (nr>=0 && nr<grid && nc>=0 && nc<grid && !occupied[nr][nc]) {
                          occupied[nr][nc] = true;
                          currR = nr; currC = nc;
                          pathLen++;
                          moved = true;
                          break;
                      }
                  }
                  if (!moved) break; // dead end
              }
              
              // We need at least 1 step away to be a valid puzzle
              if (pathLen > 0) {
                  generatedDots.push({r: startR, c: startC, colorIdx});
                  generatedDots.push({r: currR, c: currC, colorIdx});
              } else {
                  occupied[startR][startC] = false; // backtrack
              }
          }
      }
      
      // Fallback if gen failed
      if (generatedDots.length < 4) {
          grid = 5;
          return [
              {r:0, c:0, colorIdx: 0}, {r:4, c:4, colorIdx: 0},
              {r:0, c:4, colorIdx: 1}, {r:4, c:0, colorIdx: 1}
          ];
      }
      return generatedDots;
  }

  function initLevel() {
    dots = generateSolvableLevel();
    resize(); // will set cellSize and draw
    paths = [];
    currentPath = null;
    levelEl.textContent = String(level);
  }

  function draw() {
    ctx.fillStyle = '#e8e0d0'; ctx.fillRect(0,0,canvas.width,canvas.height);
    
    // Grid lines
    ctx.strokeStyle = 'rgba(0,0,0,0.05)';
    for(let i=0; i<=grid; i++) {
        ctx.beginPath(); ctx.moveTo(i*cellSize, 0); ctx.lineTo(i*cellSize, canvas.height); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, i*cellSize); ctx.lineTo(canvas.width, i*cellSize); ctx.stroke();
    }

    // Paths
    paths.forEach(p => drawPath(p));
    if (currentPath) drawPath(currentPath);

    // Dots
    dots.forEach(d => {
        ctx.fillStyle = COLORS[d.colorIdx];
        ctx.beginPath(); ctx.arc(d.c*cellSize+cellSize/2, d.r*cellSize+cellSize/2, cellSize*0.3, 0, Math.PI*2); ctx.fill();
    });
  }

  function drawPath(p) {
    ctx.strokeStyle = COLORS[p.colorIdx];
    ctx.lineWidth = cellSize * 0.4;
    ctx.lineCap = 'round'; ctx.lineJoin = 'round';
    ctx.beginPath();
    p.points.forEach((pt, i) => {
        const x = pt.c*cellSize + cellSize/2, y = pt.r*cellSize + cellSize/2;
        if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    });
    ctx.stroke();
  }

  function handleStart(e) {
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX || e.touches[0].clientX) - rect.left;
    const y = (e.clientY || e.touches[0].clientY) - rect.top;
    const r = Math.floor(y/cellSize), c = Math.floor(x/cellSize);
    
    const dot = dots.find(d => d.r === r && d.c === c);
    if (dot) {
        // Clear existing path for this color
        paths = paths.filter(p => p.colorIdx !== dot.colorIdx);
        currentPath = {colorIdx: dot.colorIdx, points: [{r, c}]};
        draw();
    }
  }

  function handleMove(e) {
    if (!currentPath) return;
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX || (e.touches?.[0]?.clientX)) - rect.left;
    const y = (e.clientY || (e.touches?.[0]?.clientY)) - rect.top;
    const r = Math.floor(y/cellSize), c = Math.floor(x/cellSize);

    if (r<0 || r>=grid || c<0 || c>=grid) return;
    
    const last = currentPath.points[currentPath.points.length-1];
    if (last.r !== r || last.c !== c) {
        // Must be adjacent
        if (Math.abs(last.r - r) + Math.abs(last.c - c) === 1) {
            const usedInCurrent = currentPath.points.some(p => p.r === r && p.c === c);
            const usedInOther = paths.some(p => p.points.some(pt => pt.r === r && pt.c === c));
            const isOtherDot = dots.some(d => d.r === r && d.c === c && d.colorIdx !== currentPath.colorIdx);
            
            // Allow moving backwards along our own path
            if (currentPath.points.length > 1) {
                const prev = currentPath.points[currentPath.points.length - 2];
                if (prev.r === r && prev.c === c) {
                    currentPath.points.pop();
                    draw();
                    return;
                }
            }

            if (!usedInCurrent && !usedInOther && !isOtherDot) {
                currentPath.points.push({r, c});
                draw();
            }
        }
    }
  }

  function handleEnd() {
    if (!currentPath) return;
    const last = currentPath.points[currentPath.points.length-1];
    const dot = dots.find(d => d.r === last.r && d.c === last.c && d.colorIdx === currentPath.colorIdx);
    const start = currentPath.points[0];
    if (dot && (start.r !== last.r || start.c !== last.c)) {
        paths.push(currentPath);
        if (paths.length === dots.length/2) endGame();
    }
    currentPath = null;
    draw();
  }

  function endGame() {
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = "Connected!";
    startBtn.textContent = 'Next Level';
    level++;
    localStorage.setItem('pathfinder-level', level);
  }

  canvas.addEventListener('touchstart', e => { e.preventDefault(); handleStart(e); }, { passive: false });
  window.addEventListener('touchmove', e => { if (currentPath) { e.preventDefault(); handleMove(e); } }, { passive: false });
  window.addEventListener('touchend', handleEnd);

  function resize() {
    const size = canvas.parentElement.clientWidth;
    canvas.width = size;
    canvas.height = size;
    cellSize = size / grid;
    draw();
  }

  canvas.width = 400; canvas.height = 400;
  startBtn.addEventListener('click', () => { overlay.classList.add('hidden'); initLevel(); });
  canvas.addEventListener('mousedown', handleStart);
  window.addEventListener('mousemove', handleMove);
  window.addEventListener('mouseup', handleEnd);
  window.addEventListener('resize', resize);
  
  // Need to wait for fonts and CSS to settle before first measurement
  setTimeout(resize, 100);
</script>
