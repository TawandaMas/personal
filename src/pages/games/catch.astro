---
import Base from '../../layouts/Base.astro';
---

<Base title="Catch">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Catch</h1>
      <div class="score-wrap">Score: <span id="score">0</span> · Lives: <span id="lives">3</span></div>
    </div>
  </div>

  <div class="game-wrap" id="game-container">
    <canvas id="catch-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Catch</div>
        <div id="overlay-sub" class="overlay-sub">Catch the falling ink dots. Avoid the red ones!</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Move basket with mouse or touch</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score, #lives { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
    aspect-ratio: 0.8;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    overflow: hidden;
  }

  #catch-canvas { display: block; width: 100%; height: 100%; }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(242, 237, 228, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { margin-top: 1.5rem; padding: 0.6rem 1.5rem; background: transparent; border: 1.5px solid var(--accent); color: var(--accent); font-family: var(--font-sans); text-transform: uppercase; cursor: pointer; }
</style>

<script>
  const canvas = document.getElementById('catch-canvas');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const livesEl = document.getElementById('lives');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let basket, items, score, lives, gameLoop, running = false, speed = 3;

  function init() {
    basket = { x: canvas.width / 2 - 30, w: 60, h: 15 };
    items = [];
    score = 0;
    lives = 3;
    speed = 3;
    scoreEl.textContent = '0';
    livesEl.textContent = '3';
  }

  function spawnItem() {
    const isBad = Math.random() < 0.15;
    items.push({
        x: Math.random() * (canvas.width - 20),
        y: -20,
        r: 8,
        bad: isBad,
        color: isBad ? '#b34a3b' : '#1c1814'
    });
  }

  function draw() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Basket
    ctx.fillStyle = '#4a4035';
    ctx.fillRect(basket.x, canvas.height - 30, basket.w, basket.h);

    // Items
    items.forEach(item => {
        ctx.fillStyle = item.color;
        ctx.beginPath();
        ctx.arc(item.x, item.y, item.r, 0, Math.PI * 2);
        ctx.fill();
    });
  }

  function update() {
    speed += 0.001;
    items.forEach((item, i) => {
        item.y += speed;
        // Catch
        if (item.y + item.r > canvas.height - 30 && item.x > basket.x && item.x < basket.x + basket.w) {
            if (item.bad) {
                lives--;
                livesEl.textContent = String(lives);
            } else {
                score++;
                scoreEl.textContent = String(score);
            }
            items.splice(i, 1);
        } else if (item.y > canvas.height) {
            if (!item.bad) {
                lives--;
                livesEl.textContent = String(lives);
            }
            items.splice(i, 1);
        }
        if (lives <= 0) return endGame();
    });

    if (Math.random() < 0.02) spawnItem();

    draw();
    gameLoop = requestAnimationFrame(update);
  }

  function moveBasket(e) {
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX || e.touches[0].clientX) - rect.left;
    basket.x = Math.max(0, Math.min(canvas.width - basket.w, x - basket.w / 2));
  }

  function startGame() {
    running = true;
    overlay.classList.add('hidden');
    init();
    update();
  }

  function endGame() {
    running = false;
    cancelAnimationFrame(gameLoop);
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = `Score: ${score}`;
    startBtn.textContent = 'Play Again';
  }

  canvas.width = 400;
  canvas.height = 500;
  draw();

  startBtn.addEventListener('click', startGame);
  window.addEventListener('mousemove', moveBasket);
  window.addEventListener('touchmove', e => { if (running) { moveBasket(e); e.preventDefault(); } }, { passive: false });
</script>
