---
import Base from '../../layouts/Base.astro';
---

<Base title="Catch">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Catch</h1>
      <div class="score-wrap">Score: <span id="score">0</span> · Lives: <span id="lives">3</span></div>
    </div>
  </div>

  <div class="game-wrap" id="game-container">
    <canvas id="catch-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Catch</div>
        <div id="overlay-sub" class="overlay-sub">Catch the falling ink dots. Avoid the red ones!</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Move basket with mouse or touch</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score, #lives { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative; width: 100%; max-width: 440px; margin: 0 auto;
    aspect-ratio: 0.8; border: 1.5px solid var(--rule);
    background: var(--paper-dark); overflow: hidden; touch-action: none;
  }

  #catch-canvas { display: block; width: 100%; height: 100%; }

  .overlay {
    position: absolute; inset: 0; background: var(--paper); opacity: 0.98;
    display: flex; align-items: center; justify-content: center; z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn {
    margin-top: 1.5rem; padding: 0.75rem 2rem;
    background: var(--ink); color: var(--paper); border: none; border-radius: 2rem;
    font-family: var(--font-sans); font-weight: 600; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
  .hint { font-family: var(--font-sans); font-size: 0.65rem; color: var(--ink-light); text-align: center; margin-top: 1.5rem; text-transform: uppercase; }
</style>

<script>
const canvas = document.getElementById('catch-canvas');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const livesEl = document.getElementById('lives');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let basket, items, score, lives, gameLoop, running = false, speed = 2;
  let wind = 0;
  let targetWind = 0;
  let lastTime = 0;
  let bestScore = parseInt(localStorage.getItem('catch-best') || 0);

  const BASKET_W = 100, BASKET_H = 14, ITEM_R = 8;

  function resize() {
    const wrap = canvas.parentElement;
    canvas.width = wrap.clientWidth;
    canvas.height = wrap.clientHeight;
    if (!running) drawIdle();
  }

  function drawIdle() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    drawBasket();
  }

  function drawBasket() {
    const bx = basket ? basket.x : (canvas.width / 2 - BASKET_W / 2);
    // Basket shape
    ctx.fillStyle = '#4a4035';
    ctx.beginPath();
    ctx.roundRect(bx, canvas.height - 40, BASKET_W, BASKET_H, 4);
    ctx.fill();
    // Basket sides
    ctx.fillStyle = '#3a3028';
    ctx.beginPath();
    ctx.roundRect(bx - 4, canvas.height - 40, 5, BASKET_H + 8, 2);
    ctx.fill();
    ctx.beginPath();
    ctx.roundRect(bx + BASKET_W - 1, canvas.height - 40, 5, BASKET_H + 8, 2);
    ctx.fill();
  }

  function init() {
    basket = { x: canvas.width / 2 - BASKET_W / 2 };
    items = [];
    score = 0;
    lives = 3;
    speed = 2;
    wind = 0;
    targetWind = 0;
    lastTime = 0;
    scoreEl.textContent = '0';
    livesEl.textContent = '3';
  }

  function spawnItem() {
    const rnd = Math.random();
    let type = 'good';
    let r = ITEM_R;
    let color = '#1c1814';
    let weight = 1;

    if (rnd < 0.05) {
        type = 'gold';
        r = ITEM_R * 1.2;
        color = '#d4af37';
        weight = 1.2;
    } else if (rnd < 0.15) {
        type = 'heavy-bad';
        r = ITEM_R * 1.5;
        color = '#6a2a1e';
        weight = 2; // Falls faster, less affected by wind
    } else if (rnd < 0.3) {
        type = 'bad';
        r = ITEM_R;
        color = '#b34a3b';
        weight = 1;
    }

    items.push({
      x: Math.max(r, Math.min(canvas.width - r, Math.random() * canvas.width)),
      y: -r, r, type, color, weight
    });
  }

  function draw() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Wind indicator
    if (Math.abs(wind) > 0.5) {
        ctx.fillStyle = 'rgba(180, 165, 140, 0.2)';
        for (let i = 0; i < 5; i++) {
            const wx = (Date.now() / 10 * wind + i * 100) % canvas.width;
            ctx.fillRect(wx < 0 ? canvas.width + wx : wx, 100 + i * 50, 40, 2);
        }
    }

    items.forEach(item => {
      ctx.fillStyle = item.color;
      ctx.beginPath();
      ctx.arc(item.x, item.y, item.r, 0, Math.PI * 2);
      ctx.fill();
      
      // Highlight for good / gold
      if (item.type === 'good' || item.type === 'gold') {
        ctx.fillStyle = 'rgba(255,255,255,0.3)';
        ctx.beginPath();
        ctx.arc(item.x - item.r * 0.3, item.y - item.r * 0.3, item.r * 0.35, 0, Math.PI * 2);
        ctx.fill();
      }
      
      // Star shape inside gold
      if (item.type === 'gold') {
          ctx.fillStyle = 'rgba(255,255,255,0.8)';
          ctx.font = '10px sans-serif';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText('+', item.x, item.y);
      }
    });

    drawBasket();
  }

  function loop(timestamp) {
    if (!running) return;
    if (!lastTime) lastTime = timestamp;
    const dt = timestamp - lastTime;
    lastTime = timestamp;

    // Slowly adjust wind
    if (Math.random() < 0.01) {
        targetWind = (Math.random() - 0.5) * 6; // -3 to 3 horizontal shift
    }
    wind += (targetWind - wind) * 0.01;

    speed += 0.0002;
    if (Math.random() < 0.015 + score * 0.0002) spawnItem();

    let nextItems = [];
    
    for (const item of items) {
      // Apply gravity & wind based on weight
      item.y += speed * (item.weight === 2 ? 1.5 : 1);
      item.x += wind / item.weight;
      
      // Bounce off walls
      if (item.x - item.r < 0) { item.x = item.r; item.x += Math.abs(wind)/item.weight; }
      if (item.x + item.r > canvas.width) { item.x = canvas.width - item.r; item.x -= Math.abs(wind)/item.weight; }

      const basketY = canvas.height - 40;
      const caught = item.y + item.r >= basketY && item.y - item.r < basketY + BASKET_H &&
                     item.x + item.r > basket.x - 10 && item.x - item.r < basket.x + BASKET_W + 10;
      const missed = item.y - item.r > canvas.height;

      if (caught) {
        if (item.type === 'bad' || item.type === 'heavy-bad') {
          lives = Math.max(0, lives - (item.type === 'heavy-bad' ? 2 : 1));
          livesEl.textContent = String(lives);
          if (lives <= 0) return endGame();
        } else if (item.type === 'gold') {
          score += 5;
          if (lives < 5) lives++; // max 5 lives
          livesEl.textContent = String(lives);
          scoreEl.textContent = String(score);
        } else {
          score++;
          scoreEl.textContent = String(score);
        }
      } else if (missed) {
        if (item.type === 'good' || item.type === 'gold') {
          lives = Math.max(0, lives - 1);
          livesEl.textContent = String(lives);
          if (lives <= 0) return endGame();
        }
      } else {
        nextItems.push(item);
      }
    }
    items = nextItems;

    draw();
    gameLoop = requestAnimationFrame(loop);
  }

  function getX(e) {
    const rect = canvas.getBoundingClientRect();
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const scale = canvas.width / rect.width;
    return (clientX - rect.left) * scale;
  }

  function moveBasket(e) {
    if (!running) return;
    e.preventDefault();
    const x = getX(e);
    basket.x = Math.max(0, Math.min(canvas.width - BASKET_W, x - BASKET_W / 2));
  }

  function startGame() {
    running = true;
    overlay.classList.add('hidden');
    init();
    gameLoop = requestAnimationFrame(loop);
  }

  function endGame() {
    running = false;
    cancelAnimationFrame(gameLoop);
    
    let bestMsg = '';
    if (score > bestScore) {
        bestScore = score;
        localStorage.setItem('catch-best', bestScore);
        bestMsg = `<br/><span style="color:var(--accent);">New Best!</span>`;
    } else {
        bestMsg = `<br/>Best: ${bestScore}`;
    }
    
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = `Score: ${score}`;
    document.getElementById('overlay-sub').innerHTML = (lives <= 0 ? 'No lives left. Try again!' : 'Game over!') + bestMsg;
    startBtn.textContent = 'Play Again';
  }

  // Header display max
  if (bestScore > 0) {
      const bestDiv = document.createElement('div');
      bestDiv.style.fontSize = '0.75rem';
      bestDiv.style.color = 'var(--ink-light)';
      bestDiv.textContent = `Best: ${bestScore}`;
      document.querySelector('.score-wrap').appendChild(bestDiv);
  }

  startBtn.addEventListener('click', startGame);
  document.addEventListener('mousemove', moveBasket); // Document-level to prevent pointer losing canvas
  document.addEventListener('touchmove', moveBasket, { passive: false });
  document.addEventListener('touchstart', moveBasket, { passive: false });
  window.addEventListener('resize', resize);
  resize();
</script>

