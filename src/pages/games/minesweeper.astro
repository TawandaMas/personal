---
import Base from '../../layouts/Base.astro';
---

<Base title="Minesweeper">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Minesweeper</h1>
      <div class="score-wrap">Mines: <span id="mine-count">10</span></div>
    </div>
  </div>

  <div class="game-wrap">
    <div id="grid" class="mine-grid"></div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Minesweeper</div>
        <div id="overlay-sub" class="overlay-sub">Uncover all safe squares. Long-press to flag mines.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap to uncover · Long-press/Right-click to flag</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #mine-count { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
  }

  .mine-grid {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    grid-template-rows: repeat(9, 1fr);
    width: 100%;
    height: 100%;
    background: var(--rule);
    gap: 1px;
  }

  .cell {
    background: var(--paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    user-select: none;
  }
  .cell.revealed { background: var(--paper-dark); cursor: default; }
  .cell.mine { background: var(--accent); }
  .cell.flagged::after { content: '🚩'; font-size: 0.8rem; }
  
  .c-1 { color: blue; }
  .c-2 { color: green; }
  .c-3 { color: red; }
  .c-4 { color: darkblue; }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

<script>
  const gridEl = document.getElementById('grid');
  const mineEl = document.getElementById('mine-count');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');
  
  // Difficulty Configs
  const LEVELS = {
      'Beginner': { r: 9, c: 9, m: 10 },
      'Intermediate': { r: 16, c: 16, m: 40 },
      'Expert': { r: 16, c: 30, m: 99 }
  };
  let currentLevel = 'Beginner';

  let board = [], mines = [], gameActive = false, flags = 0, firstClick = true;
  let cols = 9, rows = 9, totalMines = 10;

  function setLevel(lvl) {
      currentLevel = lvl;
      rows = LEVELS[lvl].r;
      cols = LEVELS[lvl].c;
      totalMines = LEVELS[lvl].m;
      
      // Update Grid CSS
      gridEl.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
      gridEl.style.gridTemplateRows = `repeat(${rows}, 1fr)`;
      
      // Responsive sizing tweak
      if (lvl === 'Expert') {
          gridEl.parentElement.style.maxWidth = '900px';
          gridEl.style.aspectRatio = '30/16';
      } else if (lvl === 'Intermediate') {
          gridEl.parentElement.style.maxWidth = '600px';
          gridEl.style.aspectRatio = '1';
      } else {
          gridEl.parentElement.style.maxWidth = '440px';
          gridEl.style.aspectRatio = '1';
      }
      
      initBoard();
  }

  function initBoard() {
    board = Array(rows * cols).fill(0);
    mines = [];
    flags = 0;
    firstClick = true;
    render();
    gameActive = true;
  }

  function placeMines(firstIdx) {
    while(mines.length < totalMines) {
        let r = Math.floor(Math.random() * (rows * cols));
        // Prevent mine on first click
        if (r !== firstIdx && !mines.includes(r)) mines.push(r);
    }
    mines.forEach(m => {
        const neighbors = getNeighbors(m);
        neighbors.forEach(n => board[n]++);
    });
  }

  function getNeighbors(idx) {
    const r = Math.floor(idx / cols), c = idx % cols;
    const res = [];
    for (let dr=-1; dr<=1; dr++) {
        for (let dc=-1; dc<=1; dc++) {
            if (dr===0 && dc===0) continue;
            let nr=r+dr, nc=c+dc;
            if (nr>=0 && nr<rows && nc>=0 && nc<cols) res.push(nr*cols+nc);
        }
    }
    return res;
  }

  function render() {
    gridEl.innerHTML = '';
    board.forEach((val, i) => {
        const cell = document.createElement('div');
        cell.className = 'cell';
        cell.dataset.index = i;
        
        // Scale font slightly down for expert
        if (currentLevel === 'Expert') cell.style.fontSize = '0.7rem';
        
        cell.addEventListener('mousedown', (e) => {
            if (e.button === 2) { e.preventDefault(); flag(i); } // Right click
            else if (e.button === 0) reveal(i); // Left click
        });
        // Touch support for flagging
        let pressTimer;
        cell.addEventListener('touchstart', (e) => {
             e.preventDefault();
             pressTimer = window.setTimeout(() => flag(i), 400);
        });
        cell.addEventListener('touchend', (e) => {
             e.preventDefault();
             if (pressTimer) { clearTimeout(pressTimer); reveal(i); }
        });
        cell.addEventListener('touchmove', () => { if(pressTimer) clearTimeout(pressTimer); });
        
        cell.addEventListener('contextmenu', e => e.preventDefault());
        gridEl.appendChild(cell);
    });
    mineEl.textContent = String(totalMines - flags);
  }

  function reveal(i) {
    if (!gameActive) return;
    const cell = gridEl.children[i];
    if (cell.classList.contains('revealed') || cell.classList.contains('flagged')) return;
    
    if (firstClick) {
        firstClick = false;
        placeMines(i);
    }

    if (mines.includes(i)) return endGame(false);
    
    cell.classList.add('revealed');
    if (board[i] > 0) {
        cell.textContent = String(board[i]);
        cell.classList.add(`c-${board[i]}`);
    } else {
        // Flood fill empty neighbors
        getNeighbors(i).forEach(n => reveal(n));
    }

    checkWin();
  }

  function flag(i) {
    if (!gameActive) return;
    const cell = gridEl.children[i];
    if (cell.classList.contains('revealed')) return;
    cell.classList.toggle('flagged');
    flags += cell.classList.contains('flagged') ? 1 : -1;
    mineEl.textContent = String(totalMines - flags);
    checkWin();
  }

  function checkWin() {
      const revealed = gridEl.querySelectorAll('.cell.revealed').length;
      if (revealed === (rows * cols) - totalMines) {
          endGame(true);
      }
  }

  function endGame(win) {
    gameActive = false;
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = win ? "Clear!" : "Boom!";
    document.getElementById('overlay-title').style.color = win ? "#4a6b4a" : "#b34a3b";
    mines.forEach(m => {
        gridEl.children[m].classList.add('mine');
        gridEl.children[m].textContent = '💣';
    });
    
    if (win) {
        const key = `minesweeper-${currentLevel}`;
        const wins = parseInt(localStorage.getItem(key) || 0) + 1;
        localStorage.setItem(key, wins);
        document.getElementById('overlay-sub').textContent = `${currentLevel} Wins: ${wins}`;
    }
  }

  // Inject Difficulty Buttons into overlay
  const overlayContent = document.querySelector('.overlay-content');
  const diffRow = document.createElement('div');
  diffRow.style.cssText = "display:flex; justify-content:center; gap: 0.5rem; margin-top: 1.5rem;";
  
  ['Beginner', 'Intermediate', 'Expert'].forEach(lvl => {
      const btn = document.createElement('button');
      btn.textContent = lvl;
      btn.className = 'diff-btn';
      btn.style.cssText = "background:var(--paper); color:var(--ink); border:1px solid var(--rule); padding: 0.5rem; border-radius: 4px; cursor:pointer;";
      btn.addEventListener('click', () => {
          document.querySelectorAll('.diff-btn').forEach(b => b.style.background = 'var(--paper)');
          btn.style.background = 'var(--rule)';
          currentLevel = lvl;
      });
      diffRow.appendChild(diffRow); // MISTAKE, FIXING IN NEXT STEP
  });

  // Let's actually append them correctly
  diffRow.innerHTML = '';
  ['Beginner', 'Intermediate', 'Expert'].forEach(lvl => {
      const btn = document.createElement('button');
      btn.textContent = lvl;
      btn.className = 'key-btn'; // reuse existing nice button style if available, or inline
      btn.style.cssText = "background:var(--paper); border:1.5px solid var(--rule); padding:0.4rem 0.8rem; border-radius:1rem; cursor:pointer; font-family:var(--font-sans); font-size:0.8rem; transition:all 0.2s;";
      btn.onclick = (e) => {
          e.stopPropagation();
          document.querySelectorAll('.diff-btn').forEach(b => { b.style.background = 'var(--paper)'; b.style.color = 'var(--ink)'; });
          btn.style.background = 'var(--ink)';
          btn.style.color = 'white';
          btn.classList.add('diff-btn');
          currentLevel = lvl;
      };
      if (lvl === 'Beginner') btn.onclick({stopPropagation:()=>{}}); // pre-select
      diffRow.appendChild(btn);
  });
  
  overlayContent.insertBefore(diffRow, startBtn);

  startBtn.addEventListener('click', () => {
      overlay.classList.add('hidden');
      setLevel(currentLevel);
  });
</script>
