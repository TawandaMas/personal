---
import Base from '../../layouts/Base.astro';
---

<Base title="Wordle">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Wordle</h1>
      <div class="score-wrap">Attempt: <span id="attempt">1</span>/6</div>
    </div>
  </div>

  <div class="game-wrap">
    <div id="grid" class="wordle-grid"></div>
    <div id="keyboard" class="keyboard"></div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Daily Word</div>
        <div id="overlay-sub" class="overlay-sub">Guess the 5-letter word in 6 tries.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Green: Right place · Yellow: Wrong place · Grey: Not in word</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #attempt { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 1.5rem;
    align-items: center;
  }

  .wordle-grid {
    display: grid;
    grid-template-rows: repeat(6, 1fr);
    gap: 5px;
    width: 250px;
  }
  .wordle-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 5px;
  }
  .tile {
    aspect-ratio: 1;
    border: 2px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    background: var(--paper);
    transition: all 0.2s;
  }
  .tile.filled { border-color: var(--ink-mid); }
  .tile.correct { background: #4a6b4a; border-color: #4a6b4a; color: white; }
  .tile.present { background: #b3a54a; border-color: #b3a54a; color: white; }
  .tile.absent { background: #8a7d6a; border-color: #8a7d6a; color: white; }

  .keyboard {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 100%;
  }
  .kb-row { display: flex; justify-content: center; gap: 5px; }
  .key {
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 10px 5px;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    min-width: 28px;
    text-align: center;
    user-select: none;
  }
  .key.wide { min-width: 50px; }
  .key.correct { background: #4a6b4a; color: white; border-color: #4a6b4a; }
  .key.present { background: #b3a54a; color: white; border-color: #b3a54a; }
  .key.absent { background: #8a7d6a; color: white; border-color: #8a7d6a; }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(242, 237, 228, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { margin-top: 1.5rem; padding: 0.6rem 1.5rem; background: transparent; border: 1.5px solid var(--accent); color: var(--accent); font-family: var(--font-sans); text-transform: uppercase; cursor: pointer; }
</style>

<script>
  const WORDS = ['BOOKS', 'IDEAS', 'PAPER', 'LOGIC', 'PIXEL', 'SPACE', 'CODES', 'STUDY', 'WRITE', 'LEARN'];
  const gridEl = document.getElementById('grid');
  const kbEl = document.getElementById('keyboard');
  const attemptEl = document.getElementById('attempt');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let target = '';
  let guesses = [];
  let currentGuess = '';
  let gameActive = false;

  function initGame() {
    target = WORDS[Math.floor(Math.random() * WORDS.length)].toUpperCase();
    guesses = [];
    currentGuess = '';
    attemptEl.textContent = '1';
    render();
    renderKeyboard();
  }

  function render() {
    gridEl.innerHTML = '';
    for (let i = 0; i < 6; i++) {
        const row = document.createElement('div');
        row.className = 'wordle-row';
        const word = guesses[i] || (i === guesses.length ? currentGuess : '');
        for (let j = 0; j < 5; j++) {
            const tile = document.createElement('div');
            tile.className = 'tile';
            const char = word[j] || '';
            tile.textContent = char;
            if (char) tile.classList.add('filled');
            if (i < guesses.length) {
                const status = checkChar(char, j);
                tile.classList.add(status);
            }
            row.appendChild(tile);
        }
        gridEl.appendChild(row);
    }
  }

  function checkChar(char, pos) {
    if (target[pos] === char) return 'correct';
    if (target.includes(char)) return 'present';
    return 'absent';
  }

  function renderKeyboard() {
    kbEl.innerHTML = '';
    const layout = [
        'QWERTYUIOP',
        'ASDFGHJKL',
        ['ENTER', ...'ZXCVBNM', 'DEL']
    ];
    layout.forEach(row => {
        const div = document.createElement('div');
        div.className = 'kb-row';
        const keys = typeof row === 'string' ? row.split('') : row;
        keys.forEach(key => {
            const btn = document.createElement('div');
            btn.className = 'key';
            if (key.length > 1) btn.classList.add('wide');
            btn.textContent = key;
            
            // Stats
            let status = '';
            guesses.forEach(g => {
                g.split('').forEach((c, idx) => {
                    if (c === key) {
                        const s = checkChar(c, idx);
                        if (s === 'correct') status = 'correct';
                        else if (s === 'present' && status !== 'correct') status = 'present';
                        else if (s === 'absent' && !status) status = 'absent';
                    }
                });
            });
            if (status) btn.classList.add(status);

            btn.addEventListener('click', () => handleInput(key));
            div.appendChild(btn);
        });
        kbEl.appendChild(div);
    });
  }

  function handleInput(key) {
    if (!gameActive) return;
    if (key === 'ENTER') {
        if (currentGuess.length === 5) {
            guesses.push(currentGuess);
            if (currentGuess === target) return endGame(true);
            if (guesses.length === 6) return endGame(false);
            currentGuess = '';
            attemptEl.textContent = String(guesses.length + 1);
        }
    } else if (key === 'DEL') {
        currentGuess = currentGuess.slice(0, -1);
    } else if (currentGuess.length < 5 && /^[A-Z]$/.test(key)) {
        currentGuess += key;
    }
    render();
    renderKeyboard();
  }

  function startGame() {
    overlay.classList.add('hidden');
    gameActive = true;
    initGame();
  }

  function endGame(win) {
    gameActive = false;
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = win ? "Genius!" : "The Word Was";
    document.getElementById('overlay-sub').textContent = win ? `Solved in ${guesses.length} attempts.` : `${target}`;
    startBtn.textContent = 'Play Again';
  }

  window.addEventListener('keydown', e => {
      let k = e.key.toUpperCase();
      if (k === 'ENTER') handleInput('ENTER');
      if (k === 'BACKSPACE') handleInput('DEL');
      if (/^[A-Z]$/.test(k)) handleInput(k);
  });

  startBtn.addEventListener('click', startGame);
</script>
