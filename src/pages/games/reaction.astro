---
import Base from '../../layouts/Base.astro';
---

<Base title="Reaction Test">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Reaction Test</h1>
      <div class="score-wrap">Round: <span id="round">1</span>/5</div>
    </div>
  </div>

  <div class="game-wrap" id="click-area">
    <div id="status-text" class="status-msg">Tap to start</div>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="result-title" class="overlay-title">Ready?</div>
        <div id="result-sub" class="overlay-sub">Wait for green, then tap as fast as you can.</div>
        <button id="start-btn" class="start-btn">Start Test</button>
      </div>
    </div>
  </div>

  <div class="hint">Wait for green · Don't tap early</div>
</Base>

<style>
  .game-header {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.75rem;
  }
  .back {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--ink-light);
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .game-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .game-title-row h1 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-style: italic;
    font-weight: 400;
  }
  .score-wrap {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--ink-light);
  }
  #round {
    color: var(--accent);
    font-weight: 500;
  }
  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 540px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.1s;
    user-select: none;
  }
  .game-wrap.waiting { background: #d4c9b4; }
  .game-wrap.ready { background: #4a6b4a; }
  .game-wrap.early { background: #8b3a2a; }

  .status-msg {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-style: italic;
    color: var(--ink);
    text-align: center;
    pointer-events: none;
  }
  :root.dark .status-msg { color: #f2ede4; }
  .ready .status-msg, .early .status-msg { color: white; }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
  .hint { font-family: var(--font-sans); font-size: 0.65rem; color: var(--ink-light); text-align: center; margin-top: 1.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
</style>

  const clickArea = document.getElementById('click-area');
  const statusText = document.getElementById('status-text');
  const roundEl = document.getElementById('round');
  const overlay = document.getElementById('overlay');
  const resultTitle = document.getElementById('result-title');
  const resultSub = document.getElementById('result-sub');
  const startBtn = document.getElementById('start-btn');

  let state = 'waiting'; // waiting, testing, counting
  let round = 0;
  let startTime = 0;
  let timer = null;
  let results = [];
  
  let bestAverage = parseInt(localStorage.getItem('reaction-best')) || Infinity;

  function startRound() {
    state = 'counting';
    clickArea.className = 'game-wrap waiting';
    statusText.textContent = 'Wait for green...';
    
    const delay = 1500 + Math.random() * 3500;
    timer = setTimeout(() => {
      state = 'testing';
      clickArea.className = 'game-wrap ready';
      statusText.textContent = 'TAP!';
      startTime = performance.now();
    }, delay);
  }

  function handleInteraction() {
    if (state === 'counting') {
      clearTimeout(timer);
      state = 'waiting';
      clickArea.className = 'game-wrap early';
      statusText.textContent = 'Too early!';
      setTimeout(startRound, 1000);
    } else if (state === 'testing') {
      const reaction = Math.round(performance.now() - startTime);
      results.push(reaction);
      
      clickArea.className = 'game-wrap'; // reset bg immediately
      statusText.textContent = `${reaction}ms`;
      state = 'waiting';
      
      round++;
      
      if (round < 5) {
        roundEl.textContent = String(round + 1);
        setTimeout(startRound, 800);
      } else {
        setTimeout(endGame, 800);
      }
    }
  }

  function endGame() {
    state = 'waiting';
    const avg = Math.round(results.reduce((a, b) => a + b) / results.length);
    
    let bestMsg = '';
    if (avg < bestAverage) {
        bestAverage = avg;
        localStorage.setItem('reaction-best', bestAverage);
        bestMsg = `<br/><span style="color:var(--accent);">New Best!</span>`;
    } else if (bestAverage !== Infinity) {
        bestMsg = `<br/>Best: ${bestAverage}ms`;
    }
    
    overlay.classList.remove('hidden');
    resultTitle.textContent = `${avg}ms`;
    
    let rank = "Impressive!";
    if (avg > 300) rank = "Keep practicing!";
    else if (avg < 200) rank = "God-like reflexes!";
    
    resultSub.innerHTML = `Average reaction time over 5 rounds. ${rank}${bestMsg}`;
    startBtn.textContent = 'Try again';
  }

  // Inject best score into header
  if (bestAverage !== Infinity) {
      const bestDiv = document.createElement('div');
      bestDiv.style.fontSize = '0.75rem';
      bestDiv.style.color = 'var(--ink-light)';
      bestDiv.textContent = `Best: ${bestAverage}ms`;
      document.querySelector('.score-wrap').appendChild(bestDiv);
  }

  startBtn.addEventListener('click', () => {
    round = 0;
    results = [];
    roundEl.textContent = '1';
    overlay.classList.add('hidden');
    startRound();
  });

  clickArea.addEventListener('mousedown', handleInteraction);
  clickArea.addEventListener('touchstart', (e) => {
    e.preventDefault();
    handleInteraction();
  }, { passive: false });
