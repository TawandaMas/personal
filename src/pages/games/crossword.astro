---
import Base from '../../layouts/Base.astro';
---

<Base title="Crossword">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Crossword</h1>
      <div class="score-wrap">Solve the mini puzzle.</div>
    </div>
  </div>

  <div class="game-wrap">
    <div class="crossword-container">
        <div id="grid" class="crossword-grid"></div>
        <div class="clues-pane">
            <div class="clue-section">
                <h3>Across</h3>
                <ul id="across-clues"></ul>
            </div>
            <div class="clue-section">
                <h3>Down</h3>
                <ul id="down-clues"></ul>
            </div>
        </div>
    </div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Mini Crossword</div>
        <div id="overlay-sub" class="overlay-sub">Fill in the 5x5 grid. Tap a square to select.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Type letters to fill squares</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    padding: 1.5rem;
  }

  .crossword-container { display: flex; gap: 2rem; }
  @media (max-width: 600px) { .crossword-container { flex-direction: column; } }

  .crossword-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(5, 1fr);
    gap: 1px;
    background: var(--rule);
    width: 100%;
    max-width: 300px;
    aspect-ratio: 1;
  }

  .square {
    background: var(--paper);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
  }
  .square.black { background: var(--ink); cursor: default; }
  .square.selected { background: rgba(139, 58, 42, 0.1); outline: 2px solid var(--accent); z-index: 5; }
  .square .num {
    position: absolute;
    top: 2px; left: 2px;
    font-size: 0.6rem;
    color: var(--ink-light);
  }

  .clues-pane { flex: 1; display: flex; flex-direction: column; gap: 1rem; }
  .clue-section h3 { font-family: var(--font-serif); font-size: 0.9rem; font-style: italic; border-bottom: 1px solid var(--rule); margin-bottom: 0.5rem; }
  .clue-section ul { list-style: none; font-family: var(--font-sans); font-size: 0.8rem; line-height: 1.4; color: var(--ink-mid); }
  .clue-section li { margin-bottom: 0.4rem; }

  .overlay {
    position: absolute; inset: 0; background: rgba(242, 237, 228, 0.95); display: flex; align-items: center; justify-content: center; z-index: 10;
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { margin-top: 1.5rem; padding: 0.6rem 1.5rem; background: transparent; border: 1.5px solid var(--accent); color: var(--accent); font-family: var(--font-sans); text-transform: uppercase; cursor: pointer; }
</style>

<script>
  const PUZZLE = {
      grid: [
          'A','S','T','R','O',
          'S','O','L','A','R',
          'T','O','O','L','S',
          'R','A','D','I','O',
          'O','R','B','I','T'
      ],
      nums: [1,2,3,4,5,6,0,0,0,0,11,0,0,0,0,16,0,0,0,0,21,0,0,0,0],
      clues: {
          across: ['1. Personal space theme', '6. Of the sun', '11. Items in a kit', '16. Wireless signal', '21. Circular path'],
          down: ['1. Celestial body', '2. Ground soil', '3. Also', '4. High temp', '5. Sphere shape']
      }
  };

  const gridEl = document.getElementById('grid');
  const acrossEl = document.getElementById('across-clues');
  const downEl = document.getElementById('down-clues');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let activeIdx = 0;

  function initBoard() {
    gridEl.innerHTML = '';
    PUZZLE.grid.forEach((char, i) => {
        const sq = document.createElement('div');
        sq.className = 'square';
        if (PUZZLE.nums[i] > 0) {
            const num = document.createElement('span');
            num.className = 'num';
            num.textContent = PUZZLE.nums[i];
            sq.appendChild(num);
        }
        sq.addEventListener('click', () => {
            document.querySelectorAll('.square').forEach(s => s.classList.remove('selected'));
            sq.classList.add('selected');
            activeIdx = i;
        });
        gridEl.appendChild(sq);
    });
    
    acrossEl.innerHTML = PUZZLE.clues.across.map(c => `<li>${c}</li>`).join('');
    downEl.innerHTML = PUZZLE.clues.down.map(c => `<li>${c}</li>`).join('');
  }

  window.addEventListener('keydown', e => {
      const char = e.key.toUpperCase();
      if (/^[A-Z]$/.test(char)) {
          const sq = gridEl.children[activeIdx];
          sq.childNodes[1] ? (sq.childNodes[1].textContent = char) : (sq.append(char));
          // Check win logic would go here
      }
  });

  startBtn.addEventListener('click', () => { overlay.classList.add('hidden'); initBoard(); });
</script>
