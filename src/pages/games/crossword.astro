---
import Base from '../../layouts/Base.astro';
---

<Base title="Crossword">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Crossword</h1>
      <div class="score-wrap" id="status-text">Solve the mini puzzle.</div>
    </div>
  </div>

  <div class="game-wrap">
    <div class="crossword-container">
      <div id="grid" class="crossword-grid"></div>
      <div class="clues-pane">
        <div class="clue-section">
          <h3>Across</h3>
          <ul id="across-clues"></ul>
        </div>
        <div class="clue-section">
          <h3>Down</h3>
          <ul id="down-clues"></ul>
        </div>
      </div>
    </div>
    <!-- Mobile keyboard -->
    <div class="mobile-keys" id="mobile-keys"></div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Mini Crossword</div>
        <div id="overlay-sub" class="overlay-sub">Fill in the 5×5 grid. Tap a square then type.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap a square · Use keyboard or on-screen keys</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #status-text { font-family: var(--font-sans); font-size: 0.8rem; color: var(--ink-light); }

  .game-wrap {
    position: relative; width: 100%; max-width: 600px; margin: 0 auto;
    border: 1.5px solid var(--rule); background: var(--paper-dark); padding: 1.5rem;
  }

  .crossword-container { display: flex; gap: 2rem; align-items: flex-start; }
  @media (max-width: 560px) { .crossword-container { flex-direction: column; } }

  .crossword-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    background: var(--rule);
    width: 100%;
    max-width: 260px;
    flex-shrink: 0;
    aspect-ratio: 1;
  }

  .square {
    background: var(--paper);
    position: relative;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-sans);
    font-size: 1.1rem; font-weight: 700; text-transform: uppercase;
    cursor: pointer; user-select: none;
    min-height: 0;
    aspect-ratio: 1;
    transition: background 0.1s;
  }
  .square.black { background: var(--ink); cursor: default; }
  .square.selected { background: rgba(139,58,42,0.15); outline: 2px solid var(--accent); z-index: 5; }
  .square.correct { color: #4a6b4a; }
  .square.wrong { color: #b34a3b; }
  .square .num {
    position: absolute; top: 1px; left: 2px;
    font-size: 0.5rem; color: var(--ink-light); font-weight: 400;
    line-height: 1;
  }
  .square .letter { font-size: 1.1rem; line-height: 1; }

  .clues-pane { flex: 1; display: flex; flex-direction: column; gap: 1rem; min-width: 0; }
  .clue-section h3 { font-family: var(--font-serif); font-size: 0.85rem; font-style: italic; border-bottom: 1px solid var(--rule); margin-bottom: 0.4rem; padding-bottom: 0.25rem; }
  .clue-section ul { list-style: none; font-family: var(--font-sans); font-size: 0.75rem; line-height: 1.5; color: var(--ink-mid); }
  .clue-section li { margin-bottom: 0.3rem; cursor: pointer; }
  .clue-section li:hover { color: var(--accent); }
  .clue-section li.active { color: var(--accent); font-weight: 600; }

  .mobile-keys {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: 4px;
    margin-top: 1rem;
  }
  .key-btn {
    background: var(--paper); border: 1px solid var(--rule);
    font-family: var(--font-sans); font-size: 0.75rem; font-weight: 600;
    padding: 0.4rem 0; cursor: pointer; border-radius: 4px;
    text-align: center; transition: all 0.1s;
  }
  .key-btn:active { background: var(--accent); color: white; }
  .key-btn.bksp { font-size: 0.65rem; color: var(--ink-light); }

  .overlay {
    position: absolute; inset: 0; background: var(--paper); opacity: 0.98;
    display: flex; align-items: center; justify-content: center; z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn {
    margin-top: 1.5rem; padding: 0.75rem 2rem;
    background: var(--ink); color: var(--paper); border: none; border-radius: 2rem;
    font-family: var(--font-sans); font-weight: 600; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
  .hint { font-family: var(--font-sans); font-size: 0.65rem; color: var(--ink-light); text-align: center; margin-top: 1.5rem; text-transform: uppercase; }
</style>

<script>
  let PUZZLE = {
    size: 5,
    solution: [],
    numbers: [],
    clues: { across: [], down: [] }
  };

  const gridEl = document.getElementById('grid');
  const acrossEl = document.getElementById('across-clues');
  const downEl = document.getElementById('down-clues');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');
  const statusText = document.getElementById('status-text');
  const mobileKeysEl = document.getElementById('mobile-keys');

  let userGrid = [];
  let activeIdx = -1;

  function buildMobileKeys() {
    const rows = ['ABCDEFGHI', 'JKLMNOPQR', 'STUVWXYZ⌫'];
    mobileKeysEl.style.gridTemplateColumns = `repeat(9, 1fr)`;
    mobileKeysEl.innerHTML = '';
    rows.forEach(row => {
      [...row].forEach(ch => {
        const btn = document.createElement('button');
        btn.className = 'key-btn' + (ch === '⌫' ? ' bksp' : '');
        btn.textContent = ch;
        btn.addEventListener('click', e => { e.preventDefault(); handleKey(ch === '⌫' ? 'Backspace' : ch); });
        mobileKeysEl.appendChild(btn);
      });
    });
  }

  async function generatePuzzle() {
      // Very basic procedural 5x5 generation: We just generate 5 separate horizontal words for now to ensure validity
      // A true crossing generation requires backtracking algorithms that are too heavy for synchronous client-side without locking the UI.
      // So instead, we do a "Word Stack" style mini crossword where down clues are essentially random anagram columns,
      // but to keep it simple and fun, we just populate 5 random valid 5-letters 
      
      gridEl.innerHTML = '<div style="color:var(--ink-light); grid-column: span 5; text-align: center; margin-top: 50%;">Thinking...</div>';
      acrossEl.innerHTML = '<li>Fetching definitions...</li>';
      downEl.innerHTML = '<li>Down clues NA</li>';

      let words = [];
      let definitions = [];

      try {
          const res = await fetch(`https://api.datamuse.com/words?sp=?????&md=df&max=50`);
          const data = await res.json();
          
          let candidates = data.filter(w => !w.word.includes(' ') && !w.word.includes('-') && w.defs && w.defs.length > 0);
          candidates.sort(() => Math.random() - 0.5);
          
          for(let i=0; i<5; i++) {
              if (candidates[i]) {
                  words.push(candidates[i].word.toUpperCase());
                  // Extract just the definition part before any tabs or massive sentences
                  let def = candidates[i].defs[0].split('\t')[1] || candidates[i].defs[0];
                  // truncate def
                  if (def.length > 60) def = def.substring(0, 57) + '...';
                  definitions.push(def);
              }
          }
      } catch (e) {
          console.error(e);
      }

      // Fallback if fetch fails or fewer than 5 words found
      if (words.length < 5) {
          words = ['PAPER', 'ARENA', 'LEAPS', 'MATES', 'STARS'];
          definitions = ['Writing material', 'Gladiatorial venue', 'Jumps', 'Companions', 'Celestial lights'];
      }

      // Build PUZZLE obj
      PUZZLE.solution = words.join('').split('');
      PUZZLE.numbers = [1,0,0,0,0, 2,0,0,0,0, 3,0,0,0,0, 4,0,0,0,0, 5,0,0,0,0];
      
      PUZZLE.clues.across = definitions.map((d, i) => `${i+1}. ${d}`);
      PUZZLE.clues.down = ['(Read across to solve columns)']; // Down clues omitted for procedural stack mode

      initBoard();
  }

  function initBoard() {
    userGrid = Array(25).fill('');
    gridEl.innerHTML = '';
    
    PUZZLE.solution.forEach((_, i) => {
      const sq = document.createElement('div');
      sq.className = 'square';
      if (PUZZLE.numbers[i] > 0) {
        const num = document.createElement('span');
        num.className = 'num';
        num.textContent = PUZZLE.numbers[i];
        sq.appendChild(num);
      }
      const letter = document.createElement('span');
      letter.className = 'letter';
      sq.appendChild(letter);
      sq.addEventListener('click', () => selectSquare(i));
      gridEl.appendChild(sq);
    });

    acrossEl.innerHTML = PUZZLE.clues.across.map((c, i) => `<li data-dir="across" data-i="${i}">${c}</li>`).join('');
    downEl.innerHTML = PUZZLE.clues.down.map((c, i) => `<li data-dir="down" data-i="${i}">${c}</li>`).join('');

    document.querySelectorAll('.clue-section li').forEach(li => {
      li.addEventListener('click', () => {
        document.querySelectorAll('.clue-section li').forEach(l => l.classList.remove('active'));
        li.classList.add('active');
        // Auto select the first square of that row
        const rowIdx = parseInt(li.dataset.i);
        if (!isNaN(rowIdx) && li.dataset.dir === 'across') {
             selectSquare(rowIdx * 5);
        }
      });
    });
  }

  function selectSquare(idx) {
    document.querySelectorAll('.square').forEach(s => s.classList.remove('selected'));
    activeIdx = idx;
    gridEl.children[idx].classList.add('selected');
  }

  function handleKey(key) {
    if (activeIdx < 0) return;
    const sq = gridEl.children[activeIdx];
    const letterEl = sq.querySelector('.letter');
    if (key === 'Backspace') {
      userGrid[activeIdx] = '';
      letterEl.textContent = '';
      sq.classList.remove('correct', 'wrong');
      // Move back
      if (activeIdx > 0) selectSquare(activeIdx - 1);
    } else if (/^[A-Za-z]$/.test(key)) {
      const ch = key.toUpperCase();
      userGrid[activeIdx] = ch;
      letterEl.textContent = ch;
      if (ch === PUZZLE.solution[activeIdx]) {
        sq.classList.add('correct'); sq.classList.remove('wrong');
      } else {
        sq.classList.add('wrong'); sq.classList.remove('correct');
      }
      // Auto-advance
      if (activeIdx < 24) selectSquare(activeIdx + 1);
      checkWin();
    }
  }

  function checkWin() {
    const allCorrect = userGrid.every((ch, i) => ch === PUZZLE.solution[i]);
    if (allCorrect) {
      statusText.textContent = '🎉 Solved!';
      overlay.classList.remove('hidden');
      document.getElementById('overlay-title').textContent = 'Solved!';
      document.getElementById('overlay-sub').textContent = 'All words correct. Excellent work!';
      startBtn.textContent = 'Play Again';
    }
  }

  window.addEventListener('keydown', e => {
    if (activeIdx >= 0 && /^[A-Za-z]$/.test(e.key)) { e.preventDefault(); handleKey(e.key); }
    if (e.key === 'Backspace') { e.preventDefault(); handleKey('Backspace'); }
    if (e.key === 'ArrowRight' && activeIdx < 24) selectSquare(activeIdx + 1);
    if (e.key === 'ArrowLeft' && activeIdx > 0) selectSquare(activeIdx - 1);
    if (e.key === 'ArrowDown' && activeIdx + 5 < 25) selectSquare(activeIdx + 5);
    if (e.key === 'ArrowUp' && activeIdx - 5 >= 0) selectSquare(activeIdx - 5);
  });

  startBtn.addEventListener('click', () => {
    overlay.classList.add('hidden');
    statusText.textContent = 'Solve the mini puzzle.';
    buildMobileKeys();
    generatePuzzle();
  });
</script>
