---
import Base from '../../layouts/Base.astro';
---

<Base title="Sliding Puzzle">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Sliding Puzzle</h1>
      <div class="score-wrap">Moves: <span id="moves">0</span></div>
    </div>
  </div>

  <div class="game-wrap">
    <div id="grid" class="slide-grid"></div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">15 Puzzle</div>
        <div id="overlay-sub" class="overlay-sub">Slide the tiles to put them in numerical order from 1 to 15.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap a tile adjacent to the empty slot</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #moves { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
  }

  .slide-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(4, 1fr);
    gap: 2px;
    background: var(--rule);
    width: 100%;
    height: 100%;
  }

  .tile {
    background: var(--paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
    transition: background 0.1s;
  }
  .tile:hover { background: var(--paper-dark); }
  .tile.empty { background: transparent; cursor: default; pointer-events: none; }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

  const gridEl = document.getElementById('grid');
  const movesEl = document.getElementById('moves');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let tiles = [];
  let moves = 0;
  let SIZE = 4;
  let currentLevel = '4x4 (Normal)';

  function setSize(s, lvlName) {
      SIZE = s;
      currentLevel = lvlName;
      gridEl.style.gridTemplateColumns = `repeat(${SIZE}, 1fr)`;
      gridEl.style.gridTemplateRows = `repeat(${SIZE}, 1fr)`;
      initBoard();
  }

  function initBoard() {
    tiles = Array.from({length: SIZE * SIZE}, (_, i) => i === SIZE * SIZE - 1 ? null : i + 1);
    shuffle();
    moves = 0;
    movesEl.textContent = '0';
    render();
  }

  function shuffle() {
    // Solvable shuffle (simulate random moves from win state)
    let emptyIdx = SIZE * SIZE - 1;
    const shuffles = SIZE === 3 ? 100 : (SIZE === 4 ? 200 : 350);
    for (let i = 0; i < shuffles; i++) {
        const neighbors = getNeighbors(emptyIdx);
        const nextIdx = neighbors[Math.floor(Math.random() * neighbors.length)];
        [tiles[emptyIdx], tiles[nextIdx]] = [tiles[nextIdx], tiles[emptyIdx]];
        emptyIdx = nextIdx;
    }
  }

  function getNeighbors(idx) {
    const r = Math.floor(idx / SIZE);
    const c = idx % SIZE;
    const neighbors = [];
    if (r > 0) neighbors.push(idx - SIZE);
    if (r < SIZE - 1) neighbors.push(idx + SIZE);
    if (c > 0) neighbors.push(idx - 1);
    if (c < SIZE - 1) neighbors.push(idx + 1);
    return neighbors;
  }

  function render() {
    gridEl.innerHTML = '';
    tiles.forEach((val, idx) => {
        const tile = document.createElement('div');
        tile.className = 'tile';
        if (SIZE === 5) tile.style.fontSize = '1.2rem';
        if (SIZE === 3) tile.style.fontSize = '2rem';
        
        if (val === null) {
            tile.classList.add('empty');
        } else {
            tile.textContent = String(val);
            tile.addEventListener('click', () => move(idx));
        }
        gridEl.appendChild(tile);
    });
  }

  function move(idx) {
    const emptyIdx = tiles.indexOf(null);
    const neighbors = getNeighbors(emptyIdx);
    if (neighbors.includes(idx)) {
        [tiles[emptyIdx], tiles[idx]] = [tiles[idx], tiles[emptyIdx]];
        moves++;
        movesEl.textContent = String(moves);
        render();
        if (checkWin()) endGame();
    }
  }

  function checkWin() {
    for (let i = 0; i < tiles.length - 1; i++) {
        if (tiles[i] !== i + 1) return false;
    }
    return true;
  }

  function endGame() {
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = "Solved!";
    document.getElementById('overlay-sub').textContent = `Magnificent. You did it in ${moves} moves.`;
    startBtn.textContent = 'Play Again';
    
    // Save best moves
    const key = `slide-${SIZE}x${SIZE}-best`;
    const best = parseInt(localStorage.getItem(key) || 999999);
    if (moves < best) {
        localStorage.setItem(key, moves);
        document.getElementById('overlay-sub').textContent += ` A NEW RECORD!`;
    }
  }

  // Inject Difficulty Buttons into overlay
  const overlayContent = document.querySelector('.overlay-content');
  const diffRow = document.createElement('div');
  diffRow.style.cssText = "display:flex; justify-content:center; gap: 0.5rem; margin-top: 1.5rem;";
  
  [
    {n: 3, label: '3x3 (Easy)'},
    {n: 4, label: '4x4 (Normal)'},
    {n: 5, label: '5x5 (Hard)'}
  ].forEach(lvl => {
      const btn = document.createElement('button');
      btn.textContent = lvl.label;
      btn.className = 'key-btn';
      btn.style.cssText = "background:var(--paper); border:1.5px solid var(--rule); padding:0.4rem 0.8rem; border-radius:1rem; cursor:pointer; font-family:var(--font-sans); font-size:0.8rem; transition:all 0.2s;";
      btn.onclick = (e) => {
          e.stopPropagation();
          document.querySelectorAll('.diff-btn').forEach(b => { b.style.background = 'var(--paper)'; b.style.color = 'var(--ink)'; });
          btn.style.background = 'var(--ink)';
          btn.style.color = 'white';
          btn.classList.add('diff-btn');
          SIZE = lvl.n;
          currentLevel = lvl.label;
      };
      if (lvl.n === 4) btn.onclick({stopPropagation:()=>{}}); // pre-select
      diffRow.appendChild(btn);
  });
  
  overlayContent.insertBefore(diffRow, startBtn);

  startBtn.addEventListener('click', () => {
      overlay.classList.add('hidden');
      setSize(SIZE, currentLevel);
  });
</script>
