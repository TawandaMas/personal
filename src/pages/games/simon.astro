---
import Base from '../../layouts/Base.astro';
---

<Base title="Simon Says">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Simon Says</h1>
      <div class="score-wrap">Round: <span id="score">0</span></div>
    </div>
  </div>

  <div class="game-wrap">
    <div class="simon-grid">
        <div class="simon-btn" data-color="0" style="background: #8b3a2a;"></div>
        <div class="simon-btn" data-color="1" style="background: #4a6b4a;"></div>
        <div class="simon-btn" data-color="2" style="background: #4a6bb3;"></div>
        <div class="simon-btn" data-color="3" style="background: #c8bca8;"></div>
    </div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Simon Says</div>
        <div id="overlay-sub" class="overlay-sub">Watch the sequence, then repeat it back.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Watch carefully · Pattern grows longer each round</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .simon-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
    width: 100%;
    height: 100%;
  }

  .simon-btn {
    border-radius: 12px;
    cursor: pointer;
    opacity: 0.3;
    transition: opacity 0.2s, transform 0.1s;
    border: 2px solid rgba(0,0,0,0.1);
  }
  .simon-btn.active { opacity: 1; transform: scale(1.05); box-shadow: 0 0 20px rgba(255,255,255,0.4); }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

  const btns = document.querySelectorAll('.simon-btn');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  const startBtn = document.getElementById('start-btn');

  let sequence = [];
  let userSequence = [];
  let gameActive = false;
  let showingSequence = false;
  
  let bestScore = parseInt(localStorage.getItem('simon-best') || 0);

  function flash(btn, duration = 400) {
    // Play sound here if adding audio later
    btn.classList.add('active');
    setTimeout(() => btn.classList.remove('active'), duration);
  }

  async function showSequence() {
    showingSequence = true;
    
    // Dynamic speed based on round
    const baseDelay = 600;
    const speedMultiplier = Math.max(0.4, 1 - (sequence.length * 0.03));
    const delay = baseDelay * speedMultiplier;
    const flashDur = 400 * speedMultiplier;

    for (let colorIdx of sequence) {
        await new Promise(r => setTimeout(r, delay));
        flash(btns[colorIdx], flashDur);
    }
    showingSequence = false;
  }

  function nextRound() {
    sequence.push(Math.floor(Math.random() * 4));
    userSequence = [];
    scoreEl.textContent = String(sequence.length);
    setTimeout(showSequence, 500); // Small pause before starting next sequence
  }

  function handleTap(e, idx) {
    if (!gameActive || showingSequence) return;
    
    // Simple tactile feedback simulation (since no audio yet)
    flash(btns[idx], 200);
    userSequence.push(idx);

    if (userSequence.length > 0 && userSequence[userSequence.length - 1] !== sequence[userSequence.length - 1]) {
        return endGame();
    }

    if (userSequence.length === sequence.length) {
        setTimeout(nextRound, 800);
    }
  }

  function startGame() {
    sequence = [];
    gameActive = true;
    overlay.classList.add('hidden');
    nextRound();
  }

  function endGame() {
    gameActive = false;
    
    let bestMsg = '';
    const roundReached = sequence.length;
    
    if (roundReached > bestScore) {
        bestScore = roundReached;
        localStorage.setItem('simon-best', bestScore);
        bestMsg = `<br/><span style="color:var(--accent);">New Best!</span>`;
    } else {
        bestMsg = `<br/>Best: ${bestScore}`;
    }
    
    overlay.classList.remove('hidden');
    overlayTitle.textContent = `Round: ${roundReached}`;
    overlaySub.innerHTML = "Don't blink! The sequence was getting tricky." + bestMsg;
    startBtn.textContent = 'Play Again';
  }

  // Inject best score into header
  if (bestScore > 0) {
      const bestDiv = document.createElement('div');
      bestDiv.style.fontSize = '0.75rem';
      bestDiv.style.color = 'var(--ink-light)';
      bestDiv.textContent = `Best: Round ${bestScore}`;
      document.querySelector('.score-wrap').appendChild(bestDiv);
  }

  btns.forEach((btn, i) => {
      // Use pointerdown for responsive tactile feel
      btn.addEventListener('pointerdown', (e) => {
          e.preventDefault(); // Prevent double firing from touch
          handleTap(e, i);
      });
  });
  
  startBtn.addEventListener('click', startGame);
