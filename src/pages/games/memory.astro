---
import Base from '../../layouts/Base.astro';
---

<Base title="Memory">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Memory</h1>
      <div class="score-wrap">Moves: <span id="moves">0</span> · Time: <span id="timer">0</span>s</div>
    </div>
  </div>

  <div class="game-wrap">
    <div id="grid" class="memory-grid"></div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Concentration</div>
        <div id="overlay-sub" class="overlay-sub">Find all 8 matching pairs.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap a card to flip it · Match symbols to clear</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  .score-wrap { font-family: var(--font-sans); font-size: 0.8rem; color: var(--ink-light); }
  #moves, #timer { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
  }

  .memory-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(4, 1fr);
    width: 100%;
    height: 100%;
    gap: 0.75rem;
    padding: 0.75rem;
  }

  .card {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
    perspective: 1000px;
  }

  .card.flipped { transform: rotateY(180deg); }
  .card.matched { cursor: default; transform: rotateY(180deg) scale(0.95); opacity: 0.6; }

  .card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    border-radius: 4px;
    border: 1px solid var(--rule);
    box-shadow: 1px 1px 3px rgba(0,0,0,0.05);
  }

  .card-back {
    background: var(--paper);
    background-image: 
      repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(139, 58, 42, 0.05) 10px, rgba(139, 58, 42, 0.05) 11px);
    z-index: 2;
    transform: rotateY(0deg);
  }

  .card-front {
    background: white;
    transform: rotateY(180deg);
    font-family: var(--font-serif);
    color: var(--accent);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

  const THEMES = {
      'Symbols': ['★', '♠', '♣', '♦', '♥', '☀', '☽', '⚓', '▲', '▼', '◀', '▶', '♻', '⚙', '♫', '⚡', '✿', '✂'],
      'Emoji': ['😀', '😂', '😎', '😍', '🤔', '🥶', '🤠', '👽', '👻', '🤖', '🎃', '💩', '🙉', '💥', '🍕', '🌮', '🍔', '🍟'],
      'Math': ['∑', 'π', '∞', '√', '∫', '∆', 'Ω', 'μ', 'θ', 'α', 'β', 'γ', 'λ', 'ρ', 'σ', 'φ', 'ψ', 'ω']
  };

  const grid = document.getElementById('grid');
  const movesEl = document.getElementById('moves');
  const timerEl = document.getElementById('timer');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  const startBtn = document.getElementById('start-btn');

  let cards = [];
  let flippedCards = [];
  let moves = 0;
  let matches = 0;
  let gameActive = false;
  let startTime = 0;
  let timerInterval = null;
  
  let currentTheme = 'Symbols';
  let gridSize = 4; // 4x4 or 6x6

  function initGame() {
    grid.innerHTML = '';
    grid.style.gridTemplateColumns = `repeat(${gridSize}, 1fr)`;
    grid.style.gridTemplateRows = `repeat(${gridSize}, 1fr)`;
    
    // Decrease font size for 6x6 so it fits
    const fontSize = gridSize === 6 ? '1.25rem' : '2rem';

    const numPairs = (gridSize * gridSize) / 2;
    const symbolsToUse = THEMES[currentTheme].slice(0, numPairs);
    const deck = [...symbolsToUse, ...symbolsToUse];
    
    // Shuffle
    for (let i = deck.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [deck[i], deck[j]] = [deck[j], deck[i]];
    }

    deck.forEach((symbol, i) => {
      const card = document.createElement('div');
      card.className = 'card';
      card.innerHTML = `
        <div class="card-face card-back"></div>
        <div class="card-face card-front" style="font-size: ${fontSize}">${symbol}</div>
      `;
      card.addEventListener('click', () => flipCard(card, symbol));
      grid.appendChild(card);
    });
  }

  function flipCard(card, symbol) {
    if (!gameActive || card.classList.contains('flipped') || flippedCards.length === 2) return;

    card.classList.add('flipped');
    flippedCards.push({ card, symbol });

    if (flippedCards.length === 2) {
      moves++;
      movesEl.textContent = String(moves);
      checkMatch();
    }
  }

  function checkMatch() {
    const [c1, c2] = flippedCards;
    if (c1.symbol === c2.symbol) {
      c1.card.classList.add('matched');
      c2.card.classList.add('matched');
      matches++;
      flippedCards = [];
      if (matches === (gridSize * gridSize) / 2) endGame();
    } else {
      setTimeout(() => {
        c1.card.classList.remove('flipped');
        c2.card.classList.remove('flipped');
        flippedCards = [];
      }, 800);
    }
  }

  function startGame() {
    moves = 0;
    matches = 0;
    flippedCards = [];
    gameActive = true;
    movesEl.textContent = '0';
    timerEl.textContent = '0';
    overlay.classList.add('hidden');
    initGame();
    
    startTime = Date.now();
    if (timerInterval) clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      timerEl.textContent = String(Math.floor((Date.now() - startTime) / 1000));
    }, 1000);
  }

  function endGame() {
    gameActive = false;
    clearInterval(timerInterval);
    const finalTime = timerEl.textContent;
    overlay.classList.remove('hidden');
    overlayTitle.textContent = "Matched!";
    overlaySub.textContent = `Completed in ${moves} moves and ${finalTime} seconds.`;
    startBtn.textContent = 'Play Again';
    
    const key = `memory-${gridSize}x${gridSize}-best`;
    const bestMoves = parseInt(localStorage.getItem(key) || 9999);
    if (moves < bestMoves) {
        localStorage.setItem(key, moves);
        overlaySub.textContent += ` New Best!`;
    }
  }

  // UI Setup for Options
  const overlayContent = document.querySelector('.overlay-content');
  
  // Theme Builder
  const themeRow = document.createElement('div');
  themeRow.style.cssText = "display:flex; justify-content:center; gap: 0.5rem; margin-top: 1.5rem; margin-bottom: 0.5rem;";
  Object.keys(THEMES).forEach(theme => {
      const btn = document.createElement('button');
      btn.textContent = theme;
      btn.className = 'theme-btn';
      btn.style.cssText = "background:var(--paper); border:1.5px solid var(--rule); padding:0.4rem 0.8rem; border-radius:1rem; cursor:pointer; font-family:var(--font-sans); font-size:0.8rem; transition:all 0.2s;";
      btn.onclick = (e) => {
          e.stopPropagation();
          document.querySelectorAll('.theme-btn').forEach(b => { b.style.background = 'var(--paper)'; b.style.color = 'var(--ink)'; });
          btn.style.background = 'var(--ink)';
          btn.style.color = 'white';
          currentTheme = theme;
      };
      if (theme === 'Symbols') btn.onclick({stopPropagation:()=>{}}); // pre-select
      themeRow.appendChild(btn);
  });
  
  // Size Builder
  const sizeRow = document.createElement('div');
  sizeRow.style.cssText = "display:flex; justify-content:center; gap: 0.5rem; margin-bottom: 1.5rem;";
  [4, 6].forEach(size => {
      const btn = document.createElement('button');
      btn.textContent = `${size}x${size}`;
      btn.className = 'size-btn';
      btn.style.cssText = "background:var(--paper); border:1.5px solid var(--rule); padding:0.4rem 0.8rem; border-radius:1rem; cursor:pointer; font-family:var(--font-sans); font-size:0.8rem; transition:all 0.2s;";
      btn.onclick = (e) => {
          e.stopPropagation();
          document.querySelectorAll('.size-btn').forEach(b => { b.style.background = 'var(--paper)'; b.style.color = 'var(--ink)'; });
          btn.style.background = 'var(--ink)';
          btn.style.color = 'white';
          gridSize = size;
      };
      if (size === 4) btn.onclick({stopPropagation:()=>{}}); // pre-select
      sizeRow.appendChild(btn);
  });

  overlayContent.insertBefore(themeRow, startBtn);
  overlayContent.insertBefore(sizeRow, startBtn);

  startBtn.addEventListener('click', startGame);
  
  // Add best score display to header
  const best4 = localStorage.getItem('memory-4x4-best');
  const best6 = localStorage.getItem('memory-6x6-best');
  if (best4 || best6) {
      const hs = document.createElement('div');
      hs.style.fontSize = '0.75rem';
      hs.style.marginTop = '0.5rem';
      hs.style.color = 'var(--ink-light)';
      hs.innerHTML = `Best Moves: 4x4: <b>${best4||'-'}</b> | 6x6: <b>${best6||'-'}</b>`;
      document.querySelector('.score-wrap').appendChild(hs);
  }
</script>
