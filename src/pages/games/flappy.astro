---
import Base from '../../layouts/Base.astro';
---

<Base title="Flappy Bird">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Flappy Bird</h1>
      <div class="score-wrap">Score: <span id="score">0</span></div>
    </div>
  </div>

  <div class="game-wrap" id="game-wrap">
    <canvas id="flappy-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Flappy Bird</div>
        <div id="overlay-sub" class="overlay-sub">Tap to flap. Don't hit the pipes!</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap anywhere or press Space to fly</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative; width: 100%; max-width: 360px; margin: 0 auto;
    aspect-ratio: 0.6; border: 1.5px solid var(--rule);
    background: var(--paper-dark); overflow: hidden; touch-action: none;
    cursor: pointer;
  }

  #flappy-canvas { display: block; width: 100%; height: 100%; }

  .overlay {
    position: absolute; inset: 0; background: var(--paper); opacity: 0.98;
    display: flex; align-items: center; justify-content: center; z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn {
    margin-top: 1.5rem; padding: 0.75rem 2rem;
    background: var(--ink); color: var(--paper); border: none; border-radius: 2rem;
    font-family: var(--font-sans); font-weight: 600; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
  .hint { font-family: var(--font-sans); font-size: 0.65rem; color: var(--ink-light); text-align: center; margin-top: 1.5rem; text-transform: uppercase; }
</style>

  const canvas = document.getElementById('flappy-canvas');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  const startBtn = document.getElementById('start-btn');

  let bird, pipes, score, gameLoop, running = false;
  let GRAVITY, FLAP, PIPE_W, GAP, PIPE_SPEED;
  
  let bestScore = parseInt(localStorage.getItem('flappy-best') || 0);

  // Day/Night colors based on score
  const THEMES = [
      { bg: '#e8e0d0', ground: '#c8bca8', pipeTop: '#4a6b4a', pipeLip: '#3a5a3a' }, // Day
      { bg: '#d0b0a0', ground: '#a89080', pipeTop: '#4a3a30', pipeLip: '#2a1a10' }, // Dusk
      { bg: '#2a3b4c', ground: '#1a2b3c', pipeTop: '#2a5b6c', pipeLip: '#1a4b5c' }, // Night
      { bg: '#100820', ground: '#050210', pipeTop: '#6a1b9a', pipeLip: '#4a148c' }  // Deep Space
  ];
  let currentThemeIdx = 0;

  function resize() {
    const wrap = canvas.parentElement;
    canvas.width = wrap.clientWidth;
    canvas.height = wrap.clientHeight;
    GRAVITY = canvas.height * 0.0006;
    FLAP = -canvas.height * 0.011;
    PIPE_W = canvas.width * 0.12;
    GAP = canvas.height * 0.28;
    PIPE_SPEED = canvas.width * 0.006;
    if (!running) { drawBg(); drawBird(); }
  }

  function getTheme() {
      // Advance theme every 10 points, maxing out at Deep Space
      const targetIdx = Math.min(Math.floor(score / 10), THEMES.length - 1);
      return THEMES[targetIdx];
  }

  function drawBg() {
    const theme = getTheme();
    ctx.fillStyle = theme.bg;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Ground line
    ctx.fillStyle = theme.ground;
    ctx.fillRect(0, canvas.height - 20, canvas.width, 20);
  }

  function drawBird() {
    const bx = bird ? bird.x : canvas.width * 0.2;
    const by = bird ? bird.y : canvas.height / 2;
    const r = bird ? bird.r : canvas.width * 0.045;
    const angle = bird ? Math.min(Math.PI / 4, Math.max(-Math.PI / 4, bird.vy * 0.05)) : 0;

    ctx.save();
    ctx.translate(bx, by);
    ctx.rotate(angle);
    
    // Body
    ctx.fillStyle = '#1c1814';
    ctx.beginPath();
    ctx.ellipse(0, 0, r * 1.1, r, 0, 0, Math.PI * 2);
    ctx.fill();

    // Wing
    ctx.fillStyle = '#3a3228';
    ctx.beginPath();
    ctx.ellipse(-r * 0.2, r * 0.2, r * 0.5, r * 0.3, -0.3, 0, Math.PI * 2);
    ctx.fill();

    // Eye
    ctx.fillStyle = 'white';
    ctx.beginPath();
    ctx.arc(r * 0.4, -r * 0.2, r * 0.3, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = '#1c1814';
    ctx.beginPath();
    ctx.arc(r * 0.5, -r * 0.2, r * 0.15, 0, Math.PI * 2);
    ctx.fill();

    // Beak
    ctx.fillStyle = score > 20 ? '#d4af37' : '#b37a4a'; // Gold beak at high scores
    ctx.beginPath();
    ctx.moveTo(r * 0.9, 0);
    ctx.lineTo(r * 1.4, r * 0.15);
    ctx.lineTo(r * 0.9, r * 0.3);
    ctx.fill();

    ctx.restore();
  }

  function init() {
    bird = { x: canvas.width * 0.2, y: canvas.height / 2, vy: 0, r: canvas.width * 0.045 };
    pipes = [];
    score = 0;
    scoreEl.textContent = '0';
    GAP = canvas.height * 0.28; // reset gap
    PIPE_SPEED = canvas.width * 0.006;
  }

  function spawnPipe() {
    // Gap decreases by 1% per point, down to a minimum of 20% height
    const dynamicGap = Math.max(canvas.height * 0.20, GAP - (canvas.height * 0.003 * score));
    const minH = canvas.height * 0.1;
    const maxH = canvas.height - dynamicGap - minH - 20;
    
    // As score increases, allow wilder swings in pipe height difference from previous
    let h;
    if (pipes.length > 0 && score < 15) {
        // Restrict delta early on
        const lastH = pipes[pipes.length-1].h;
        const maxDelta = canvas.height * 0.3;
        const minBound = Math.max(minH, lastH - maxDelta);
        const maxBound = Math.min(maxH, lastH + maxDelta);
        h = minBound + Math.random() * (maxBound - minBound);
    } else {
        // Totally random later
        h = minH + Math.random() * (maxH - minH);
    }
    
    pipes.push({ x: canvas.width, h, gap: dynamicGap, passed: false });
  }

  function draw() {
    drawBg();
    const theme = getTheme();

    // Pipes
    pipes.forEach(p => {
      ctx.fillStyle = theme.pipeTop;
      // Top pipe
      ctx.fillRect(p.x, 0, PIPE_W, p.h);
      ctx.fillStyle = theme.pipeLip;
      ctx.fillRect(p.x - 4, p.h - 20, PIPE_W + 8, 20);
      
      // Bottom pipe
      ctx.fillStyle = theme.pipeTop;
      ctx.fillRect(p.x, p.h + p.gap, PIPE_W, canvas.height - p.h - p.gap);
      ctx.fillStyle = theme.pipeLip;
      ctx.fillRect(p.x - 4, p.h + p.gap, PIPE_W + 8, 20);
    });

    drawBird();

    // Score on canvas
    ctx.fillStyle = getTheme() === THEMES[0] ? '#1c1814' : 'rgba(255,255,255,0.8)';
    ctx.font = `bold ${canvas.width * 0.08}px sans-serif`;
    ctx.textAlign = 'center';
    ctx.fillText(score, canvas.width / 2, canvas.height * 0.15);
  }

  function update() {
    bird.vy += GRAVITY;
    bird.y += bird.vy;

    if (bird.y + bird.r > canvas.height - 20 || bird.y - bird.r < 0) return endGame();

    for (const p of pipes) {
      p.x -= PIPE_SPEED;
      
      // Collision
      if (bird.x + bird.r > p.x && bird.x - bird.r < p.x + PIPE_W) {
        if (bird.y - bird.r < p.h || bird.y + bird.r > p.h + p.gap) return endGame();
      }
      
      // Scoring (only once per pipe)
      if (!p.passed && p.x + PIPE_W < bird.x - bird.r) {
        score++;
        p.passed = true;
        scoreEl.textContent = String(score);
        PIPE_SPEED = canvas.width * 0.006 + score * 0.00015 * canvas.width;
      }
    }

    pipes = pipes.filter(p => p.x + PIPE_W > 0);
    
    // Spawn logic based on speed so they don't overlap or space too far
    const lastPipe = pipes[pipes.length - 1];
    if (!lastPipe || lastPipe.x < canvas.width - canvas.width * 0.55 - (score * 2)) {
        spawnPipe();
    }

    draw();
    gameLoop = requestAnimationFrame(update);
  }

  function flap() {
    if (!running) return;
    bird.vy = FLAP;
  }

  function startGame() {
    running = true;
    overlay.classList.add('hidden');
    init();
    spawnPipe();
    gameLoop = requestAnimationFrame(update);
  }

  function endGame() {
    running = false;
    cancelAnimationFrame(gameLoop);
    
    let bestMsg = '';
    if (score > bestScore) {
        bestScore = score;
        localStorage.setItem('flappy-best', bestScore);
        bestMsg = `<br/><span style="color:var(--accent);">New Best!</span>`;
    } else {
        bestMsg = `<br/>Best: ${bestScore}`;
    }
    
    overlay.classList.remove('hidden');
    overlayTitle.textContent = `Score: ${score}`;
    overlaySub.innerHTML = (score >= 5 ? 'Decent flying!' : 'Watch those pipes!') + bestMsg;
    startBtn.textContent = 'Try Again';
  }

  // Header display max
  if (bestScore > 0) {
      const bestDiv = document.createElement('div');
      bestDiv.style.fontSize = '0.75rem';
      bestDiv.style.color = 'var(--ink-light)';
      bestDiv.textContent = `Best: ${bestScore}`;
      document.querySelector('.score-wrap').appendChild(bestDiv);
  }

  startBtn.addEventListener('click', startGame);
  window.addEventListener('keydown', e => { if (e.code === 'Space') { e.preventDefault(); flap(); } });
  canvas.addEventListener('click', flap);
  canvas.addEventListener('touchstart', e => { e.preventDefault(); flap(); }, { passive: false });
  window.addEventListener('resize', resize);
  resize();
</script>
