---
import Base from '../../layouts/Base.astro';
---

<Base title="Flappy Bird">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Flappy Bird</h1>
      <div class="score-wrap">Score: <span id="score">0</span></div>
    </div>
  </div>

  <div class="game-wrap">
    <canvas id="flappy-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Flappy Bird</div>
        <div id="overlay-sub" class="overlay-sub">Tap to flap. Don't hit the pipes.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap anywhere to fly</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  .score-wrap { font-family: var(--font-sans); font-size: 0.8rem; color: var(--ink-light); }
  #score { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
    aspect-ratio: 0.75;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    overflow: hidden;
  }

  #flappy-canvas { display: block; width: 100%; height: 100%; }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(242, 237, 228, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn {
    margin-top: 1.5rem;
    padding: 0.6rem 1.5rem;
    background: transparent;
    border: 1.5px solid var(--accent);
    color: var(--accent);
    font-family: var(--font-sans);
    text-transform: uppercase;
    cursor: pointer;
  }
  .hint { font-family: var(--font-sans); font-size: 0.65rem; color: var(--ink-light); text-align: center; margin-top: 1.5rem; text-transform: uppercase; }
</style>

<script>
  const canvas = document.getElementById('flappy-canvas');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  const startBtn = document.getElementById('start-btn');

  let bird, pipes, score, gameLoop, running = false;
  const GRAVITY = 0.25;
  const FLAP = -4.5;
  const PIPE_WIDTH = 50;
  const GAP = 120;

  function init() {
    bird = { x: 50, y: canvas.height / 2, vy: 0, radius: 10 };
    pipes = [];
    score = 0;
    scoreEl.textContent = '0';
  }

  function spawnPipe() {
    const minH = 50;
    const maxH = canvas.height - GAP - minH;
    const h = Math.floor(Math.random() * (maxH - minH + 1)) + minH;
    pipes.push({ x: canvas.width, h: h });
  }

  function draw() {
    ctx.fillStyle = '#e8e0d0'; // var(--paper-dark)
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    // Bird
    ctx.fillStyle = '#1c1814'; // var(--ink)
    ctx.beginPath();
    ctx.arc(bird.x, bird.y, bird.radius, 0, Math.PI * 2);
    ctx.fill();

    // Pipes
    ctx.fillStyle = '#8b3a2a'; // var(--accent)
    pipes.forEach(p => {
      ctx.fillRect(p.x, 0, PIPE_WIDTH, p.h);
      ctx.fillRect(p.x, p.h + GAP, PIPE_WIDTH, canvas.height);
    });
  }

  function update() {
    bird.vy += GRAVITY;
    bird.y += bird.vy;

    if (bird.y + bird.radius > canvas.height || bird.y - bird.radius < 0) return endGame();

    pipes.forEach(p => {
      p.x -= 2;
      // Collision
      if (bird.x + bird.radius > p.x && bird.x - bird.radius < p.x + PIPE_WIDTH) {
        if (bird.y - bird.radius < p.h || bird.y + bird.radius > p.h + GAP) return endGame();
      }
      // Score
      if (p.x + PIPE_WIDTH === bird.x) {
        score++;
        scoreEl.textContent = String(score);
      }
    });

    pipes = pipes.filter(p => p.x + PIPE_WIDTH > 0);
    if (pipes.length === 0 || pipes[pipes.length - 1].x < canvas.width - 180) spawnPipe();

    draw();
    gameLoop = requestAnimationFrame(update);
  }

  function startGame() {
    running = true;
    overlay.classList.add('hidden');
    init();
    spawnPipe();
    update();
  }

  function endGame() {
    running = false;
    cancelAnimationFrame(gameLoop);
    overlay.classList.remove('hidden');
    overlayTitle.textContent = `Score: ${score}`;
    overlaySub.textContent = "Ouch! Watch those pipes.";
    startBtn.textContent = "Try Again";
  }

  function flap() {
    if (!running) return;
    bird.vy = FLAP;
  }

  canvas.width = 300;
  canvas.height = 400;
  draw();

  startBtn.addEventListener('click', startGame);
  window.addEventListener('keydown', e => { if (e.code === 'Space') flap(); });
  canvas.addEventListener('mousedown', flap);
  canvas.addEventListener('touchstart', e => { e.preventDefault(); flap(); }, { passive: false });
</script>
