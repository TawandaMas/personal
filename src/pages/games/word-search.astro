---
import Base from '../../layouts/Base.astro';
---

<Base title="Word Search">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Word Search</h1>
      <div class="score-wrap">Found: <span id="found">0</span>/<span id="total">0</span></div>
    </div>
  </div>

  <div class="game-wrap">
    <div id="grid" class="search-grid"></div>
    <div class="word-list-pane">
        <h3>Find these words:</h3>
        <ul id="word-list"></ul>
    </div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Word Search</div>
        <div id="overlay-sub" class="overlay-sub">Find all the hidden words in the grid. Drag to select.</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap letters to select words · Highlight full words to find them</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #found { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
  }
  @media (max-width: 600px) { .game-wrap { flex-direction: column; } }

  .search-grid {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: 2px;
    background: var(--rule);
    aspect-ratio: 1;
    width: 100%;
    max-width: 350px;
    user-select: none;
  }

  .letter {
    background: var(--paper);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .letter.selected { background: var(--accent); color: white; }
  .letter.dragging { background: rgba(139,58,42,0.3); }
  .letter.found { background: rgba(74,107,74,0.15); color: #4a6b4a; font-weight: 700; }

  .word-list-pane { flex: 1; font-family: var(--font-sans); font-size: 0.85rem; }
  .word-list-pane h3 { margin-bottom: 0.75rem; color: var(--ink-mid); font-size: 0.9rem; border-bottom: 1px solid var(--rule); padding-bottom: 0.4rem; }
  #word-list { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; }
  #word-list li.found { text-decoration: line-through; opacity: 0.5; color: var(--accent); }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

<script>
  const WORD_SETS = [['ASTRO', 'CARDS', 'GAMES', 'LOGIC', 'PIXEL', 'SPACE', 'CODE'], ['BOOK', 'PAPER', 'INK', 'SHELF', 'READ', 'STORY'], ['WEB', 'REACT', 'HTML', 'STYLE', 'DOM', 'APP']];
  const gridEl = document.getElementById('grid');
  const listEl = document.getElementById('word-list');
  const foundEl = document.getElementById('found');
  const totalEl = document.getElementById('total');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');

  let grid = [];
  let targetWords = [];
  let foundWords = [];
  let selection = [];

  function initGame() {
    targetWords = WORD_SETS[Math.floor(Math.random() * WORD_SETS.length)];
    foundWords = [];
    foundEl.textContent = '0';
    totalEl.textContent = String(targetWords.length);
    
    // Create empty grid
    grid = Array.from({length: 10}, () => Array(10).fill(''));
    
    // Place words
    targetWords.forEach(word => {
        let placed = false;
        while (!placed) {
            const dir = Math.random() > 0.5 ? 'H' : 'V';
            const r = Math.floor(Math.random() * 10);
            const c = Math.floor(Math.random() * 10);
            if (canPlace(word, r, c, dir)) {
                for (let i=0; i<word.length; i++) {
                    if (dir === 'H') grid[r][c+i] = word[i];
                    else grid[r+i][c] = word[i];
                }
                placed = true;
            }
        }
    });

    // Fill empty holes
    const abc = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    for (let r=0; r<10; r++) {
        for (let c=0; c<10; c++) {
            if (grid[r][c] === '') grid[r][c] = abc[Math.floor(Math.random()*26)];
        }
    }

    render();
  }

  function canPlace(word, r, c, dir) {
    if (dir === 'H' && c + word.length > 10) return false;
    if (dir === 'V' && r + word.length > 10) return false;
    for (let i=0; i<word.length; i++) {
        const char = dir === 'H' ? grid[r][c+i] : grid[r+i][c];
        if (char !== '' && char !== word[i]) return false;
    }
    return true;
  }

  function render() {
    gridEl.innerHTML = '';
    for (let r = 0; r < 10; r++) {
      for (let c = 0; c < 10; c++) {
        const div = document.createElement('div');
        div.className = 'letter';
        div.textContent = grid[r][c];
        div.dataset.r = r;
        div.dataset.c = c;
        gridEl.appendChild(div);
      }
    }

    listEl.innerHTML = '';
    targetWords.forEach(word => {
      const li = document.createElement('li');
      li.textContent = word;
      if (foundWords.includes(word)) li.className = 'found';
      listEl.appendChild(li);
    });

    // Restore found state
    document.querySelectorAll('.found-cell').forEach(el => el.classList.add('found'));
  }

  let isDragging = false;
  let dragStart = null;
  let dragCells = [];
  const foundCellKeys = new Set();

  function getCellAt(clientX, clientY) {
    const el = document.elementFromPoint(clientX, clientY);
    if (el && el.classList.contains('letter')) return el;
    return null;
  }

  function getLine(startEl, endEl) {
    const r1 = parseInt(startEl.dataset.r), c1 = parseInt(startEl.dataset.c);
    const r2 = parseInt(endEl.dataset.r), c2 = parseInt(endEl.dataset.c);
    const dr = Math.sign(r2 - r1), dc = Math.sign(c2 - c1);
    const cells = [];
    let r = r1, c = c1;
    while (true) {
      const el = gridEl.querySelector(`[data-r="${r}"][data-c="${c}"]`);
      if (el) cells.push(el);
      if (r === r2 && c === c2) break;
      r += dr; c += dc;
    }
    return cells;
  }

  function highlightDrag(cells) {
    document.querySelectorAll('.letter.dragging').forEach(el => el.classList.remove('dragging'));
    cells.forEach(el => el.classList.add('dragging'));
    dragCells = cells;
  }

  function commitSelection() {
    const word = dragCells.map(el => el.textContent).join('');
    const revWord = word.split('').reverse().join('');
    const match = targetWords.find(w => (w === word || w === revWord) && !foundWords.includes(w));
    if (match) {
      foundWords.push(match);
      dragCells.forEach(el => {
        el.classList.remove('dragging');
        el.classList.add('found');
        foundCellKeys.add(`${el.dataset.r},${el.dataset.c}`);
      });
      foundEl.textContent = String(foundWords.length);
      render();
      // Restore found cells
      foundCellKeys.forEach(key => {
        const [r, c] = key.split(',');
        const el = gridEl.querySelector(`[data-r="${r}"][data-c="${c}"]`);
        if (el) el.classList.add('found');
      });
      if (foundWords.length === targetWords.length) endGame();
    } else {
      document.querySelectorAll('.letter.dragging').forEach(el => el.classList.remove('dragging'));
    }
    dragCells = [];
    dragStart = null;
    isDragging = false;
  }

  // Mouse events
  gridEl.addEventListener('mousedown', e => {
    const cell = e.target.closest('.letter');
    if (cell) { isDragging = true; dragStart = cell; highlightDrag([cell]); }
  });
  gridEl.addEventListener('mousemove', e => {
    if (!isDragging || !dragStart) return;
    const cell = e.target.closest('.letter');
    if (cell) highlightDrag(getLine(dragStart, cell));
  });
  window.addEventListener('mouseup', () => { if (isDragging) commitSelection(); isDragging = false; });

  // Touch events
  gridEl.addEventListener('touchstart', e => {
    e.preventDefault();
    const cell = getCellAt(e.touches[0].clientX, e.touches[0].clientY);
    if (cell) { isDragging = true; dragStart = cell; highlightDrag([cell]); }
  }, { passive: false });
  gridEl.addEventListener('touchmove', e => {
    e.preventDefault();
    if (!isDragging || !dragStart) return;
    const cell = getCellAt(e.touches[0].clientX, e.touches[0].clientY);
    if (cell) highlightDrag(getLine(dragStart, cell));
  }, { passive: false });
  gridEl.addEventListener('touchend', e => {
    e.preventDefault();
    if (isDragging) commitSelection();
  }, { passive: false });

  function startGame() {
    foundCellKeys.clear();
    overlay.classList.add('hidden');
    initGame();
  }

  function endGame() {
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = 'Excellent!';
    document.getElementById('overlay-sub').textContent = 'All words discovered. Sharp eyes!';
    startBtn.textContent = 'Play Again';
  }

  startBtn.addEventListener('click', startGame);
</script>
