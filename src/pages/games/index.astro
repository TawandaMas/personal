---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const gameFiles = await getCollection('games');
const games = gameFiles
  .map(g => ({ slug: g.slug, ...g.data }))
  .sort((a, b) => (a.order || 99) - (b.order || 99));
---

<Base title="Games">
  <div class="page-header">
    <h1>Games</h1>
    <p>Small things you can actually play.</p>
  </div>

  <div class="games-grid">
    {games.map(game => (
      <a href={`/games/${game.slug}`} class="game-card">
        <div class="game-tag">{game.tag}</div>
        <h2 class="game-title">{game.title}</h2>
        <p class="game-desc">{game.description}</p>
        <div class="play-cta">Play →</div>
      </a>
    ))}
  </div>
</Base>

<style>
  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    padding-top: 1rem;
  }

  .game-card {
    background: var(--bg);
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    border: var(--border-w) solid var(--rule);
    box-shadow: 4px 4px 0 var(--rule);
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
  }

  .game-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0 var(--accent);
    border-color: var(--ink);
  }

  .game-card:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 var(--ink);
  }

  .game-tag {
    display: inline-block;
    width: fit-content;
    padding: 0.2rem 0.6rem;
    background: var(--accent-light);
    border: 2px solid var(--rule);
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .game-title {
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.1;
  }

  .game-desc {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-mid);
    line-height: 1.5;
    flex: 1;
    margin-top: 0.5rem;
  }

  .play-cta {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    color: var(--ink);
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .game-card:hover .play-cta {
    color: var(--accent);
  }
</style>
