---
import Base from '../../layouts/Base.astro';
---

<Base title="Typing Test">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Typing Test</h1>
      <div class="score-wrap">WPM: <span id="wpm">0</span> · Acc: <span id="acc">100</span>%</div>
    </div>
  </div>

  <div class="game-wrap">
    <div id="text-display" class="typing-text"></div>
    <textarea id="input-field" class="typing-input" placeholder="Start typing here..." autofocus></textarea>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Typing Test</div>
        <div id="overlay-sub" class="overlay-sub">Type the passage as fast and accurately as you can.</div>
        <button id="start-btn" class="start-btn">Start Test</button>
      </div>
    </div>
  </div>

  <div class="hint">Focus on accuracy first · The timer starts on your first keypress</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #wpm, #acc { color: var(--accent); font-weight: 500; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .typing-text {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--ink-mid);
    user-select: none;
    background: var(--paper);
    padding: 1rem;
    border: 1px solid var(--rule);
    min-height: 150px;
  }

  .typing-text span { position: relative; }
  .typing-text span.correct { color: #4a6b4a; }
  .typing-text span.wrong { color: #b34a3b; border-bottom: 2px solid #b34a3b; }
  .typing-text span.current { background: rgba(139, 58, 42, 0.1); border-left: 2px solid var(--accent); }

  .typing-input {
    width: 100%;
    height: 100px;
    background: var(--paper);
    border: 1.5px solid var(--rule);
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: var(--ink);
    resize: none;
    outline: none;
  }
  .typing-input:focus { border-color: var(--accent); }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

<script>
const FALLBACK_PASSAGES = [
    "The library was a silent cathedral of paper and ink, where every shelf held a thousand lives waiting to be relived through the eyes of a reader.",
    "Technology is a mirror that reflects our own creativity, yet at its best, it acts as a lens that clarifies the complexities of the human condition.",
    "Design is not just what it looks like and feels like. Design is how it works, and how it makes the user feel in the moment of interaction.",
    "A journey of a thousand miles begins with a single step, but the most important steps are the ones we take when we are tired and want to turn back.",
    "The stars above have fascinated humanity since we first looked up, reminding us that we are part of something vast, ancient, and beautiful.",
    "To plant a garden is to believe in tomorrow. The quiet patience of tending to seeds mirrors the discipline required to cultivate a meaningful life.",
    "Courage is not the absence of fear, but rather the assessment that something else is more important than fear. Action conquers the hesitation.",
    "Language is the profound capacity to translate the invisible architecture of thoughts into vibrations of air that another mind can reconstruct.",
    "In the deepest winters of the soul, one must remember that an invincible summer lies within, waiting for the courage to melt the frost away.",
    "Art washes away from the soul the dust of everyday life, leaving behind a vibrant canvas where imagination can paint without consequence or limit."
  ];

  const displayEl = document.getElementById('text-display');
  const inputEl = document.getElementById('input-field');
  const wpmEl = document.getElementById('wpm');
  const accEl = document.getElementById('acc');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  const startBtn = document.getElementById('start-btn');

  let text = '';
  let startTime = 0;
  let timerInterval = null;
  let active = false;
  let totalKeystrokes = 0;
  let correctKeystrokes = 0;
  
  let bestWPM = parseInt(localStorage.getItem('typing-best') || 0);

  // Inject best score into header
  if (bestWPM > 0) {
      const bestDiv = document.createElement('div');
      bestDiv.style.fontSize = '0.75rem';
      bestDiv.style.color = 'var(--ink-light)';
      bestDiv.style.marginTop = '0.2rem';
      bestDiv.textContent = `Best: ${bestWPM} WPM`;
      document.querySelector('.score-wrap').appendChild(bestDiv);
  }

  async function fetchQuote() {
      try {
          // Public quote API (doesn't require key, CORS friendly usually)
          const res = await fetch('https://api.quotable.io/random?minLength=100&maxLength=250');
          if (!res.ok) throw new Error('API failed');
          const data = await res.json();
          return data.content;
      } catch (e) {
          console.log("Using fallback quote");
          return FALLBACK_PASSAGES[Math.floor(Math.random() * FALLBACK_PASSAGES.length)];
      }
  }

  async function initTest() {
    startBtn.textContent = 'Loading...';
    startBtn.disabled = true;
    
    text = await fetchQuote();
    
    startBtn.textContent = 'Start Test';
    startBtn.disabled = false;
    
    displayEl.innerHTML = '';
    text.split('').forEach((char, i) => {
        const span = document.createElement('span');
        span.textContent = char;
        if (i === 0) span.classList.add('current');
        displayEl.appendChild(span);
    });
    
    inputEl.value = '';
    inputEl.disabled = false;
    wpmEl.textContent = '0';
    accEl.textContent = '100';
    active = false;
    totalKeystrokes = 0;
    correctKeystrokes = 0;
  }

  inputEl.addEventListener('input', (e) => {
    // Prevent typing further if the last character typed was wrong (forces correction)
    const typed = inputEl.value;
    
    if (!active && typed.length > 0) {
        active = true;
        startTime = Date.now();
        timerInterval = setInterval(updateStats, 500);
    }
    
    if (e.inputType !== 'deleteContentBackward') totalKeystrokes++;

    const spans = displayEl.querySelectorAll('span');
    let mistakes = 0;
    let isCurrentWrong = false;

    spans.forEach((span, i) => {
        span.className = '';
        if (i < typed.length) {
            if (typed[i] === text[i]) {
                span.classList.add('correct');
                if (i === typed.length - 1 && e.inputType !== 'deleteContentBackward') {
                    correctKeystrokes++;
                }
            } else {
                span.classList.add('wrong');
                mistakes++;
                isCurrentWrong = true;
            }
        }
        if (i === typed.length) span.classList.add('current');
    });

    const acc = Math.max(0, Math.round((correctKeystrokes / totalKeystrokes) * 100)) || 100;
    accEl.textContent = String(acc);
    
    // Stop progression if there's a mistake anywhere in the typed text
    if (mistakes > 0) {
        inputEl.style.borderColor = 'var(--error, #d9534f)';
        inputEl.style.background = 'rgba(217, 83, 79, 0.05)';
    } else {
        inputEl.style.borderColor = 'var(--accent)';
        inputEl.style.background = 'var(--paper)';
        // Only end if everything is right
        if (typed.length === text.length) endGame();
    }
  });

  function updateStats() {
    const elapsed = (Date.now() - startTime) / 1000 / 60; // minutes
    const words = inputEl.value.length / 5;
    const wpm = Math.round(words / elapsed);
    wpmEl.textContent = String(wpm > 0 && wpm < 500 ? wpm : 0); // basic sanity check
  }

  function startGame() {
    overlay.classList.add('hidden');
    inputEl.focus();
  }

  function endGame() {
    active = false;
    clearInterval(timerInterval);
    updateStats();
    inputEl.disabled = true;
    
    const finalWPM = parseInt(wpmEl.textContent);
    let bestMsg = '';
    
    if (finalWPM > bestWPM) {
        bestWPM = finalWPM;
        localStorage.setItem('typing-best', bestWPM);
        bestMsg = `<br/><span style="color:var(--accent);">New Best!</span>`;
    } else {
        bestMsg = `<br/>Best: ${bestWPM} WPM`;
    }
    
    overlay.classList.remove('hidden');
    overlayTitle.textContent = `${finalWPM} WPM`;
    overlaySub.innerHTML = `Accuracy: ${accEl.textContent}%${bestMsg}`;
    startBtn.textContent = 'Next Quote';
    initTest(); // Pre-load next
  }

  startBtn.addEventListener('click', startGame);
  initTest();
</script>

