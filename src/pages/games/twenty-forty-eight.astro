---
import Base from '../../layouts/Base.astro';
---

<Base title="2048">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>2048</h1>
      <div class="score-wrap">Score: <span id="score">0</span></div>
    </div>
  </div>

  <div class="game-wrap" id="game-container">
    <div id="grid" class="grid-2048"></div>

    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">2048</div>
        <div id="overlay-sub" class="overlay-sub">Swipe to merge matching tiles. Reach 2048!</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Use Arrow Keys or Swipe</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative;
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
    aspect-ratio: 1;
    border: 1.5px solid var(--rule);
    background: var(--paper-dark);
    padding: 0.5rem;
    border-radius: 8px;
  }

  .grid-2048 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(4, 1fr);
    gap: 0.5rem;
    width: 100%;
    height: 100%;
  }

  .tile {
    background: rgba(200, 188, 168, 0.3); /* var(--rule) with alpha */
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--ink);
    transition: all 0.1s;
  }

  .tile[data-value="2"] { background: #eee4da; }
  .tile[data-value="4"] { background: #ede0c8; }
  .tile[data-value="8"] { background: #f2b179; color: white; }
  .tile[data-value="16"] { background: #f59563; color: white; }
  .tile[data-value="32"] { background: #f67c5f; color: white; }
  .tile[data-value="64"] { background: #f65e3b; color: white; }
  .tile[data-value="128"] { background: #edcf72; color: white; font-size: 1.25rem; }
  .tile[data-value="256"] { background: #edcc61; color: white; font-size: 1.25rem; }
  .tile[data-value="512"] { background: #edc850; color: white; font-size: 1.25rem; }
  .tile[data-value="1024"] { background: #edc53f; color: white; font-size: 1rem; }
  .tile[data-value="2048"] { background: #edc22e; color: white; font-size: 1rem; }

  .overlay {
    position: absolute;
    inset: 0;
    background: var(--paper);
    opacity: 0.98;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn { 
    margin-top: 1.5rem; 
    padding: 0.75rem 2rem; 
    background: var(--ink); 
    color: var(--paper);
    border: none;
    border-radius: 2rem;
    font-family: var(--font-sans); 
    font-weight: 600;
    text-transform: uppercase; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
</style>

  const gridEl = document.getElementById('grid');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const startBtn = document.getElementById('start-btn');
  
  // Add Undo and Best Score UI
  const headerWrap = document.querySelector('.score-wrap');
  const bestEl = document.createElement('div');
  bestEl.style.fontSize = '0.75rem';
  bestEl.style.color = 'var(--ink-light)';
  bestEl.textContent = `Best: ${localStorage.getItem('2048-best') || 0}`;
  headerWrap.appendChild(bestEl);

  const undoBtn = document.createElement('button');
  undoBtn.textContent = 'Undo';
  undoBtn.style.cssText = 'background:var(--rule); border:none; padding:4px 8px; border-radius:4px; cursor:pointer; font-family:var(--font-sans); font-size:0.75rem; color:var(--ink); margin-top:4px;';
  undoBtn.onclick = undoMove;
  headerWrap.appendChild(undoBtn);

  let board = [];
  let score = 0;
  let history = []; // stores {board, score}
  let bestScore = parseInt(localStorage.getItem('2048-best') || 0);

  function initBoard() {
    board = Array(4).fill().map(() => Array(4).fill(0));
    score = 0;
    history = [];
    addTile();
    addTile();
    render();
    undoBtn.disabled = true;
    undoBtn.style.opacity = '0.5';
  }

  function addTile() {
    let empty = [];
    for (let r=0; r<4; r++) {
      for (let c=0; c<4; c++) {
        if (board[r][c] === 0) empty.push({r, c});
      }
    }
    if (empty.length > 0) {
      let {r, c} = empty[Math.floor(Math.random() * empty.length)];
      board[r][c] = Math.random() < 0.9 ? 2 : 4;
    }
  }

  function render() {
    gridEl.innerHTML = '';
    board.forEach(row => {
      row.forEach(val => {
        const tile = document.createElement('div');
        tile.className = 'tile';
        if (val > 0) {
          tile.textContent = val;
          tile.dataset.value = val;
        }
        gridEl.appendChild(tile);
      });
    });
    scoreEl.textContent = String(score);
    if (score > bestScore) {
        bestScore = score;
        localStorage.setItem('2048-best', bestScore);
        bestEl.textContent = `Best: ${bestScore}`;
    }
    undoBtn.disabled = history.length === 0;
    undoBtn.style.opacity = history.length === 0 ? '0.5' : '1';
  }

  function saveState() {
      history.push({ board: JSON.parse(JSON.stringify(board)), score: score });
      if (history.length > 5) history.shift(); // keep last 5
  }

  function undoMove() {
      if (history.length > 0) {
          const prev = history.pop();
          board = prev.board;
          score = prev.score;
          render();
      }
  }

  function slide(row) {
    let arr = row.filter(val => val !== 0);
    for (let i = 0; i < arr.length - 1; i++) {
        if (arr[i] === arr[i + 1]) {
            arr[i] *= 2;
            score += arr[i];
            arr.splice(i + 1, 1);
        }
    }
    while (arr.length < 4) arr.push(0);
    return arr;
  }

  function move(dir) {
    let oldBoard = JSON.stringify(board);
    saveState(); // push current before changes
    
    let newBoard = Array(4).fill().map(() => Array(4).fill(0));

    if (dir === 'left') {
        newBoard = board.map(row => slide([...row]));
    } else if (dir === 'right') {
        newBoard = board.map(row => slide([...row].reverse()).reverse());
    } else if (dir === 'up') {
        for (let c = 0; c < 4; c++) {
            let col = [board[0][c], board[1][c], board[2][c], board[3][c]];
            col = slide(col);
            for (let r = 0; r < 4; r++) newBoard[r][c] = col[r];
        }
    } else if (dir === 'down') {
        for (let c = 0; c < 4; c++) {
            let col = [board[3][c], board[2][c], board[1][c], board[0][c]];
            col = slide(col);
            for (let r = 0; r < 4; r++) newBoard[3-r][c] = col[r];
        }
    }

    if (oldBoard !== JSON.stringify(newBoard)) {
        board = newBoard;
        addTile();
        render();
        if (isGameOver()) endGame();
    } else {
        history.pop(); // unused state
    }
  }

  function isGameOver() {
    for (let r=0; r<4; r++) {
      for (let c=0; c<4; c++) {
        if (board[r][c] === 0) return false;
        if (c < 3 && board[r][c] === board[r][c+1]) return false;
        if (r < 3 && board[r][c] === board[r+1][c]) return false;
      }
    }
    return true;
  }

  function startGame() {
    overlay.classList.add('hidden');
    initBoard();
  }

  function endGame() {
    overlay.classList.remove('hidden');
    document.getElementById('overlay-title').textContent = `Score: ${score}`;
    startBtn.textContent = 'Play Again';
  }

  startBtn.addEventListener('click', startGame);
  let isThrottled = false;
  window.addEventListener('keydown', e => {
    if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
      e.preventDefault();
      if (isThrottled) return;
      isThrottled = true;
      setTimeout(() => isThrottled = false, 100);
      move(e.key.replace('Arrow', '').toLowerCase());
    }
  });

  // Swipe support
  let touchStart = null;
  gridEl.addEventListener('touchstart', e => {
    e.preventDefault();
    touchStart = {x: e.touches[0].clientX, y: e.touches[0].clientY};
  }, { passive: false });
  gridEl.addEventListener('touchmove', e => e.preventDefault(), { passive: false });
  gridEl.addEventListener('touchend', e => {
    e.preventDefault();
    if (!touchStart) return;
    const dx = e.changedTouches[0].clientX - touchStart.x;
    const dy = e.changedTouches[0].clientY - touchStart.y;
    if (Math.abs(dx) > Math.abs(dy)) {
        if (Math.abs(dx) > 30) move(dx > 0 ? 'right' : 'left');
    } else {
        if (Math.abs(dy) > 30) move(dy > 0 ? 'down' : 'up');
    }
    touchStart = null;
  }, { passive: false });
</script>
