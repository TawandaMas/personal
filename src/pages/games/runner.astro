---
import Base from '../../layouts/Base.astro';
---

<Base title="Endless Runner">
  <div class="game-header">
    <a href="/games" class="back">← Games</a>
    <div class="game-title-row">
      <h1>Paper Run</h1>
      <div class="score-wrap">Distance: <span id="score">0</span>m</div>
    </div>
  </div>

  <div class="game-wrap" id="game-wrap">
    <canvas id="runner-canvas"></canvas>
    <div id="overlay" class="overlay">
      <div class="overlay-content">
        <div id="overlay-title" class="overlay-title">Paper Run</div>
        <div id="overlay-sub" class="overlay-sub">Jump over obstacles. Double-jump for high barriers!</div>
        <button id="start-btn" class="start-btn">Start Game</button>
      </div>
    </div>
  </div>

  <div class="hint">Tap, click, or press Space to jump · Double-tap to double-jump</div>
</Base>

<style>
  .game-header { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.75rem; }
  .back { font-family: var(--font-sans); font-size: 0.75rem; color: var(--ink-light); text-decoration: none; }
  .game-title-row { display: flex; align-items: baseline; justify-content: space-between; }
  .game-title-row h1 { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; font-weight: 400; }
  #score { color: var(--accent); font-weight: 500; font-size: 1rem; }

  .game-wrap {
    position: relative; width: 100%; max-width: 640px; margin: 0 auto;
    height: 35vh; min-height: 250px; max-height: 400px; border: 1.5px solid var(--rule);
    background: var(--paper-dark); overflow: hidden; touch-action: none; cursor: pointer;
  }

  #runner-canvas { display: block; width: 100%; height: 100%; }

  .overlay {
    position: absolute; inset: 0; background: var(--paper); opacity: 0.98;
    display: flex; align-items: center; justify-content: center; z-index: 10;
    border: 2px solid var(--rule);
  }
  .overlay.hidden { display: none; }
  .overlay-content { text-align: center; padding: 2rem; }
  .overlay-title { font-family: var(--font-serif); font-size: 2.5rem; font-style: italic; color: var(--accent); }
  .overlay-sub { font-family: var(--font-sans); font-size: 0.85rem; color: var(--ink-light); margin-top: 0.5rem; }
  .start-btn {
    margin-top: 1.5rem; padding: 0.75rem 2rem;
    background: var(--ink); color: var(--paper); border: none; border-radius: 2rem;
    font-family: var(--font-sans); font-weight: 600; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
  }
  .start-btn:hover { transform: scale(1.05); }
  .hint { font-family: var(--font-sans); font-size: 0.65rem; color: var(--ink-light); text-align: center; margin-top: 1.5rem; text-transform: uppercase; }
</style>

<script>
const canvas = document.getElementById('runner-canvas');
  const ctx = canvas.getContext('2d');
  const scoreEl = document.getElementById('score');
  const overlay = document.getElementById('overlay');
  const overlayTitle = document.getElementById('overlay-title');
  const overlaySub = document.getElementById('overlay-sub');
  const startBtn = document.getElementById('start-btn');

  let runner, obstacles, particles, score, gameLoop, running = false, speed, groundY;
  let parallaxLines = []; // mountains, trees
  
  let bestScore = parseInt(localStorage.getItem('runner-best') || 0);

  function resize() {
    const wrap = canvas.parentElement;
    canvas.width = wrap.clientWidth;
    canvas.height = wrap.clientHeight;
    groundY = canvas.height * 0.8;
    if (!running) drawIdle();
  }

  function drawIdle() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    drawGround();
    drawRunner();
  }

  function drawGround() {
    // Ground shadow
    ctx.fillStyle = 'rgba(180,156,120,0.3)';
    ctx.fillRect(0, groundY + 2, canvas.width, 4);
    // Ground line
    ctx.fillStyle = '#c8bca8';
    ctx.fillRect(0, groundY, canvas.width, 2);
  }

  function drawRunner() {
    if (!runner) return;
    const { x, y, w, h } = runner;
    const isOnGround = y + h >= groundY;
    
    // Shadow
    if (isOnGround) {
      ctx.fillStyle = 'rgba(0,0,0,0.08)';
      ctx.beginPath();
      ctx.ellipse(x + w / 2, groundY + 4, w * 0.7, 4, 0, 0, Math.PI * 2);
      ctx.fill();
    }

    // Body
    ctx.fillStyle = '#1c1814';
    ctx.fillRect(x, y, w, h * 0.7);
    
    // Head
    ctx.beginPath();
    ctx.arc(x + w / 2, y, w * 0.45, 0, Math.PI * 2);
    ctx.fill();

    // Legs (running animation)
    const legTime = Date.now() / 100;
    const leg1 = isOnGround ? Math.sin(legTime * (speed/2)) * 8 : (runner.vy > 0 ? 4 : -4);
    const leg2 = isOnGround ? -Math.sin(legTime * (speed/2)) * 8 : (runner.vy > 0 ? -2 : 6);
    
    ctx.strokeStyle = '#1c1814';
    ctx.lineWidth = 3;
    ctx.lineCap = 'round';
    
    ctx.beginPath();
    ctx.moveTo(x + w / 2, y + h * 0.7);
    ctx.lineTo(x + w / 2 + leg1, y + h);
    ctx.stroke();
    
    ctx.beginPath();
    ctx.moveTo(x + w / 2, y + h * 0.7);
    ctx.lineTo(x + w / 2 + leg2, y + h);
    ctx.stroke();
  }

  function init() {
    runner = { x: canvas.width * 0.12, y: groundY - canvas.height * 0.35, w: canvas.width * 0.04, h: canvas.height * 0.35, vy: 0, jumps: 0 };
    obstacles = [];
    particles = [];
    score = 0;
    speed = canvas.width * 0.007;
    scoreEl.textContent = '0';
    
    parallaxLines = [
        { type: 'cloud', speedMulti: 0.1, y: canvas.height * 0.15, items: [] },
        { type: 'mountain', speedMulti: 0.25, y: groundY, items: [] },
        { type: 'tree', speedMulti: 0.5, y: groundY, items: [] }
    ];
    
    // Initially populate somewhat
    for (let c of parallaxLines) {
        for(let i=0; i<3; i++) spawnBgItem(c, Math.random() * canvas.width);
    }
  }

  function spawnBgItem(layer, forceX = null) {
      if (layer.type === 'cloud') {
          layer.items.push({ x: forceX || canvas.width + 100, w: 40 + Math.random() * 40, h: 20 });
      } else if (layer.type === 'mountain') {
          const w = canvas.width * 0.3 + Math.random() * canvas.width * 0.2;
          const h = (groundY - canvas.height * 0.3) + Math.random() * 40;
          layer.items.push({ x: forceX || canvas.width + w, w, h });
      } else if (layer.type === 'tree') {
          const w = canvas.width * 0.05 + Math.random() * canvas.width * 0.05;
          const h = canvas.height * 0.3 + Math.random() * 40;
          layer.items.push({ x: forceX || canvas.width + w, w, h });
      }
  }

  function spawnObstacle() {
    const typeRnd = Math.random();
    let type = 'box'; // standard small box
    let y = groundY;
    let w = canvas.width * 0.025 + Math.random() * canvas.width * 0.02;
    let h = groundY * 0.25;
    
    if (score > 200 && typeRnd > 0.7) {
        type = 'tall_box';
        h = groundY * 0.55;
    } else if (score > 500 && typeRnd > 0.4 && typeRnd <= 0.7) {
        type = 'bird';
        y = groundY - runner.h * 1.5; // Requires ducking or jumping over, but we don't have duck. Make it jumpable but high
        w = canvas.width * 0.04;
        h = 10;
        // Actually, if we don't have duck, make the bird fly low so you *must* double jump it, or high so you *must* stay on ground
        y = Math.random() > 0.5 ? groundY - runner.h * 1.5 : groundY - runner.h * 0.6; // either high or low
    }
    
    if (type !== 'bird') y -= h;
    
    obstacles.push({ x: canvas.width + w, y: y, w, h, type });
  }

  function drawBgLayers() {
      // Clouds
      const clouds = parallaxLines[0];
      ctx.fillStyle = 'rgba(200,188,168,0.5)';
      clouds.items.forEach(c => {
          ctx.beginPath(); ctx.ellipse(c.x, c.y, c.w / 2, c.w / 4, 0, 0, Math.PI * 2); ctx.fill();
          ctx.beginPath(); ctx.ellipse(c.x + c.w * 0.2, c.y - c.w * 0.1, c.w / 4, c.w / 5, 0, 0, Math.PI * 2); ctx.fill();
      });
      
      // Mountains
      const mtns = parallaxLines[1];
      ctx.fillStyle = '#d8d0c0';
      mtns.items.forEach(m => {
          ctx.beginPath();
          ctx.moveTo(m.x - m.w/2, groundY);
          ctx.lineTo(m.x, groundY - m.h);
          ctx.lineTo(m.x + m.w/2, groundY);
          ctx.fill();
      });
      
      // Trees
      const trees = parallaxLines[2];
      trees.items.forEach(t => {
          ctx.fillStyle = '#8b7d6b'; // trunk
          ctx.fillRect(t.x - t.w*0.1, groundY - t.h*0.3, t.w*0.2, t.h*0.3);
          ctx.fillStyle = '#b8ac98'; // leaves
          ctx.beginPath();
          ctx.moveTo(t.x - t.w/2, groundY - t.h*0.2);
          ctx.lineTo(t.x, groundY - t.h);
          ctx.lineTo(t.x + t.w/2, groundY - t.h*0.2);
          ctx.fill();
      });
  }

  function draw() {
    ctx.fillStyle = '#e8e0d0';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    drawBgLayers();

    // Obstacles
    obstacles.forEach(o => {
      if (o.type === 'bird') {
          ctx.fillStyle = '#1c1814';
          ctx.beginPath();
          ctx.moveTo(o.x, o.y);
          ctx.lineTo(o.x + o.w/2, o.y + o.h);
          ctx.lineTo(o.x + o.w, o.y);
          ctx.lineTo(o.x + o.w/2, o.y + o.h/2);
          ctx.fill();
      } else {
          ctx.fillStyle = '#8b3a2a';
          ctx.fillRect(o.x, o.y, o.w, o.h + 2);
          ctx.fillStyle = '#6a2a1e';
          ctx.fillRect(o.x - 3, o.y, o.w + 6, 6);
      }
    });

    drawGround();
    drawRunner();

    // Particles
    particles.forEach(p => {
      ctx.globalAlpha = p.life;
      ctx.fillStyle = '#8b3a2a';
      ctx.fillRect(p.x, p.y, 3, 3);
    });
    ctx.globalAlpha = 1;

    // Score on canvas
    ctx.fillStyle = '#8a7d6a';
    ctx.font = `${canvas.height * 0.08}px sans-serif`;
    ctx.textAlign = 'right';
    ctx.fillText(Math.floor(score / 10) + 'm', canvas.width - 8, canvas.height * 0.12);
  }

  function update() {
    if (!running) return;
    speed += 0.001;
    score += speed;
    scoreEl.textContent = String(Math.floor(score / 10));

    // Physics
    runner.vy += canvas.height * 0.0015;
    runner.y += runner.vy;
    if (runner.y + runner.h >= groundY) {
      runner.y = groundY - runner.h;
      runner.vy = 0;
      runner.jumps = 0;
    }

    // Parallax
    parallaxLines.forEach(layer => {
        layer.items.forEach(item => { item.x -= speed * layer.speedMulti; });
        layer.items = layer.items.filter(item => item.x + item.w > -canvas.width);
        
        // Spawn chance based on type
        const spawnRates = { 'cloud': 0.01, 'mountain': 0.005, 'tree': 0.02 };
        if (Math.random() < spawnRates[layer.type]) spawnBgItem(layer);
    });

    // Obstacles
    obstacles.forEach(o => { 
        o.x -= speed;
        if (o.type === 'bird') o.x -= speed * 0.5; // Birds fly faster than ground obstacles
    });
    
    // Collision
    for (const o of obstacles) {
      const margin = runner.w * 0.15;
      
      // Hitbox logic slightly more forgiving
      if (runner.x + margin < o.x + o.w &&
          runner.x + runner.w - margin > o.x &&
          runner.y + margin < o.y + o.h &&
          runner.y + runner.h - margin > o.y) {
        
        spawnParticles();
        return endGame();
      }
    }

    obstacles = obstacles.filter(o => o.x + o.w > -100);
    const minGap = canvas.width * 0.4 + (speed * 10); // gap scales with speed
    if (obstacles.length === 0 || obstacles[obstacles.length - 1].x < canvas.width - minGap - Math.random() * canvas.width * 0.5) {
      spawnObstacle();
    }

    // Particles
    particles.forEach(p => { p.x += p.vx; p.y += p.vy; p.life -= 0.05; });
    particles = particles.filter(p => p.life > 0);

    draw();
    gameLoop = requestAnimationFrame(update);
  }

  function spawnParticles() {
    for (let i = 0; i < 15; i++) {
      particles.push({
        x: runner.x + runner.w / 2, y: runner.y + runner.h / 2,
        vx: (Math.random() - 0.5) * 8, vy: -Math.random() * 8,
        life: 1
      });
    }
  }

  function jump() {
    if (!running || runner.jumps >= 2) return;
    runner.vy = -(canvas.height * 0.020);
    runner.jumps++;
  }

  function startGame() {
    running = true;
    overlay.classList.add('hidden');
    init();
    gameLoop = requestAnimationFrame(update);
  }

  function endGame() {
    running = false;
    cancelAnimationFrame(gameLoop);
    
    let bestMsg = '';
    const finalScore = Math.floor(score / 10);
    if (finalScore > bestScore) {
        bestScore = finalScore;
        localStorage.setItem('runner-best', bestScore);
        bestMsg = `<br/><span style="color:var(--accent);">New Best!</span>`;
    } else {
        bestMsg = `<br/>Best: ${bestScore}m`;
    }
    
    overlayTitle.textContent = `${finalScore}m`;
    overlaySub.innerHTML = (finalScore > 100 ? 'Great run!' : 'Tripped up.') + bestMsg;
    
    overlay.classList.remove('hidden');
    startBtn.textContent = 'Run Again';
  }

  // Inject best score into header
  if (bestScore > 0) {
      const bestDiv = document.createElement('div');
      bestDiv.style.fontSize = '0.75rem';
      bestDiv.style.color = 'var(--ink-light)';
      bestDiv.textContent = `Best: ${bestScore}m`;
      document.querySelector('.score-wrap').appendChild(bestDiv);
  }

  startBtn.addEventListener('click', startGame);
  window.addEventListener('keydown', e => {
    if (e.code === 'Space' || e.code === 'ArrowUp') { e.preventDefault(); jump(); }
  });
  canvas.addEventListener('click', jump);
  canvas.addEventListener('touchstart', e => { e.preventDefault(); jump(); }, { passive: false });
  window.addEventListener('resize', resize);
  resize();
</script>

